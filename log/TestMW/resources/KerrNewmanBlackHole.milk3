  "image": "#define tx (sin(time)*0.5+1)\n\n// CONV: texture() ??? tex2Dlod LOD=0 (gradient-safe for loops)\nfloat4 tex2D_lod0(sampler2D _s, float2 _tc) {\n  return tex2Dlod(_s, float4(_tc, 0, 0));\n}\n\nfloat3 saturate(float3 x)\n{\n  return clamp(x, float3(0.0, 0.0, 0.0), float3(1.0, 1.0, 1.0));\n}\n\nfloat4 cubic(float x)\n{\n  float x2 = x * x;\n  float x3 = x2 * x;\n  float4 w;\n  w.x =   -x3 + 3.0*x2 - 3.0*x + 1.0;\n  w.y =  3.0*x3 - 6.0*x2       + 4.0;\n  w.z = -3.0*x3 + 3.0*x2 + 3.0*x + 1.0;\n  w.w =  x3;\n  return w / 6.0;\n}\n\nfloat4 BicubicTexture(in sampler2D tex, in float2 coord)\n{\n  float2 resolution = float3(texsize.x, texsize.y, 1.0).xy;\n\n  coord *= resolution;\n\n  float fx = frac(coord.x);\n  float fy = frac(coord.y);\n  coord.x -= fx;\n  coord.y -= fy;\n\n  fx -= 0.5;\n  fy -= 0.5;\n\n  float4 xcubic = cubic(fx);\n  float4 ycubic = cubic(fy);\n\n  float4 c = float4(coord.x - 0.5, coord.x + 1.5, coord.y - 0.5, coord.y + 1.5);\n  float4 s = float4(xcubic.x + xcubic.y, xcubic.z + xcubic.w, ycubic.x + ycubic.y, ycubic.z + ycubic.w);\n  float4 offset = c + float4(xcubic.y, xcubic.w, ycubic.y, ycubic.w) / s;\n\n  float4 sample0 = tex2D_lod0(tex, float2(offset.x, offset.z) / resolution);\n  float4 sample1 = tex2D_lod0(tex, float2(offset.y, offset.z) / resolution);\n  float4 sample2 = tex2D_lod0(tex, float2(offset.x, offset.w) / resolution);\n  float4 sample3 = tex2D_lod0(tex, float2(offset.y, offset.w) / resolution);\n\n  float sx = s.x / (s.x + s.y);\n  float sy = s.z / (s.z + s.w);\n\n  return lerp( lerp(sample3, sample2, sx), lerp(sample1, sample0, sx), sy);\n}\n\nfloat3 ColorFetch(float2 coord)\n{\n  return tex2D_lod0(sampler_feedback, coord).rgb;   \n}\n\nfloat3 BloomFetch(float2 coord)\n{\n  return BicubicTexture(sampler_bufferD, coord).rgb;   \n}\n\nfloat3 Grab(float2 coord, const float octave, const float2 offset)\n{\n  float scale = exp2(octave);\n\n  coord /= scale;\n  coord -= offset;\n\n  return BloomFetch(coord);\n}\n\nfloat2 CalcOffset(float octave)\n{\n  float2 offset = float2(0.0, 0.0);\n\n  float2 padding = float2(10.0, 10.0) / float3(texsize.x, texsize.y, 1.0).xy;\n\n  offset.x = -min(1.0, floor(octave / 3.0)) * (0.25 + padding.x);\n\n  offset.y = -(1.0 - (1.0 / exp2(octave))) - padding.y * octave;\n\n  offset.y += min(1.0, floor(octave / 3.0)) * 0.35;\n\n  return offset;   \n}\n\nfloat3 GetBloom(float2 coord)\n{\n  float3 bloom = float3(0.0, 0.0, 0.0);\n\n  bloom += Grab(coord, 1.0, ((float2)(CalcOffset(0.0)))) * 1.0;\n  bloom += Grab(coord, 2.0, ((float2)(CalcOffset(1.0)))) * 1.5;\n  bloom += Grab(coord, 3.0, ((float2)(CalcOffset(2.0)))) * 1.0;\n  bloom += Grab(coord, 4.0, ((float2)(CalcOffset(3.0)))) * 1.5;\n  bloom += Grab(coord, 5.0, ((float2)(CalcOffset(4.0)))) * 1.8;\n  bloom += Grab(coord, 6.0, ((float2)(CalcOffset(5.0)))) * 1.0;\n  bloom += Grab(coord, 7.0, ((float2)(CalcOffset(6.0)))) * 1.0;\n  bloom += Grab(coord, 8.0, ((float2)(CalcOffset(7.0)))) * 1.0;\n\n  return bloom;\n}\n\nshader_body {\n  float4 fragColor = 0;\n  float2 fragCoord = uv * texsize.xy;\n  #undef uv\n  #undef uv_orig\n  #undef mouse\n  #undef mouse_x\n  #undef mouse_y\n  #undef mouse_pos\n  #undef mouse_clicked\n  float2 uv = fragCoord.xy / float3(texsize.x, texsize.y, 1.0).xy;\n\n  float3 color = ColorFetch(uv);\n\n  color += GetBloom(uv) * 0.08;\n\n  color = pow(color, float3(1.5, 1.5, 1.5));\n  color = color / (1.0 + color);\n  color = pow(color, ((float3)(1.0 / 1.5)));\n\n  color = lerp(color, color * color * (3.0 - 2.0 * color), float3(1.0, 1.0, 1.0));\n  color = pow(color, float3(1.3, 1.20, 1.0));    \n\n  color = saturate(color * 1.01);\n\n  color = pow(color, ((float3)(0.7 / 2.2)));\n\n  fragColor = float4(color, 1.0);\n\n  ret = fragColor;\n}\n",
  "bufferA": "#define tx (sin(time)*0.5+1)\n\n// CONV: texelFetch for screen-sized textures\nfloat4 texelFetch_conv(sampler2D s, int2 c, int l) {\n  return tex2Dlod(s, float4((((float2)(c)) + 0.5) * texsize.zw, 0, l));\n}\n\n// CONV: adding helper functions\nfloat mod_conv(float x, float y) { return x - y * floor(x / y); }\nfloat2 mod_conv(float2 x, float2 y) { return x - y * floor(x / y); }\nfloat3 mod_conv(float3 x, float3 y) { return x - y * floor(x / y); }\nfloat4 mod_conv(float4 x, float4 y) { return x - y * floor(x / y); }\n\n#define iHistoryTex sampler_feedback\n#define textureQueryLod(s, d) float2(0.0, 0.0)\n\n#define iFovRadians  60.0 * 0.01745329\n#define iGrid           0      \n#define iObserverMode   0      \n\n#define iBlackHoleTime          (2.0*time) \n#define iBlackHoleMassSol       (1e7)     \n#define iSpin                   0.99      \n#define iQ                      0.0      \n\n#define iMu                     1.0      \n#define iAccretionRate          (5e-4)      \n\n#define iInterRadiusRs          1.5      \n#define iOuterRadiusRs          25.0     \n#define iThinRs                 0.75     \n#define iHopper                 0.24      \n#define iBrightmut              1.0      \n#define iDarkmut                0.5     \n#define iReddening              0.3      \n#define iSaturation             0.5      \n#define iBlackbodyIntensityExponent 0.5\n#define iRedShiftColorExponent      3.0\n#define iRedShiftIntensityExponent  4.0\n\n#define iPhotonRingBoost             7.0 \n#define iPhotonRingColorTempBoost    2.0 \n#define iBoostRot                    0.75 \n\n#define iJetRedShiftIntensityExponent 2.0\n#define iJetBrightmut           1.0\n#define iJetSaturation          0.0\n#define iJetShiftMax            3.0\n\n#define ENABLE_HEAT_HAZE        1       \n#define HAZE_STRENGTH           0.2    \n#define HAZE_SCALE              5.2     \n#define HAZE_DENSITY_THRESHOLD  0.1     \n#define HAZE_LAYER_THICKNESS    0.8     \n#define HAZE_RADIAL_EXPAND      0.8     \n#define HAZE_ROT_SPEED          0.2     \n#define HAZE_FLOW_SPEED         0.15     \n#define HAZE_PROBE_STEPS        10      \n#define HAZE_STEP_SIZE          0.05    \n#define HAZE_DEBUG_MASK         0       \n#define HAZE_DEBUG_VECTOR       0       \n#define HAZE_DISK_DENSITY_REF   (iBrightmut * 30.0) \n#define HAZE_JET_DENSITY_REF    (iJetBrightmut * 1.0)\n\n#define iBlendWeight            0.5      \n\n#define ENABLE_SHADOW_CULLING     1       \n#define DEBUG_SHADOW_CULLING      0       \n#define SHADOW_SIZE_MULTIPLIER    0.995     \n\nfloat3 FragUvToDir(float2 FragUv, float Fov, float2 NdcResolution)\n{\n  return normalize(float3(Fov * (2.0 * FragUv.x - 1.0),\n  Fov * (2.0 * FragUv.y - 1.0) * NdcResolution.y / NdcResolution.x,\n  -1.0));\n}\n\nfloat2 PosToNdc(float4 Pos, float2 NdcResolution)\n{\n  return float2(-Pos.x / Pos.z, -Pos.y / Pos.z * NdcResolution.x / NdcResolution.y);\n}\n\nfloat2 DirToNdc(float3 Dir, float2 NdcResolution)\n{\n  return float2(-Dir.x / Dir.z, -Dir.y / Dir.z * NdcResolution.x / NdcResolution.y);\n}\n\nfloat2 DirToFragUv(float3 Dir, float2 NdcResolution)\n{\n  return float2(0.5 - 0.5 * Dir.x / Dir.z, 0.5 - 0.5 * Dir.y / Dir.z * NdcResolution.x / NdcResolution.y);\n}\n\nfloat2 PosToFragUv(float4 Pos, float2 NdcResolution)\n{\n  return float2(0.5 - 0.5 * Pos.x / Pos.z, 0.5 - 0.5 * Pos.y / Pos.z * NdcResolution.x / NdcResolution.y);\n}\n\nstatic const float kPi          = 3.1415926535897932384626433832795;\nstatic const float k2Pi         = 6.283185307179586476925286766559;\nstatic const float kEuler       = 2.7182818284590452353602874713527;\nstatic const float kRadToDegree = 57.295779513082320876798154814105;\nstatic const float kDegreeToRad = 0.017453292519943295769236907684886;\n\nstatic const float kGravityConstant = 6.6743e-11;\nstatic const float kSpeedOfLight    = 299792458.0;\nstatic const float kSolarMass       = 1.9884e30;\n\nfloat RandomStep(float2 Input, float Seed)\n{\n  return frac(sin(dot(Input + frac(11.4514 * sin(Seed)), float2(12.9898, 78.233))) * 43758.5453);\n}\n\nfloat CubicInterpolate(float x)\n{\n  return 3.0 * pow(x, 2.0) - 2.0 * pow(x, 3.0);\n}\n\nfloat PerlinNoise(float3 Position)\n{\n  float3 PosInt   = floor(Position);\n  float3 PosFloat = frac(Position);\n\n  float Sx = CubicInterpolate(PosFloat.x);\n  float Sy = CubicInterpolate(PosFloat.y);\n  float Sz = CubicInterpolate(PosFloat.z);\n\n  float v000 = 2.0 * frac(sin(dot(float3(PosInt.x,       PosInt.y,       PosInt.z),       float3(12.9898, 78.233, 213.765))) * 43758.5453) - 1.0;\n  float v100 = 2.0 * frac(sin(dot(float3(PosInt.x + 1.0, PosInt.y,       PosInt.z),       float3(12.9898, 78.233, 213.765))) * 43758.5453) - 1.0;\n  float v010 = 2.0 * frac(sin(dot(float3(PosInt.x,       PosInt.y + 1.0, PosInt.z),       float3(12.9898, 78.233, 213.765))) * 43758.5453) - 1.0;\n  float v110 = 2.0 * frac(sin(dot(float3(PosInt.x + 1.0, PosInt.y + 1.0, PosInt.z),       float3(12.9898, 78.233, 213.765))) * 43758.5453) - 1.0;\n  float v001 = 2.0 * frac(sin(dot(float3(PosInt.x,       PosInt.y,       PosInt.z + 1.0), float3(12.9898, 78.233, 213.765))) * 43758.5453) - 1.0;\n  float v101 = 2.0 * frac(sin(dot(float3(PosInt.x + 1.0, PosInt.y,       PosInt.z + 1.0), float3(12.9898, 78.233, 213.765))) * 43758.5453) - 1.0;\n  float v011 = 2.0 * frac(sin(dot(float3(PosInt.x,       PosInt.y + 1.0, PosInt.z + 1.0), float3(12.9898, 78.233, 213.765))) * 43758.5453) - 1.0;\n  float v111 = 2.0 * frac(sin(dot(float3(PosInt.x + 1.0, PosInt.y + 1.0, PosInt.z + 1.0), float3(12.9898, 78.233, 213.765))) * 43758.5453) - 1.0;\n\n  return lerp(lerp(lerp(v000, v100, Sx), lerp(v010, v110, Sx), Sy),\n  lerp(lerp(v001, v101, Sx), lerp(v011, v111, Sx), Sy), Sz);\n}\n\nfloat SoftSaturate(float x)\n{\n  return 1.0 - 1.0 / (max(x, 0.0) + 1.0);\n}\n\nfloat PerlinNoise1D(float Position)\n{\n  float PosInt   = floor(Position);\n  float PosFloat = frac(Position);\n  float v0 = 2.0 * frac(sin(PosInt * 12.9898) * 43758.5453) - 1.0;\n  float v1 = 2.0 * frac(sin((PosInt + 1.0) * 12.9898) * 43758.5453) - 1.0;\n  return v1 * CubicInterpolate(PosFloat) + v0 * CubicInterpolate(1.0 - PosFloat);\n}\n\nfloat GenerateAccretionDiskNoise(float3 Position, float NoiseStartLevel, float NoiseEndLevel, float ContrastLevel)\n{\n  float NoiseAccumulator = 10.0;\n  float start = NoiseStartLevel;\n  float end = NoiseEndLevel;\n  int iStart = int(floor(start));\n  int iEnd = int(ceil(end));\n\n  int maxIterations = iEnd - iStart;\n  for (int delta = 0; delta < maxIterations; delta++)\n  {\n    int i = iStart + delta;\n    float iFloat = float(i);\n    float w = max(0.0, min(end, iFloat + 1.0) - max(start, iFloat));\n    if (w <= 0.0) continue;\n\n    float NoiseFrequency = pow(3.0, iFloat);\n    float3 ScaledPosition = NoiseFrequency * Position;\n    float noise = PerlinNoise(ScaledPosition);\n    NoiseAccumulator *= (1.0 + 0.1 * noise * w);\n  }\n\n  return log(1.0 + pow(0.1 * NoiseAccumulator, ContrastLevel));\n}\n\nfloat Vec2ToTheta(float2 v1, float2 v2)\n{\n  float VecDot   = dot(v1, v2);\n  float VecCross = v1.x * v2.y - v1.y * v2.x;\n  float Angle    = asin(0.999999 * VecCross / (length(v1) * length(v2)));\n  float Dx = step(0.0, VecDot);\n  float Cx = step(0.0, VecCross);\n  return lerp(lerp(-kPi - Angle, kPi - Angle, Cx), Angle, Dx);\n}\n\nfloat Shape(float x, float Alpha, float Beta)\n{\n  float k = pow(Alpha + Beta, Alpha + Beta) / (pow(Alpha, Alpha) * pow(Beta, Beta));\n  return k * pow(x, Alpha) * pow(1.0 - x, Beta);\n}\n\nfloat3 KelvinToRgb(float Kelvin)\n{\n  if (Kelvin < 400.01) return float3(0.0, 0.0, 0.0);\n  float Teff     = (Kelvin - 6500.0) / (6500.0 * Kelvin * 2.2);\n  float3  RgbColor = float3(0.0, 0.0, 0.0);\n  RgbColor.r = exp(2.05539304e4 * Teff);\n  RgbColor.g = exp(2.63463675e4 * Teff);\n  RgbColor.b = exp(3.30145739e4 * Teff);\n  float BrightnessScale = 1.0 / max(max(1.5 * RgbColor.r, RgbColor.g), RgbColor.b);\n  if (Kelvin < 1000.0) BrightnessScale *= (Kelvin - 400.0) / 600.0;\n  RgbColor *= BrightnessScale;\n  return RgbColor;\n}\n\nfloat3 WavelengthToRgb(float wavelength) {\n  float3 color = float3(0.0, 0.0, 0.0);\n  if (wavelength <= 380.0 ) {\n    color.r = 1.0; color.g = 0.0; color.b = 1.0;\n  }\n\n  else if (wavelength >= 380.0 && wavelength < 440.0) {\n    color.r = -(wavelength - 440.0) / (440.0 - 380.0); color.g = 0.0; color.b = 1.0;\n  }\n\n  else if (wavelength >= 440.0 && wavelength < 490.0) {\n    color.r = 0.0; color.g = (wavelength - 440.0) / (490.0 - 440.0); color.b = 1.0;\n  }\n\n  else if (wavelength >= 490.0 && wavelength < 510.0) {\n    color.r = 0.0; color.g = 1.0; color.b = -(wavelength - 510.0) / (510.0 - 490.0);\n  }\n\n  else if (wavelength >= 510.0 && wavelength < 580.0) {\n    color.r = (wavelength - 510.0) / (580.0 - 510.0); color.g = 1.0; color.b = 0.0;\n  }\n\n  else if (wavelength >= 580.0 && wavelength < 645.0) {\n    color.r = 1.0; color.g = -(wavelength - 645.0) / (645.0 - 580.0); color.b = 0.0;\n  }\n\n  else if (wavelength >= 645.0 && wavelength <= 750.0) {\n    color.r = 1.0; color.g = 0.0; color.b = 0.0;\n  }\n\n  else if (wavelength >= 750.0) {\n    color.r = 1.0; color.g = 0.0; color.b = 0.0;\n  }\n\n  float factor = 0.3;\n  if (wavelength >= 380.0 && wavelength < 420.0) factor = 0.3 + 0.7 * (wavelength - 380.0) / (420.0 - 380.0);\n  else if (wavelength >= 420.0 && wavelength < 645.0) factor = 1.0;\n  else if (wavelength >= 645.0 && wavelength <= 750.0) factor = 0.3 + 0.7 * (750.0 - wavelength) / (750.0 - 645.0);\n\n  return color * factor / pow(color.r * color.r + 2.25 * color.g * color.g + 0.36 * color.b * color.b, 0.5) * (0.1 * (color.r + color.g + color.b) + 0.9);\n}\n\nfloat4 hash43x(float3 p)\n{\n  uint3 x = ((uint3)(((int3)(p))));\n  x = 1103515245U*((x.xyz >> 1U)^(x.yzx));\n  uint h = 1103515245U*((x.x^x.z)^(x.y>>3U));\n  uint4 rz = uint4(h, h*16807U, h*48271U, h*69621U); \n  return ((float4)((rz >> 1) & ((uint4)(0x7fffffffU))))/float(0x7fffffff);\n}\n\nfloat3 stars(float3 p)\n{\n  float3 col = float3(0, 0, 0);\n  float _st_rad = .087*float3(texsize.x, texsize.y, 1.0).y;\n  float dens = 0.15;\n  float id = 0.;\n  float rz = 0.;\n  float z = 1.;\n\n  for (float i = 0.; i < 5.; i++)\n  {\n    p = mul(float3x3(0.86564, -0.28535, 0.41140, 0.50033, 0.46255, -0.73193, 0.01856, 0.83942, 0.54317), p);\n    float3 q = abs(p);\n    float3 p2 = p/max(q.x, max(q.y,q.z));\n    p2 *= _st_rad;\n    float3 ip = floor(p2 + 1e-5);\n    float3 fp = frac(p2 + 1e-5);\n    float4 rand = hash43x(ip*283.1);\n    float3 q2 = abs(p2);\n    float3 pl = 1.0- step(max(q2.x, max(q2.y, q2.z)), q2);\n    float3 pp = fp - ((rand.xyz-0.5)*.6 + 0.5)*pl; \n    float pr = length(ip) - _st_rad;   \n    if (rand.w > (dens - dens*pr*0.035)) pp += 1e6;\n\n    float d = dot(pp, pp);\n    d /= pow(frac(rand.w*172.1), 32.) + .25;\n    float bri = dot(rand.xyz*(1.-pl),float3(1, 1, 1)); \n    id = frac(rand.w*101.);\n    col += bri*z*.00009/pow(d + 0.025, 3.0)*(lerp(float3(1.0,0.45,0.1),float3(0.75,0.85,1.), id)*0.6+0.4);\n\n    _st_rad = floor(_st_rad*1.08);\n    dens *= 1.45;\n    z *= 0.6;\n    p = p.yxz;\n  }\n\n  return col;\n}\n\nstatic const int ITERATIONS = 40;   \nstatic const float SPEED = 1.;\n\nstatic const float STRIP_CHARS_MIN =  7.;\nstatic const float STRIP_CHARS_MAX = 40.;\nstatic const float STRIP_CHAR_HEIGHT = 0.15;\nstatic const float STRIP_CHAR_WIDTH = 0.10;\nstatic const float ZCELL_SIZE = 1. * (STRIP_CHAR_HEIGHT * STRIP_CHARS_MAX);  \nstatic const float XYCELL_SIZE = 12. * STRIP_CHAR_WIDTH;  \n\nstatic const int BLOCK_SIZE = 10;  \nstatic const int BLOCK_GAP = 2;    \n\nstatic const float WALK_SPEED = 1. * XYCELL_SIZE;\nstatic const float BLOCKS_BEFORE_TURN = 3.;\n\nstatic const float PI = 3.14159265359;\n\nfloat hash(float v) {\n  return frac(sin(v)*43758.5453123);\n}\n\nfloat hash(float2 v) {\n  return hash(dot(v, float2(5.3983, 5.4427)));\n}\n\nfloat2 hash2(float2 v)\n{\n  v = ((float2)(mul(float2x2(127.1, 311.7,  269.5, 183.3), v)));\n  return frac(sin(v)*43758.5453123);\n}\n\nfloat4 hash4(float2 v)\n{\n  float4 p = ((float4)(mul(float4x2( 127.1, 311.7,\n  269.5, 183.3,\n  113.5, 271.9,\n  246.1, 124.6 ), v)));\n  return frac(sin(p)*43758.5453123);\n}\n\nfloat4 hash4(float3 v)\n{\n  float4 p = ((float4)(mul(float4x3( 127.1, 311.7, 74.7,\n  269.5, 183.3, 246.1,\n  113.5, 271.9, 124.6,\n  271.9, 269.5, 311.7 ), v)));\n  return frac(sin(p)*43758.5453123);\n}\n\nfloat rune_line(float2 p, float2 a, float2 b) {   \np -= a, b -= a;\nfloat h = clamp(dot(p, b) / dot(b, b), 0., 1.);   \nreturn length(p - b * h);                         \n}\n\nfloat rune(float2 U, float2 seed, float highlight)\n{\n  float d = 1e5;\n  for (int i = 0; i < 4; i++)\t\n  {\n    float4 pos = hash4(seed);\n    seed += 1.;\n\n    if (i == 0) pos.y = .0;\n    if (i == 1) pos.x = .999;\n    if (i == 2) pos.x = .0;\n    if (i == 3) pos.y = .999;\n\n    float4 snaps = float4(2, 3, 2, 3);\n    pos = ( floor(pos * snaps) + .5) / snaps;\n\n    if (all(pos.xy != pos.zw))  \n    d = min(d, rune_line(U, pos.xy, pos.zw + .001) ); \n  }\n\n  return smoothstep(0.1, 0., d) + highlight*smoothstep(0.4, 0., d);\n}\n\nfloat random_char(float2 outer, float2 inner, float highlight) {\n  float2 seed = float2(dot(outer, float2(269.5, 183.3)), dot(outer, float2(113.5, 271.9)));\n  return rune(inner, seed, highlight);\n}\n\nfloat3 rain(float3 ro3, float3 rd3, float time_conv) {\n  float4 result = float4(0., 0., 0., 0.);\n\n  float2 ro2 = ((float2)(ro3));\n  float2 rd2 = normalize(((float2)(rd3)));\n\n  bool prefer_dx = abs(rd2.x) > abs(rd2.y);\n  float t3_to_t2 = prefer_dx ? rd3.x / rd2.x : rd3.y / rd2.y;\n\n  int3 cell_side = ((int3)(step(0., rd3)));      \n  int3 cell_shift = ((int3)(sign(rd3)));         \n\n  float t2 = 0.;  \n  int2 next_cell = ((int2)(floor(ro2/XYCELL_SIZE)));  \n  for (int i=0; i<ITERATIONS; i++) {\n    int2 cell = next_cell;  \n    float t2s = t2;          \n\n    float2 side = ((float2)(next_cell + cell_side.xy)) * XYCELL_SIZE;  \n    float2 t2_side = (side - ro2) / rd2;  \n    if (t2_side.x < t2_side.y) {\n      t2 = t2_side.x;\n      next_cell.x += cell_shift.x;  \n    }\n\n    else {\n      t2 = t2_side.y;\n      next_cell.y += cell_shift.y;  \n    }\n\n    float2 cell_in_block = frac(((float2)(cell)) / float(BLOCK_SIZE));\n    float gap = float(BLOCK_GAP) / float(BLOCK_SIZE);\n    if (cell_in_block.x < gap || cell_in_block.y < gap || (cell_in_block.x < (gap+0.1) && cell_in_block.y < (gap+0.1))) {\n      continue;\n    }\n\n    float t3s = t2s / t3_to_t2;\n\n    float pos_z = ro3.z + rd3.z * t3s;\n    float xycell_hash = hash(((float2)(cell)));\n    float z_shift = xycell_hash*11. - time_conv * (0.5 + xycell_hash * 1.0 + xycell_hash * xycell_hash * 1.0 + pow(xycell_hash, 16.) * 3.0);  \n    float char_z_shift = floor(z_shift / STRIP_CHAR_HEIGHT);\n    z_shift = char_z_shift * STRIP_CHAR_HEIGHT;\n    int zcell = int(floor((pos_z - z_shift)/ZCELL_SIZE));  \n    for (int j=0; j<2; j++) {  \n\n    float4 cell_hash = hash4(((float3)(int3(cell, zcell))));\n    float4 cell_hash2 = frac(cell_hash*float4(127.1, 311.7, 271.9, 124.6));\n\n    float chars_count = cell_hash.w * (STRIP_CHARS_MAX - STRIP_CHARS_MIN) + STRIP_CHARS_MIN;\n    float target_length = chars_count * STRIP_CHAR_HEIGHT;\n    float target_rad = STRIP_CHAR_WIDTH / 2.;\n    float target_z = (float(zcell)*ZCELL_SIZE + z_shift) + cell_hash.z * (ZCELL_SIZE - target_length);\n    float2 target = ((float2)(cell)) * XYCELL_SIZE + target_rad + cell_hash.xy * (XYCELL_SIZE - target_rad*2.);\n\n    float2 s = target - ro2;\n    float tmin = dot(s, rd2);  \n    if (tmin >= t2s && tmin <= t2) {\n      float u = s.x * rd2.y - s.y * rd2.x;  \n      if (abs(u) < target_rad) {\n        u = (u/target_rad + 1.) / 2.;\n        float z = ro3.z + rd3.z * tmin/t3_to_t2;\n        float v = (z - target_z) / target_length;  \n        if (v >= 0.0 && v < 1.0) {\n          float c = floor(v * chars_count);  \n          float q = frac(v * chars_count);\n          float2 char_hash = hash2(float2(c+char_z_shift, cell_hash2.x));\n     