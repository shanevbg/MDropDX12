wavecode_2_scaling=1.00000
wavecode_2_smoothing=0.50000
wavecode_2_r=1.000
wavecode_2_g=1.000
wavecode_2_b=1.000
wavecode_2_a=1.000
wave_2_per_point1=curves=42* cos(time);
wave_2_per_point2=wave=sample*curves/12;
wave_2_per_point3=x=rad*.5+.15* sin(wave) * cos(.2*time)+sample;
wave_2_per_point4=y=.5+.15*( cos(wave+time) +sqrt(sample)*3*rad);
wavecode_3_enabled=1
wavecode_3_samples=512
wavecode_3_sep=0
wavecode_3_bSpectrum=0
wavecode_3_bUseDots=0
wavecode_3_bDrawThick=1
