wave_0_per_point1=curves=62* cos(time);
wave_0_per_point2=wave=sample*curves/5;
wave_0_per_point3=x=rad*.5+.15* sin(wave) * cos(.2*time)+sample;
wave_0_per_point4=y=rad*.5+.15* cos(wave) * sin(.2*time)+sample;
wavecode_1_enabled=1
wavecode_1_samples=512
wavecode_1_sep=0
wavecode_1_bSpectrum=0
wavecode_1_bUseDots=0
wavecode_1_bDrawThick=1
wavecode_1_bAdditive=1
wavecode_1_scaling=1.00000
wavecode_1_smoothing=0.50000
wavecode_1_r=1.000
wavecode_1_g=1.000
wavecode_1_b=1.000
wavecode_1_a=1.000
wave_1_per_point1=curves=32* cos(time);
wave_1_per_point2=wave=sample*curves/5;
wave_1_per_point3=x=rad*.5+.15* sin(wave) * cos(.2*time)+sample;
wave_1_per_point4=y=.5+.15*( cos(wave+time) +sqrt(sample)*3*rad);
wavecode_2_enabled=1
wavecode_2_samples=512
wavecode_2_sep=0
wavecode_2_bSpectrum=0
wavecode_2_bUseDots=0
wavecode_2_bDrawThick=1
