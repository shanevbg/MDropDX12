wave_1_per_point23=g = 0.5;
wave_1_per_point24=b = 0;
wave_1_per_point25=
wave_1_per_point26=a=0.25*(cos(t_abs*3.14/2)) + 0.2 *below (abs(1-t_abs- t1),0.0);
wave_1_per_point27=//a=0.25*(sin(t_abs*3.14)) + 0.4 *below (abs(1-t_abs-t1), bass_att/1);
