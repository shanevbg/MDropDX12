wave_1_per_point36=
wave_1_per_point37=// Rotation um x,y,z
wave_1_per_point38=
wave_1_per_point39=mx = ox*cos(zang) - oy*sin(zang);
wave_1_per_point40=my = ox*sin(zang) + oy*cos(zang);
wave_1_per_point41=
wave_1_per_point42=ox = mx;
wave_1_per_point43=oy = my;
wave_1_per_point44=mx = ox*cos(yang) + oz*sin(yang);
wave_1_per_point45=mz = - ox*sin(yang) + oz*cos(yang);
