wave_1_per_point10=
wave_1_per_point11=ox = sin (t_rel*8) + ampl*sin (t_rel*12) ;
wave_1_per_point12=oy = cos (t_rel*13) + ampl*cos (t_rel*11);
wave_1_per_point13=oz =  ampl/3;
