wave_1_per_point49=mz = oy*sin(xang) + oz*cos(xang);
wave_1_per_point50=oy = my;
wave_1_per_point51=oz = mz;
wave_1_per_point52=
wave_1_per_point53=oz = oz - 6;
wave_1_per_point54=x = ox*fov/oz +0.5;
wave_1_per_point55=//x = (x-.5)*0.75 + 0.5;
wave_1_per_point56=y = oy*fov/oz + 0.5;
