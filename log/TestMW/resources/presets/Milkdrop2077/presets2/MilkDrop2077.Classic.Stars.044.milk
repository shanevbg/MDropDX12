shape_1_per_frame1=sounds=(bass+treb+mid);
shape_1_per_frame2=att=(bass_att+treb_att+mid_att)/13;
shape_1_per_frame3=att=(bass_att+treb_att+mid_att)/13;
shape_1_per_frame4=r2=r2+(0.25*sin(time*16.28))-bass;
shape_1_per_frame5=g2=g2+(1.25*sin(time*16.28))-bass;
shape_1_per_frame6=
shape_1_per_frame7=rad=0.4;
shape_1_per_frame8=//x=x+0.243*tan(time/2)+sounds*0.09;
shape_1_per_frame9=//y=y+0.217*sin((time/1.5)+(sounds*0.3));
per_frame_1=dec_med = 1- .2*30/fps;
per_frame_2=dec_slow = 1-.05*30/fps;
per_frame_3=
per_frame_4=beat = max (max (bass, mid), treb); 
per_frame_5=avg = avg*dec_slow + beat*(1-dec_slow);
per_frame_6=is_beat = above(beat, .2*avg+peak) * above (time, t0+.1);
per_frame_7=t0 = is_beat*time + (1-is_beat)*t0;
per_frame_8=peak = is_beat * beat + (1-is_beat)*peak*dec_med;
per_frame_9=index = (index + is_beat) %16;
per_frame_10=
per_frame_11=q27 = index;
per_frame_12=q22 = peak;
per_frame_13=peak_ = dec_med*peak_ + (1-dec_med)*peak;
per_frame_14=
per_frame_15=trig = is_beat * bnot(index%4);
per_frame_16=count = count + trig;
per_frame_17=rott = rott*dec_med + (1-dec_med) * count*3.14/2;
per_frame_18=q1 = cos(rott);
per_frame_19=q2 = sin(rott);
per_frame_20=
per_frame_21=
per_frame_22=ma = ma + (peak_-0)/fps*4*above(peak_,0);
per_frame_23=mx=mx*dec_slow+(1-dec_slow)*cos(ma);
per_frame_24=my=my*dec_slow+(1-dec_slow)*sin(ma*q1);
per_frame_25=q15 = mx/2 ;
per_frame_26=q16 = my/2 ;
per_frame_27=q17 = ma;
per_frame_28=
per_frame_29=ang1 = ang1 + 8*bass*above(bass,1)/fps*q1;
per_frame_30=q18 = ang1;
per_frame_31=
per_frame_32=q32 = aspecty;
per_frame_33=monitor = q1;
per_pixel_1=zoom = 1 + pow(sin(ang*5 - q5),1)*.04*bass;
per_pixel_2=rot = .02*sin(rad*6.2832*2 - q4*4)*(mid + treb)*.5;
warp_1=`shader_body {
warp_2=`ret = min (0.4,GetBlur2(uv))*0.85 * (1-lum(GetBlur1(uv))*0.1);
warp_3=`//ret = max(ret,GetBlur2((uv-.15)*3.25+.5)*.02);
warp_4=`
warp_5=`float tx = time*12;
warp_6=`float2 uv3 = uv-.95-.3*float2(sin(tx),cos(tx))-.0*(tex2D(sampler_noise_lq,uv/8+rand_frame).r-.5);
warp_7=`ret += q25/length(uv3)* saturate(tan(+18*atan2(uv3.y,uv3.x)))*(roam_cos+1) ;
warp_8=`
warp_9=`}
comp_1=`shader_body
comp_2=`{
comp_3=`
comp_4=`
comp_5=`
comp_6=`
comp_7=`
comp_8=`float2 uv2 = uv;
comp_9=`uv2.x=1-uv2.x;
comp_10=`
comp_11=`    float2 d  = texsize.zw*4;
comp_12=`    float2 d2 = texsize.zw*4;
comp_13=`
comp_14=`    float3 dx  = ( GetBlur1(uv +float2(1,0)*d )-GetBlur1(uv2-float2(1,0)*d2) );
comp_15=`    float3 dx2 = ( GetBlur1(uv2+float2(1,0)*d2)-GetBlur1(uv -float2(0,1)*d ) );
comp_16=`
comp_17=`    float3 dy  = ( GetBlur1(uv2+float2(0,1)*d2)-GetBlur1(uv -float2(1,0)*d ) );
comp_18=`    float3 dy2 = ( GetBlur1(uv +float2(0,1)*d )-GetBlur1(uv2-float2(0,1)*d2) );
comp_19=`
comp_20=`
comp_21=`float2 uv_bg  = uv2 - float2(dx2.y,dy2.y)*texsize.zw*16;
comp_22=`float2 uv_bg2 = uv  - float2(dx.y ,dy.y )*texsize.zw*16;
comp_23=`
comp_24=`        ret = (GetBlur2(uv_bg )-GetBlur1(uv_bg2)*1+GetPixel(uv_bg )*0.9 + (-dx.y  + dy.y )*0.4).y*0.8*float3(1.0,1.1,1.2);
comp_25=`float3 ret2 = (GetBlur2(uv_bg2)-GetBlur1(uv_bg )*1+GetPixel(uv_bg2)*0.9 + (-dx2.y + dy2.y)*0.4).y*0.8*float3(1.2,1.0,1.1);
comp_26=`
comp_27=`float2 uv_m  = uv2 - float2(dx2.x,dy.x )*texsize.zw*8;
comp_28=`float2 uv_m2 = uv  - float2(dx.x ,dy2.x)*texsize.zw*8;
comp_29=`
comp_30=`ret  = lerp(ret , 2*float3(0.0,0.5,1.0), GetBlur3(uv_m2 - float2(dx2.y,dy.y )*0.4).x*0.4);
comp_31=`ret2 = lerp(ret2, 2*float3(0.5,1.0,0.0), GetBlur3(uv_m  - float2(dx.y ,dy2.y)*0.4).x*0.4);
comp_32=`
comp_33=`ret  = lerp(ret , 2*float3(0.5,1.0,1.0), GetBlur2(uv_m  - float2(dx.y ,dy2.y)*0.2).x*0.4);
comp_34=`ret2 = lerp(ret2, 2*float3(1.0,0.5,1.0), GetBlur2(uv_m2 - float2(dx2.y,dy.y )*0.2).x*0.4);
comp_35=`
comp_36=`ret = lerp(ret, 2*float3(1,1,0.8), GetBlur1(uv_m - float2(dx.y,dy.y)*0.1).x*0.2);
comp_37=`//ret = lerp(ret, float3(0.5,0,1), GetPixel(uv_m).x*0.4);
comp_38=`
comp_39=`//ret = .7-ret2;
comp_40=`//ret2=.7-ret;
comp_41=`ret-=ret2;
comp_42=`//MilkDrop3 Color Mode:
comp_43=`ret /= float3(-1.1,2.1,0.9);
comp_44=`//MilkDrop3 Blow Mode:
comp_45=`float3 avg_col = GetBlur2(uv);ret = abs(avg_col - ret)*2;
comp_46=`}
