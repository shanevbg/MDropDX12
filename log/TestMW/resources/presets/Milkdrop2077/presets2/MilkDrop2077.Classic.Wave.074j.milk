per_frame_3=speed=0.80;
per_frame_4=speedinv=1-speed;
per_frame_5=q1=(qa*speed + bass*speedinv);
per_frame_6=q2=(qb*speed + mid *speedinv);
per_frame_7=q3=(qc*speed + treb*speedinv);
per_frame_8=qa=q1;
per_frame_9=qb=q2;
per_frame_10=qc=q3;
per_frame_11=flux=sin(time/2);
per_frame_12=q4=flux * 0.5 + 0.5;
per_frame_13=q5=flux;
per_frame_14=
per_frame_15=q8=treb_att;
per_frame_16=q9=mid_att;
per_frame_17=
per_frame_18=vol = 0.33*(treb_att + mid_att + bass_att);
per_frame_19=q10=vol;
per_frame_20=r = treb_att;
per_pixel_1=wave_a = (treb_att + mid_att);
per_pixel_2=
per_pixel_3=wave_x = wave_x - (mid_att / 20)*sin(time*0.015+3);
per_pixel_4=wave_y = wave_y - (treb_att / 25)*sin(time*0.019+1);
per_pixel_5=g = treb_att;
warp_1=`static const float2 centre = float2 (q10-0.5,-(q11-0.5))/aspect.xy+0.5;
warp_2=`
warp_3=`shader_body {
warp_4=`ret = lerp(GetPixel(uv),GetBlur1(uv),0.2)*0.75;
warp_5=`float2 uv2 = uv-centre+0.5;
warp_6=`       uv2 = float2 (1-uv2.x,uv2.y)-0.5;
warp_7=`uv2 = (uv2)*0.8 + centre;
warp_8=`ret = max (ret, lerp(GetPixel(uv2),GetBlur1(uv2),0.4)*0.55);
warp_9=`
warp_10=`ret = ret* (1-pow(rad,2)*1) - 0.002;
warp_11=`
warp_12=`}
comp_1=`float2 d, d_uv;
comp_2=`float3 dx, dy;
comp_3=`
comp_4=`shader_body
comp_5=`{
comp_6=`
comp_7=`
comp_8=`
comp_9=`
comp_10=`float2 uv_o = uv;
comp_11=`
comp_12=`ret = GetBlur3(uv);
comp_13=`
comp_14=`float2 uv2 = uv*(1-.15*GetBlur1(saturate(ret.xy)));
comp_15=`uv2 += .075*GetBlur1(saturate(ret.xy));
comp_16=`
comp_17=`uv = lerp(uv,uv2,.75);
comp_18=`
comp_19=`
comp_20=`   d = texsize.zw*4;
comp_21=`   d_uv = uv;
comp_22=`   dx = GetBlur1(d_uv + float2(1,0)*d) - GetBlur1(d_uv - float2(1,0)*d);
comp_23=`   dy = GetBlur1(d_uv + float2(0,1)*d) - GetBlur1(d_uv - float2(0,1)*d);
comp_24=`   d_uv += float2(dx.x,dy.x)*0.03;
comp_25=`
comp_26=`ret = lerp(GetBlur2(d_uv),GetPixel(d_uv),0.4);
comp_27=`float4 noise9 = tex3D(sampler_noisevol_hq, 
comp_28=`                      ((d_uv.xyy*q28
comp_29=`                       )*texsize.xyy*texsize_noisevol_hq.zww
comp_30=`                      ).xyz*
comp_31=`                      float3(2.9,0.2,1.6)*0.05 + 
comp_32=`                      time*float3(1.9,1.9,0.4)*q31
comp_33=`                     );
comp_34=`if(ret.x> q26*q13         && ret.x<= q23*q11        )ret.z -= (noise9).x*.5; 
comp_35=`if(ret.y> q25*q11         && ret.y<= q22*q12        )ret.x -= (noise9).y*.5; 
comp_36=`if(ret.z> q24*q12         && ret.z<= q21*q13        )ret.y -= (noise9).z*.5; 
comp_37=`ret = (ret.y-ret.x*0.5)*lerp(float3(1.4,0.4,1),1,ret.x)*1.4;
comp_38=`
comp_39=`ret = lerp(ret,float3(0.9,2.1,4.8),GetBlur1(d_uv-float2(1,1)*texsize.zw*32).z*0.6);
comp_40=`ret = lerp(ret,float3(2.5,3.5,3.5),GetPixel(uv_o).z*0.36);
comp_41=`ret *= ret+2;
comp_42=`//ret = GetPixel(uv);
comp_43=`}
