shape_0_per_frame1=rad0 = 0.0350;
shape_0_per_frame2=
shape_0_per_frame3=fslot = int (instance/32);
shape_0_per_frame4=x = -0.02 + fslot/31;
shape_0_per_frame5=
shape_0_per_frame6=y0 = (instance%32)/64;
shape_0_per_frame7=y = -0.03 + y0+rad0;
shape_0_per_frame8=
shape_0_per_frame9=lim = max(0,min(1,5*log(1+gmegabuf(fslot)*30) - 20*y0)); 
shape_0_per_frame10=
shape_0_per_frame11=a=0; a2 = a/2;
shape_0_per_frame12=trel = time;
shape_0_per_frame13=if ( lim > 0.1,
shape_0_per_frame14=  r = 0.5 + 0.5*sin(fslot/32*6+trel);
shape_0_per_frame15=  g = 0.5 + 0.5*sin(fslot/32*6+2+trel);
shape_0_per_frame16=  b = 0.5 + 0.5*sin(fslot/32*6+4+trel);
shape_0_per_frame17=  r2 = r; g2 = g; b2 = b;
shape_0_per_frame18=  a = min(1,a+lim); a2 = a;
shape_0_per_frame19=,
shape_0_per_frame20=r = 1; b = 1; g = 1; r2 = r; b2 = b; g2 = g;;
shape_0_per_frame21=);
shape_0_per_frame22=
shape_0_per_frame23=
shape_0_per_frame24=
shape_0_per_frame25=rad = rad0;
per_frame_init_1=n = 0;
per_frame_init_2=loop (100000,megabuf(n)=0;gmegabuf(n)=0;n += 1;);
per_frame_init_3=
per_frame_init_4=posx = rand(10); posy = rand(10);
per_frame_init_5=ranx = rand (1); rany = rand(1);
per_frame_init_6=ranh = rand(10);
per_frame_init_7=t0 = time;
per_frame_init_8=st = 0.5; st_=0.5;
per_frame_1=st = max (0, st-0.2/fps);
per_frame_2=dec = 1-0.5/fps;
per_frame_3=st_ = st_* (dec) + (1-dec)*st;
per_frame_4=
per_frame_5=//dir
per_frame_6=dir = 0.7*sin(time*.0162+rany*6);
per_frame_7=q2 = dir+0.5; 
per_frame_8=q3 = sin(dir);
per_frame_9=q4 = cos(dir);
per_frame_10=
per_frame_11=//scaling plane
per_frame_12=q7 = 0.002;
per_frame_13=
per_frame_14=//movement
per_frame_15=posx = time*0.0003;
per_frame_16=posy = time*0.004;
per_frame_17=q10 = posx;
per_frame_18=q11 = posy;
per_frame_19=
per_frame_20=//start ran for warp mod 
per_frame_21=q15 = ranx;
per_frame_22=q16 = rany;
per_frame_23=
per_frame_24=test = (t0-time)*0.047-3.14/2;
per_frame_25=view = 0.7 + min(1, max (-1, 2*sin(test)))*0.17;
per_frame_26=
per_frame_27=//Alti
per_frame_28=q8 = 4 + 3* sin(test) + (view-0.55)*16;
per_frame_29=
per_frame_30=//hory (Kippung)
per_frame_31=q6 = view * (1-st_) + st_*2;
per_frame_32=
per_frame_33=//q6  = 0.55;
per_frame_34=monitor = view;
warp_1=`shader_body
warp_2=`{ret=tex2D(sampler_fc_main,uv).xyz;ret*=0.96;}
comp_1=`shader_body
comp_2=`{//MilkDrop3 Split Mode:
comp_3=`uv = float2 (abs(uv.x-0.5), uv.y);
comp_4=`
comp_5=`
comp_6=`
comp_7=`
comp_8=`
comp_9=`
comp_10=`
comp_11=`
comp_12=`
comp_13=`
comp_14=`
comp_15=`ret = lerp( 0, float3(1, 1, 0), GetBlur2(uv).x*2.5 -  GetBlur1(uv).x*0.7 + tex2D(sampler_main, uv).x*0.75);
comp_16=`ret *= 1- GetBlur1(uv).x*3.85;
comp_17=`ret += float3(0,0,0.7)*tex2D(sampler_main, uv).x + float3(0.25,0.25,0.25)*tex2D(sampler_main, uv).y;
comp_18=`ret *= max(tex2D(sampler_main, uv).y*0.8, GetBlur2(uv).y*0.5);
comp_19=`//ret = tex2D(sampler_main, uv);
comp_20=`//MilkDrop3 Color Mode:
comp_21=`ret /= float3(2.3,2.4,-2.7);
comp_22=`//MilkDrop3 Blow Mode:
comp_23=`float3 avg_col = GetBlur2(uv);ret = abs(avg_col - ret)*2;
comp_24=`}
