shape_0_per_frame4=b=q3;
per_frame_init_1=index = 0;
per_frame_init_2=loop (300000,
per_frame_init_3=  megabuf(index) = .1;
per_frame_init_4=  gmegabuf(index) = 0;
per_frame_init_5=  index = index + 1;
per_frame_init_6=);
per_frame_init_7=
per_frame_init_8=vol_=1;
per_frame_init_9=
per_frame_init_10=q10 = rand(100) >= 30;
per_frame_init_11=q11 = rand(100) >= 30;
per_frame_init_12=q12 = (rand(100) >= 30)*9+3;
per_frame_init_13=q13 = min(max((rand(100)/50-.5),-.001),1);
per_frame_init_14=q14 = rand(8);
per_frame_1=dec_m = pow(.9, 30/fps);dec_s = pow(.98, 30/fps);dec_xs = pow(.985, 30/fps);
per_frame_2=
per_frame_3=flen = 128; shapes = 16;
per_frame_4=
per_frame_5=beat = (bass + treb + mid)/3;
per_frame_6=beat_ = beat_*dec_m + (1-dec_m)*beat; 
per_frame_7=is_beat = above(beat, peak*8) * above (time, t0+.2);
per_frame_8=t0 = is_beat*time + (1-is_beat)*t0;
per_frame_9=peak = is_beat * beat + (1-is_beat)*peak*dec_m;
per_frame_10=index = (index + is_beat) %8;
per_frame_11=q22 = peak;
per_frame_12=q27 = index;
per_frame_13=
per_frame_14=n = 0; vol = .1; bbase = 5000;
per_frame_15=loop (flen,
per_frame_16=  value = gmegabuf(n) * (1+1/(n+.5));
per_frame_17=  megabuf(bbase+n) = (beat >= (1.1-n/flen/2)*beat_)*(time >= megabuf(bbase+1000+n)+.1);
per_frame_18=  trig = megabuf(bbase+n); ;
per_frame_19=  megabuf(bbase+1000+n) = if(trig,time, megabuf(bbase+1000+n));
per_frame_20=  dec = if(trig,0.2,pow(.98,30/fps));
per_frame_21=  megabuf(n) = megabuf(n)*dec + (1-dec)*value;
per_frame_22=  vol = vol + pow(megabuf(n),2);
per_frame_23=  n = n+1;
per_frame_24=);
per_frame_25=vol = sqrt(vol);
per_frame_26=vol_ = dec_m*vol_ + (1-dec_m)*vol;
per_frame_27=
per_frame_28=// post smoothing
per_frame_29=n = 0;
per_frame_30=loop (flen,
per_frame_31=  value = megabuf(n);
per_frame_32=  dec = if (megabuf(1000+n)<=value,.85,.9-0.1*n/flen);
per_frame_33=  dec = pow(dec,30/fps);
per_frame_34=//  dec = 1; //#
per_frame_35=    megabuf(n+1000) = megabuf(n+1000)*dec+ (1-dec)*value/vol_;
per_frame_36=  n = n+1;
per_frame_37=);
per_frame_38=
per_frame_39=
per_frame_40=// Berechnung Ortskoordinaten aus Spektrum
per_frame_41=dist = 2; reduce = flen/shapes;
per_frame_42=n = 2000; m = 1000+dist; k=0;
per_frame_43=loop (shapes,
per_frame_44=  betr = (megabuf(m)+megabuf(m-dist)+megabuf(m+dist))/3;
per_frame_45=  megabuf(n)   = megabuf(m) - megabuf(m+dist);
per_frame_46=  megabuf(n+1) = megabuf(m) - megabuf(m-dist);
per_frame_47=  z1 = max(.03/betr,.05);
per_frame_48=  z2 = ((k+q22*q14+time*2)%shapes)/shapes+.06;
per_frame_49=  megabuf(n+2) = q13*z1+(1-q13)*z2;
per_frame_50=  m = m + reduce; n = n+8; k= k+1;
per_frame_51=);
per_frame_52=
per_frame_53=
per_frame_54=//Projektion
per_frame_55=n = 1000; m = 2000;
per_frame_56=loop (shapes,
per_frame_57=  gmegabuf(n) = megabuf(m)/megabuf(m+2);
per_frame_58=  gmegabuf(n+1) = megabuf(m+1)/megabuf(m+2);
per_frame_59=  gmegabuf(n+2) = megabuf(m+2);
per_frame_60=  mx = mx + gmegabuf(n)/shapes/fps;
per_frame_61=  my = my + gmegabuf(n+1)/shapes/fps;
per_frame_62=  n = n+8; m = m+8;
per_frame_63=);
per_frame_64=
per_frame_65=
per_frame_66=q1 = sin(8*mx+time*.1)/2;
per_frame_67=q2 = sin(-8*my+time*.03);
per_frame_68=q3 = atan2(gmegabuf(1000+8),gmegabuf(1000+8+1));
per_frame_69=
per_frame_70=trel = trel + bass_att/fps;
per_frame_71=q4 = trel;
per_frame_72=
per_frame_73=monitor = q13;
per_frame_74=
per_frame_75=q32 = aspecty;
per_frame_76=q31 = min(.996,dec_xs);
per_pixel_1=rot = 0.0; zoom = 1.04; warp = 0; dx = 0; dy = 0;
warp_1=`shader_body {
warp_2=`ret = min (0.4,GetBlur2(uv))*0.85 * (1-lum(GetBlur1(uv))*0.1);
warp_3=`ret = max(ret,GetBlur2((uv-.5)*.25+.5)*.12);
warp_4=`
warp_5=`float tx = time*12;
warp_6=`float2 uv3 = uv-.5-.7*float2(sin(tx),cos(tx))-.0*(tex2D(sampler_noise_lq,uv/8+rand_frame).r-.5);
warp_7=`ret += q25/length(uv3)* saturate(sin(+8*atan2(uv3.y,uv3.x)))*(roam_cos+1) ;
warp_8=`
warp_9=`}
comp_1=`shader_body
comp_2=`{
comp_3=`
comp_4=`
comp_5=`
comp_6=`
comp_7=`
comp_8=`
comp_9=`
comp_10=`
comp_11=`
comp_12=`
comp_13=`float2 uv2 = uv;
comp_14=`uv2.x=1-uv2.x;
comp_15=`
comp_16=`    float2 d  = texsize.zw*4;
comp_17=`    float2 d2 = texsize.zw*4;
comp_18=`
comp_19=`    float3 dx  = ( GetBlur1(uv +float2(1,0)*d )-GetBlur1(uv2-float2(1,0)*d2) );
comp_20=`    float3 dx2 = ( GetBlur1(uv2+float2(1,0)*d2)-GetBlur1(uv -float2(0,1)*d ) );
comp_21=`
comp_22=`    float3 dy  = ( GetBlur1(uv2+float2(0,1)*d2)-GetBlur1(uv -float2(1,0)*d ) );
comp_23=`    float3 dy2 = ( GetBlur1(uv +float2(0,1)*d )-GetBlur1(uv2-float2(0,1)*d2) );
comp_24=`
comp_25=`
comp_26=`float2 uv_bg  = uv2 - float2(dx2.y,dy2.y)*texsize.zw*16;
comp_27=`float2 uv_bg2 = uv  - float2(dx.y ,dy.y )*texsize.zw*16;
comp_28=`
comp_29=`        ret = (GetBlur2(uv_bg )-GetBlur1(uv_bg2)*1+GetPixel(uv_bg )*0.9 + (-dx.y  + dy.y )*0.4).y*0.8*float3(1.0,1.1,1.2);
comp_30=`float3 ret2 = (GetBlur2(uv_bg2)-GetBlur1(uv_bg )*1+GetPixel(uv_bg2)*0.9 + (-dx2.y + dy2.y)*0.4).y*0.8*float3(1.2,1.0,1.1);
comp_31=`
comp_32=`float2 uv_m  = uv2 - float2(dx2.x,dy.x )*texsize.zw*8;
comp_33=`float2 uv_m2 = uv  - float2(dx.x ,dy2.x)*texsize.zw*8;
comp_34=`
comp_35=`ret  = lerp(ret , 2*float3(0.0,0.5,1.0), GetBlur3(uv_m2 - float2(dx2.y,dy.y )*0.4).x*0.4);
comp_36=`ret2 = lerp(ret2, 2*float3(0.5,1.0,0.0), GetBlur3(uv_m  - float2(dx.y ,dy2.y)*0.4).x*0.4);
comp_37=`
comp_38=`ret  = lerp(ret , 2*float3(0.5,1.0,1.0), GetBlur2(uv_m  - float2(dx.y ,dy2.y)*0.2).x*0.4);
comp_39=`ret2 = lerp(ret2, 2*float3(1.0,0.5,1.0), GetBlur2(uv_m2 - float2(dx2.y,dy.y )*0.2).x*0.4);
comp_40=`
comp_41=`ret = lerp(ret, 2*float3(1,1,0.8), GetBlur1(uv_m - float2(dx.y,dy.y)*0.1).x*0.2);
comp_42=`//ret = lerp(ret, float3(0.5,0,1), GetPixel(uv_m).x*0.4);
comp_43=`
comp_44=`//ret = .7-ret2;
comp_45=`//ret2=.7-ret;
comp_46=`ret-=ret2;
comp_47=`//MilkDrop3 Color Mode:
comp_48=`ret /= float3(-0.5,-0.9,-0.6);
comp_49=`//MilkDrop3 Blow Mode:
comp_50=`float3 avg_col = GetBlur2(uv);ret = abs(avg_col - ret)*2;
comp_51=`}
