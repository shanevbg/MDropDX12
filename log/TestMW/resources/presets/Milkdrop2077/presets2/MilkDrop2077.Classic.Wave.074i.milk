shape_0_per_frame1=x = 0.5 + 0.225*sin(time /instance*mid_att);
shape_0_per_frame2=y = 0.5 + 0.36*cos(time /instance*mid_att);
shape_0_per_frame3=x = x- 0.14*x*sin(time);
shape_0_per_frame4=y = y- 0.44*y*cos(time)-rad;
