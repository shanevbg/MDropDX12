comp_23=`//MilkDrop3 Zoom Mode:
comp_24=`uv = 0.05+ 0.9*uv;
comp_25=`
comp_26=`    ret = tex2D(sampler_main, uv).xyz;
comp_27=`    ret *= 1.42; //gamma
comp_28=`    ret *= ret; //darken
comp_29=`//MilkDrop3 Color Mode:
comp_30=`ret /= float3(0.5,-0.2,2.2);
comp_31=`}
