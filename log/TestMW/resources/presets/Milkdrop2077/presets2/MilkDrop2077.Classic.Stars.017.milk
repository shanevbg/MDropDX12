shape_0_per_frame1=ang=sin(time*0.41)*0.044 * (sin(time*0.41)*0.511+0.511);
shape_0_per_frame2=r=q1;
shape_0_per_frame3=g=q2;
shape_0_per_frame4=b=q3;
per_frame_1=red_value = if(above(bass,1.15),3*(1-bass)+abs(sin(time*0.3)*0.1),if(above(treb,1.0),0, sin(time/2.5)/10+0.65));
per_frame_2=blue_value = if(above(bass,1.15),0.5+abs(sin(time*0.3)*0.1),if(above(treb,1.0),0.7+0.1*sin(time*1.123), 0.3-treb-sin(time/2.5)/10));
per_frame_3=green_value = if(above(bass,1.15),1-abs(sin(time*0.3)*0.1),if(above(treb,1.0),0.6+0.1*sin(time*1.123), sin(time/2.5)/10+0.3));
per_frame_4=wave_r = red_value;
per_frame_5=wave_b= blue_value;
per_frame_6=wave_g = green_value;
per_frame_7=q1 = (cx*2-1) + 0.62*( 0.60*sin(0.374*time) + 0.40*sin(0.294*time) );
per_frame_8=q2 = (cy*2-1) + 0.62*( 0.60*sin(0.393*time) + 0.40*tan(0.223*time) );
per_frame_9=q3 = (cx*2-1) + 0.62*( 0.60*sin(0.174*-time) + 0.40*sin(0.364*time) );
per_frame_10=q4 = (cy*2-1) + 0.62*( 0.60*sin(0.234*time) + 0.40*cos(0.271*-time) );
per_frame_11=decay = decay - 0.01*equal(frame%5,0);
per_pixel_1=du = (x+rad)*2-1 - q1;
per_pixel_2=dv = (y+rad)*2-1 - q2;
per_pixel_3=dist = sqrt(du*du+dv*dv);
per_pixel_4=ang2 = atan2(du,dv);
per_pixel_5=mult = 0.008/(dist+0.4);
per_pixel_6=dx = mult*sin(ang2-1.5)/4;
per_pixel_7=dy = mult*cos(ang2-1.5)/4;
per_pixel_8=du = (1-rad)*2-1 - q3;
per_pixel_9=dv = (1-rad)*2-1 - q4;
per_pixel_10=dist = sqrt(du*du+dv*dv);
per_pixel_11=ang2 = atan2(du,dv);
per_pixel_12=mult = 0.008/(dist+0.4);
per_pixel_13=dx = dx + mult*sin(ang2+1.5)/4;
per_pixel_14=dy = dy + mult*cos(ang2+1.5)/4;
warp_1=`#define sat saturate
warp_2=`static const float quality = 3;
warp_3=`static const float cscale = 0.01;
warp_4=`float3 rsl, rsl2, ret1;
warp_5=`float2 dz, uv0, uv1, uv2, uv3;
warp_6=`float  lav_gnd,noise,noise2,tmp;
warp_7=`
warp_8=`float2 noise3 (float2 uvi,float scale) 
warp_9=`{ uvi.y = sin(uvi.y*2*M_PI)*scale; uvi.x*=scale; 
warp_10=`  return (tex2D(sampler_noise_lq,uvi+time*.0001)
warp_11=`         +tex2D(sampler_noise_lq,uvi*2)/2  
warp_12=`         +tex2D(sampler_noise_lq,uvi*4)/4 
warp_13=`         +tex2D(sampler_noise_lq,uvi*8)/8)/1.5; 
warp_14=`}
warp_15=`
warp_16=`
warp_17=`float3 rs_lav (float2 uvi,float berg) {  float z; float2 rs;
warp_18=` z = .15*(1-berg*3)/length(uvi); 
warp_19=`  rs.x =  z ; rs.y = atan2(uvi.y,uvi.x)/M_PI/2; 
warp_20=`  return float3(rs,z); }
warp_21=`
warp_22=`shader_body {
warp_23=`uv0 = uv_orig; 
warp_24=`float i=0, p=0;
warp_25=`uv1 = uv-0.5;
warp_26=`
warp_27=`float2 uv5 = uv0-float2(0,1-GetPixel(uv0).b)*-texsize.w*4;
warp_28=`lav_gnd=lerp (-0.5, -GetPixel(uv5).b,1);
warp_29=`
warp_30=`for (int n=3; n <= quality; n++) {
warp_31=`  rsl = rs_lav(uv1,lav_gnd) +time*3*float3(.8,.007,0); 
warp_32=`  p = (lav_gnd*1.3+noise3 (rsl.xy, cscale))/quality;
warp_33=`  i += p;
warp_34=`  lav_gnd -= p*2+i*0.4; }
warp_35=`
warp_36=`float l = saturate(-lav_gnd);
warp_37=`ret.r = (lav_gnd +noise3 (rsl.xy+0.004,cscale))*2*sat(rad*2);
warp_38=`ret.b = lerp(l,GetBlur1(uv).b,0.3);
warp_39=`
warp_40=`ret.r += sat(GetPixel(uv0+.01*(uv1)).g)/4;
warp_41=`
warp_42=`ret *= uv.x<0.97;
warp_43=`}
