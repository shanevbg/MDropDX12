shape_0_per_frame1=rad0 = 0.0350;
shape_0_per_frame2=
shape_0_per_frame3=fslot = int (instance/32);
shape_0_per_frame4=x = -0.02 + fslot/31;
shape_0_per_frame5=
shape_0_per_frame6=y0 = (instance%32)/32;
shape_0_per_frame7=y = -0.03 + y0+0.016;
shape_0_per_frame8=
shape_0_per_frame9=lim = max(0,min(1,6*log(1+gmegabuf(fslot)*10) - 20*y0)); 
shape_0_per_frame10=
shape_0_per_frame11=a=0; a2 = a/2;
shape_0_per_frame12=trel = time;
shape_0_per_frame13=if ( lim > 0.1,
shape_0_per_frame14=  r = 1;
shape_0_per_frame15=  g = 1;
shape_0_per_frame16=  b = 1;
shape_0_per_frame17=  r2 = r; g2 = g; b2 = b;
shape_0_per_frame18=  a = min(1,a+lim); a2 = a*1;
shape_0_per_frame19=,
shape_0_per_frame20=r = 1; b = 1; g = 1; r2 = r; b2 = b; g2 = g;;
shape_0_per_frame21=);
shape_0_per_frame22=
shape_0_per_frame23=
shape_0_per_frame24=
shape_0_per_frame25=rad = rad0;
per_frame_init_1=n=0; loop (5000, gmegabuf(n)=0; n+=1);
per_frame_1=dec_f = pow (0.5, 50/fps);
per_frame_2=dec_m = pow (0.84,50/fps);
per_frame_3=dec_s = 1-0.6/fps;
per_frame_4=
per_frame_5=vol = (bass+mid+treb)/3; 
per_frame_6=vol_ = dec_m * vol_ + (1-dec_m)*vol;
per_frame_7=avg = avg*dec_s + vol*(1-dec_s);
per_frame_8=is_beat = above(vol, 1*avg+2*peak) * above (time, t0+.2);
per_frame_9=t0 = is_beat*time + (1-is_beat)*t0;
per_frame_10=peak = is_beat * vol + (1-is_beat)*peak*dec_m;
per_frame_11=index = (index + is_beat) %8;
per_frame_12=index2 = (index2 + is_beat*bnot(index)) %8;
per_frame_13=
per_frame_14=trig = is_beat*(index==0);
per_frame_15=t1 = t1+trig; 
per_frame_16=reg32 = aspecty;
per_frame_17=
per_frame_18=reg19 *= dec_s;
per_frame_19=reg20= reg20*dec_s + (1-dec_s)*reg19*2;
per_frame_20=reg20 = min(10,max(0.05,reg20));
per_frame_21=monitor = reg20;
per_frame_22=
per_frame_23=reg00 = dec_f*0;
per_frame_24=reg01 = dec_m;
per_frame_25=reg02 = dec_s;
per_frame_26=
per_frame_27=reg05 = vol_>.1; //!stop
per_frame_28=
per_frame_29=monitor = dec_m;
warp_1=`shader_body
warp_2=`{
warp_3=`    float4 N = tex2D(sampler_noise_lq, rand_frame.xy + uv*
warp_4=`                             texsize_noise_lq.zw*texsize.xy )*2-1;
warp_5=`    // sample previous frame
warp_6=`    ret = tex2D( sampler_pw_main, uv + N.zw*texsize.zw*0.5 ).xyz;
warp_7=`    ret += (0.59-0.2*rad)*N.xyz;
warp_8=`
warp_9=`
warp_10=`    ret = saturate((ret-0.5)*2 + 0.25);
warp_11=`//    ret.yz = ret.x;
warp_12=`}
comp_1=`shader_body
comp_2=`{
comp_3=`ret = lerp( 0, float3(1, 1, 0), GetBlur2(uv).x*2.5 -  GetBlur1(uv).x*0.7 + tex2D(sampler_main, uv).x*0.75);
comp_4=`ret *= 1- GetBlur1(uv).x*3.85;
comp_5=`ret += float3(0,0,0.7)*tex2D(sampler_main, uv).x + float3(0.25,0.25,0.25)*tex2D(sampler_main, uv).y;
comp_6=`ret *= max(tex2D(sampler_main, uv).y*0.8, GetBlur2(uv).y*0.5);
comp_7=`//ret = tex2D(sampler_main, uv);
comp_8=`//MilkDrop3 Color Mode:
comp_9=`ret /= float3(-0.7,-2.5,2.4);
comp_10=`}
