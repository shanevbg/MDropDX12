wave_2_per_frame1=t1 = 0;
wave_2_per_point1=dis = reg00;
wave_2_per_point2=n = t1;
wave_2_per_point3=x = int(n/dis) *dis/512/2*1+0.501;
wave_2_per_point4=
wave_2_per_point5=y0 = gmegabuf (5000+n/dis+128) * (n%dis < 2) ;
wave_2_per_point6=
wave_2_per_point7=
wave_2_per_point8=y = 0.2+y0*0.52;
wave_2_per_point9=t1 += 1;
wave_2_per_point10=
wave_2_per_point11=a = !(n%dis<=0) && !(n%dis>=dis-2); 
per_frame_init_1=reg00 = 4;
per_frame_1=dec_f = pow (0.2, 30/fps);
per_frame_2=dec_m = pow (0.5, 30/fps);
per_frame_3=
per_frame_4=n = 0;
per_frame_5=loop (256,
per_frame_6=  exc = pow (gmegabuf(n),1)+0.1;
per_frame_7=  dec = if (exc > gmegabuf(5000+n),dec_f,dec_m);
per_frame_8=  gmegabuf (5000+n) = gmegabuf (5000+n)*dec + (1-dec) * exc;
per_frame_9=  n += 1;
per_frame_10=);
per_pixel_1=zoom = 1;
per_pixel_2=
comp_1=`shader_body {
comp_2=`
comp_3=`  ret = GetPixel(uv_orig) ;
comp_4=`
comp_5=`
comp_6=`  ret = saturate(ret*16);
comp_7=`
comp_8=`   ret += GetBlur2(uv)*1;
comp_9=`   ret += GetBlur1(uv)*0;
comp_10=`  ret *= float3 (0., 0.35, 1)*2;;
comp_11=`
comp_12=`  ret += (1-2*length (uv-0.5))*float3 (0,0.,0.4);
comp_13=`}
