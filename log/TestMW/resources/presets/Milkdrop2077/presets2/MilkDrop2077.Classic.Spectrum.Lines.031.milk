wavecode_1_smoothing=0.00000
wavecode_1_r=1.000
wavecode_1_g=1.000
wavecode_1_b=1.000
wavecode_1_a=0.100
wave_1_per_frame1=t1 = 0;
wave_1_per_point1=dis = reg00;
wave_1_per_point2=n = t1;
wave_1_per_point3=x = int(n/dis) *dis/512/2*1+0.001;
wave_1_per_point4=
wave_1_per_point5=y0 = gmegabuf (5000+n/dis) * (n%dis < 2) ;
wave_1_per_point6=
wave_1_per_point7=
wave_1_per_point8=y = 0.2+y0*0.52;
wave_1_per_point9=t1 += 1;
wave_1_per_point10=
wave_1_per_point11=a = !(n%dis<=0) && !(n%dis>=dis-2); 
wavecode_2_enabled=1
wavecode_2_samples=512
wavecode_2_sep=0
wavecode_2_bSpectrum=0
wavecode_2_bUseDots=0
