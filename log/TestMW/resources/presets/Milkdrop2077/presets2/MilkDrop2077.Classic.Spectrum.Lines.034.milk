wavecode_1_smoothing=0.00000
wavecode_1_r=1.000
wavecode_1_g=1.000
wavecode_1_b=1.000
wavecode_1_a=0.100
wave_1_per_frame1=t1 = 0;
wave_1_per_point1=dis = reg00;
wave_1_per_point2=n = t1;
wave_1_per_point3=x = int(n/dis) *dis/256/2*1+0.001;
wave_1_per_point4=
wave_1_per_point5=y0 = gmegabuf (5000+n/dis) * (n%dis < 2) ;
wave_1_per_point6=
wave_1_per_point7=
wave_1_per_point8=y = 0.2+y0*0.52;
wave_1_per_point9=t1 += 1;
wave_1_per_point10=
wave_1_per_point11=a = !(n%dis<=0) && !(n%dis>=dis-2); 
per_frame_init_1=reg00 = 4;
per_frame_1=dec_f = pow (0.2, 30/fps);
per_frame_2=dec_m = pow (0.5, 30/fps);
per_frame_3=
per_frame_4=n = 0;
per_frame_5=loop (256,
per_frame_6=  exc = pow (gmegabuf(n),1)+0.1;
per_frame_7=  dec = if (exc > gmegabuf(5000+n),dec_f,dec_m);
per_frame_8=  gmegabuf (5000+n) = gmegabuf (5000+n)*dec + (1-dec) * exc;
per_frame_9=  n += 1;
per_frame_10=);
per_pixel_1=zoom = 1;
per_pixel_2=
comp_1=`shader_body
comp_2=`{
comp_3=`//MilkDrop3 Multiplicate Mode:
comp_4=`uv = 1- abs( frac((uv-.5)*1.5 * 0.5 ) * 2 - 1.0 );
comp_5=`
comp_6=`
comp_7=`
comp_8=`
comp_9=`
comp_10=`
comp_11=`
comp_12=`
comp_13=`
comp_14=`
comp_15=`
comp_16=`
comp_17=`
comp_18=`
comp_19=`
comp_20=`float2 uv2 = uv;
comp_21=`uv2.x=1-uv2.x;
comp_22=`
comp_23=`    float2 d  = texsize.zw*4;
comp_24=`    float2 d2 = texsize.zw*4;
comp_25=`
comp_26=`    float3 dx  = ( GetBlur1(uv +float2(1,0)*d )-GetBlur1(uv2-float2(1,0)*d2) );
comp_27=`    float3 dx2 = ( GetBlur1(uv2+float2(1,0)*d2)-GetBlur1(uv -float2(0,1)*d ) );
comp_28=`
comp_29=`    float3 dy  = ( GetBlur1(uv2+float2(0,1)*d2)-GetBlur1(uv -float2(1,0)*d ) );
comp_30=`    float3 dy2 = ( GetBlur1(uv +float2(0,1)*d )-GetBlur1(uv2-float2(0,1)*d2) );
comp_31=`
comp_32=`
comp_33=`float2 uv_bg  = uv2 - float2(dx2.y,dy2.y)*texsize.zw*16;
comp_34=`float2 uv_bg2 = uv  - float2(dx.y ,dy.y )*texsize.zw*16;
comp_35=`
comp_36=`        ret = (GetBlur2(uv_bg )-GetBlur1(uv_bg2)*1+GetPixel(uv_bg )*0.9 + (-dx.y  + dy.y )*0.4).y*0.8*float3(1.0,1.1,1.2);
comp_37=`float3 ret2 = (GetBlur2(uv_bg2)-GetBlur1(uv_bg )*1+GetPixel(uv_bg2)*0.9 + (-dx2.y + dy2.y)*0.4).y*0.8*float3(1.2,1.0,1.1);
comp_38=`
comp_39=`float2 uv_m  = uv2 - float2(dx2.x,dy.x )*texsize.zw*8;
comp_40=`float2 uv_m2 = uv  - float2(dx.x ,dy2.x)*texsize.zw*8;
comp_41=`
comp_42=`ret  = lerp(ret , 2*float3(0.0,0.5,1.0), GetBlur3(uv_m2 - float2(dx2.y,dy.y )*0.4).x*0.4);
comp_43=`ret2 = lerp(ret2, 2*float3(0.5,1.0,0.0), GetBlur3(uv_m  - float2(dx.y ,dy2.y)*0.4).x*0.4);
comp_44=`
comp_45=`ret  = lerp(ret , 2*float3(0.5,1.0,1.0), GetBlur2(uv_m  - float2(dx.y ,dy2.y)*0.2).x*0.4);
comp_46=`ret2 = lerp(ret2, 2*float3(1.0,0.5,1.0), GetBlur2(uv_m2 - float2(dx2.y,dy.y )*0.2).x*0.4);
comp_47=`
comp_48=`ret = lerp(ret, 2*float3(1,1,0.8), GetBlur1(uv_m - float2(dx.y,dy.y)*0.1).x*0.2);
comp_49=`//ret = lerp(ret, float3(0.5,0,1), GetPixel(uv_m).x*0.4);
comp_50=`
comp_51=`//ret = .7-ret2;
comp_52=`//ret2=.7-ret;
comp_53=`ret-=ret2;
comp_54=`//MilkDrop3 Color Mode:
comp_55=`ret /= float3(1.8,-2.6,0.8);
comp_56=`//MilkDrop3 Blow Mode:
comp_57=`float3 avg_col = GetBlur2(uv);ret = abs(avg_col - ret)*2;
comp_58=`}
