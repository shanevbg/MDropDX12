wave_0_per_frame1=t1 = 0;
wave_0_per_point1=n = t1;
wave_0_per_point2=gmegabuf (n) = (value1 + value2) * 1/(sample+0.01);
wave_0_per_point3=
wave_0_per_point4=x = sample;
wave_0_per_point5=y = 0.5 - gmegabuf(5000+n)*0.1;
wave_0_per_point6=t1 += 1;
wavecode_1_enabled=1
wavecode_1_samples=512
wavecode_1_sep=0
wavecode_1_bSpectrum=0
wavecode_1_bUseDots=0
wavecode_1_bDrawThick=1
