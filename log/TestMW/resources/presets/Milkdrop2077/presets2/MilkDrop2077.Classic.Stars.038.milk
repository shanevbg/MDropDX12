shape_0_per_frame4=b=q3;
per_frame_1=// -------------------------------- Beat Detective v0.07 ----------------------------------
per_frame_2=sure=if(equal(sure,0),.6,sure);
per_frame_3=interval=if(equal(interval,0),40,interval);
per_frame_4=lastbeat=if(equal(lastbeat,0),frame-FPS,lastbeat);
per_frame_5=dbass=(bass-pbass)/FPS;
per_frame_6=beat=above(dbass,.6*maxdbass)*above(frame-lastbeat,FPS/3);
per_frame_7=sure=if(beat*below(abs(frame-(interval+lastbeat)),FPS/5),
per_frame_8=min(.095+sure,1),beat*(sure-.095)+(1-beat)*sure*.9996);
per_frame_9=sure=max(.5,sure);
per_frame_10=cheat=if(above(frame,lastbeat+interval+ int(FPS/10))*above(sure,.91),1,cheat);
per_frame_11=beat=if(cheat,1,beat);
per_frame_12=sure=if(cheat,.95*sure,sure);
per_frame_13=maxdbass=max(maxdbass*.999,dbass);
per_frame_14=maxdbass=max(.012,maxdbass);
per_frame_15=maxdbass=min(.02,maxdbass);
per_frame_16=interval=if(beat, frame-lastbeat,interval);
per_frame_17=lastbeat=if(beat,frame-cheat*int(FPS/10),lastbeat);
per_frame_18=cheat=0;
per_frame_19=pbass=bass;
per_frame_20=// ----------------------------------------------------------------------------------------------
per_frame_21=warp=0;
per_frame_22=zoom=1;
per_frame_23=temp=(time/6.2831-int(time/6.2831));
per_frame_24=q7=abs(temp*6.2831-3.1415)/3.1415;
per_frame_25=q8=beat;
per_frame_26=
per_frame_27=// this echoes the value of the "beat" variable for one more frame after a beat so that both "sparks" are drawn highlighted (on consecutive frames)
per_frame_28=q8=q8+equal(frame-lastbeat,1);
per_frame_29=
per_frame_30=orient = if(alpha,orient,int(rand(3))+1);
per_frame_31=echo_orient = orient;
per_frame_32=
per_frame_33=trans = if(equal(alpha,0),0,if(equal(alpha,1),0,trans));
per_frame_34=trans = if(equal(trans,0),beat,trans);
per_frame_35=alphadir = if(alpha,if(alpha-1,alphadir,-1),1);
per_frame_36=alpha = alpha + trans*alphadir*(1/fps);
per_frame_37=alpha = max(alpha,0); alpha = min(alpha,1);
per_frame_38=echo_alpha = alpha;
per_frame_39=
per_frame_40=// ------------------ Indecision Code ----------------------
per_frame_41=// xpos and ypos are calculated as springs being acted on by a variable force, comprised of vol and bass_att or treb_att.
per_frame_42=vol = 0.167*(bass+mid);
per_frame_43=xamptarg = if(equal(frame%15,0),min(0.5*vol*bass_att,0.5),xamptarg);
per_frame_44=xamp = xamp + 0.5*(xamptarg-xamp);
per_frame_45=xdir = if(above(abs(xpos),xamp),-sign(xpos),if(below(abs(xspeed),0.1),2*above(xpos,0)-1,xdir));
per_frame_46=xspeed = xspeed + xdir*xamp - xpos - xspeed*0.1*below(abs(xpos),xamp);
per_frame_47=xpos = xpos + 0.001*xspeed;
per_frame_48=yamptarg = if(equal(frame%15,0),min(0.3*vol*treb_att,0.5),yamptarg);
per_frame_49=yamp = yamp + 0.5*(yamptarg-yamp);
per_frame_50=ydir = if(above(abs(ypos),yamp),-sign(ypos),if(below(abs(yspeed),0.1),2*above(ypos,0)-1,ydir));
per_frame_51=yspeed = yspeed + ydir*yamp - ypos - yspeed*0.1*below(abs(ypos),yamp);
per_frame_52=ypos = ypos + 0.001*yspeed;
per_frame_53=// ---------------------------------------------------------
per_frame_54=
per_frame_55=q1 = xpos;
per_frame_56=q2 = ypos;
per_frame_57=
per_frame_58=ob_g = max(min(0.5*(sin(1.345*time)+sin(0.987*time))+0.2,0.4),0);
per_frame_59=ob_b = max(min(0.5*(sin(1.543*time)+sin(0.789*time))+0.2,0.4),0);
per_frame_60=ob_r = max(min(0.5*(sin(0.876*time)+sin(0.543*time))+0.1,0.2),0);
per_frame_61=ib_g = max(min(0.5*(sin(1.246*time)+sin(0.864*time))+0.2,0.4),0);
per_frame_62=ib_b = max(min(0.5*(sin(1.642*time)+sin(0.468*time))+0.2,0.4),0);
per_frame_63=ib_r = max(min(0.5*(sin(0.765*time)+sin(0.654*time))+0.1,0.2),0);
per_frame_64=
per_frame_65=basschange = 0.1*basschange+0.01*bass;
per_frame_66=midchange = 0.1*midchange+0.01*mid;
per_frame_67=trebchange = 0.1*trebchange+0.01*treb;
per_frame_68=
per_frame_69=basstime = basstime + basschange;
per_frame_70=midtime = midtime + midchange;
per_frame_71=trebtime = trebtime + trebchange;
per_frame_72=
per_frame_73=q3 = basstime;
per_frame_74=q4 = midtime;
per_frame_75=q5 = trebtime;
per_frame_76=
per_frame_77=q6 = frame%2;
per_pixel_1=zoom=.99+(rad/10);
per_pixel_2=rot=rad/100;
warp_1=`shader_body {
warp_2=`ret = min (0.4,GetBlur2(uv))*0.85 * (1-lum(GetBlur1(uv))*0.1);
warp_3=`//ret = max(ret,GetBlur2((uv-.15)*3.25+.5)*.02);
warp_4=`
warp_5=`float tx = time*12;
warp_6=`float2 uv3 = uv-.95-.3*float2(sin(tx),cos(tx))-.0*(tex2D(sampler_noise_lq,uv/8+rand_frame).r-.5);
warp_7=`ret += q25/length(uv3)* saturate(tan(+18*atan2(uv3.y,uv3.x)))*(roam_cos+1) ;
warp_8=`
warp_9=`}
comp_1=`shader_body
comp_2=`{
comp_3=`//MilkDrop3 Lava Mode:
comp_4=`uv += 0.03*sin(uv.x*50.0)*cos(uv.y*50.0)*(0.5+0.5*sin(0.5))*(1.0-0.5*sin(2.0));
comp_5=`
comp_6=`float2 uv2 = uv;
comp_7=`uv2.x=1-uv2.x;
comp_8=`
comp_9=`    float2 d  = texsize.zw*4;
comp_10=`    float2 d2 = texsize.zw*4;
comp_11=`
comp_12=`    float3 dx  = ( GetBlur1(uv +float2(1,0)*d )-GetBlur1(uv2-float2(1,0)*d2) );
comp_13=`    float3 dx2 = ( GetBlur1(uv2+float2(1,0)*d2)-GetBlur1(uv -float2(0,1)*d ) );
comp_14=`
comp_15=`    float3 dy  = ( GetBlur1(uv2+float2(0,1)*d2)-GetBlur1(uv -float2(1,0)*d ) );
comp_16=`    float3 dy2 = ( GetBlur1(uv +float2(0,1)*d )-GetBlur1(uv2-float2(0,1)*d2) );
comp_17=`
comp_18=`
comp_19=`float2 uv_bg  = uv2 - float2(dx2.y,dy2.y)*texsize.zw*16;
comp_20=`float2 uv_bg2 = uv  - float2(dx.y ,dy.y )*texsize.zw*16;
comp_21=`
comp_22=`        ret = (GetBlur2(uv_bg )-GetBlur1(uv_bg2)*1+GetPixel(uv_bg )*0.9 + (-dx.y  + dy.y )*0.4).y*0.8*float3(1.0,1.1,1.2);
comp_23=`float3 ret2 = (GetBlur2(uv_bg2)-GetBlur1(uv_bg )*1+GetPixel(uv_bg2)*0.9 + (-dx2.y + dy2.y)*0.4).y*0.8*float3(1.2,1.0,1.1);
comp_24=`
comp_25=`float2 uv_m  = uv2 - float2(dx2.x,dy.x )*texsize.zw*8;
comp_26=`float2 uv_m2 = uv  - float2(dx.x ,dy2.x)*texsize.zw*8;
comp_27=`
comp_28=`ret  = lerp(ret , 2*float3(0.0,0.5,1.0), GetBlur3(uv_m2 - float2(dx2.y,dy.y )*0.4).x*0.4);
comp_29=`ret2 = lerp(ret2, 2*float3(0.5,1.0,0.0), GetBlur3(uv_m  - float2(dx.y ,dy2.y)*0.4).x*0.4);
comp_30=`
comp_31=`ret  = lerp(ret , 2*float3(0.5,1.0,1.0), GetBlur2(uv_m  - float2(dx.y ,dy2.y)*0.2).x*0.4);
comp_32=`ret2 = lerp(ret2, 2*float3(1.0,0.5,1.0), GetBlur2(uv_m2 - float2(dx2.y,dy.y )*0.2).x*0.4);
comp_33=`
comp_34=`ret = lerp(ret, 2*float3(1,1,0.8), GetBlur1(uv_m - float2(dx.y,dy.y)*0.1).x*0.2);
comp_35=`//ret = lerp(ret, float3(0.5,0,1), GetPixel(uv_m).x*0.4);
comp_36=`
comp_37=`//ret = .7-ret2;
comp_38=`//ret2=.7-ret;
comp_39=`ret-=ret2;
comp_40=`//MilkDrop3 Color Mode:
comp_41=`ret /= float3(-2.1,-1.9,2.6);
comp_42=`//MilkDrop3 Blow Mode:
comp_43=`float3 avg_col = GetBlur2(uv);ret = abs(avg_col - ret)*2;
comp_44=`}
