shape_0_per_frame1=rad0 = 0.042;
shape_0_per_frame2=
shape_0_per_frame3=fslot = int (instance/32);
shape_0_per_frame4=x = -0.015 + fslot/30;
shape_0_per_frame5=
shape_0_per_frame6=y0 = (instance%32)/32;
shape_0_per_frame7=y = -0.03 + y0+0.015;
shape_0_per_frame8=
shape_0_per_frame9=lim = max(0,min(1,6*log(1+gmegabuf(fslot)*10) - 20*y0)*50); 
shape_0_per_frame10=
shape_0_per_frame11=a=0; a2 = a/2;
shape_0_per_frame12=trel = time;
shape_0_per_frame13=if ( lim > 0.1,
shape_0_per_frame14=  r = 1;
shape_0_per_frame15=  g = 1;
shape_0_per_frame16=  b = 1;
shape_0_per_frame17=  r2 = r; g2 = g; b2 = b;
shape_0_per_frame18=  a = min(1,a+lim); a2 = a;
shape_0_per_frame19=,
shape_0_per_frame20=r = 1; b = 1; g = 1; r2 = r; b2 = b; g2 = g;;
shape_0_per_frame21=);
shape_0_per_frame22=
shape_0_per_frame23=
shape_0_per_frame24=
shape_0_per_frame25=rad = rad0;
per_frame_1=wave_y = 1.4;
per_frame_2=decay = decay - 0.02*equal(frame%30,0);
per_pixel_1=dx = dx + (x*2-1.5)*0.002 + 0.0015*sin(y*12 + time*1.03);
per_pixel_2=dy = dy + 0.01+ 0.005*sin(y*26-13) + 0.005*sin(x*4.2 + time*1.303);
warp_1=`
warp_2=`shader_body {
warp_3=`
warp_4=`
warp_5=`//ret.r = saturate(struc2*0) * (length(box) > q30);
warp_6=`
warp_7=`ret.b = max(GetPixel((uv_orig-0.5)*1.02+0.5).b*.98,ret.r);
warp_8=`
warp_9=`}
comp_1=`sampler sampler_pw_noise_lq;
comp_2=`float3 ret1;
comp_3=`float2 zz, uv0, uv1,uv2,uv3,uv4;
comp_4=`float smask;
comp_5=`
comp_6=`float aTan2(float y, float x) {float angle;	 float abs_y = abs(y);
comp_7=`if (x >= 0) {float r = (x - abs_y) / (x + abs_y); angle = 1-r;} 
comp_8=`else {float r = (x + abs_y) / (abs_y - x); angle = 3-r; }	
comp_9=`angle = angle * .25;
comp_10=`return y < 0 ? -angle : angle;}
comp_11=`
comp_12=`shader_body {
comp_13=`
comp_14=`
comp_15=`
comp_16=`
comp_17=` ;
comp_18=`uv0 = uv;
comp_19=`uv1 = (uv-.5)*aspect.xy;
comp_20=`
comp_21=`uv1 = (uv - .5) * aspect.xy;    
comp_22=`float stars = 0; float dist, inten;
comp_23=`int n = 1;
comp_24=`int anz = 4;
comp_25=`while (n <= anz) {
comp_26=`  dist = (1-frac(1.0/anz*n+.10*time)) * (1-.2*rad);
comp_27=`  inten =  (1-dist);
comp_28=`  uv3 = (uv1+float2(q1,q2));
comp_29=`   uv4 = 64*dist*uv3;
comp_30=`  smask = (tex2D (sampler_pw_noise_lq,uv4/256)).g-.9;
comp_31=`  stars += max(stars,saturate(inten*(0.11/length(abs(frac(uv4)-0.47))*smask)));
comp_32=`n++;
comp_33=`}
comp_34=`uv2 = uv1 - float2(q5,q6);
comp_35=`float beat = (mid - 0.45) * (mid > 0.45)*2;
comp_36=`float flash = .01/(length(uv2))*min(3,pow(beat,1));
comp_37=`flash *= flash/(abs(frac(3*aTan2(uv2.x,uv2.y)+time*2)-.5));
comp_38=`ret1 = max(GetPixel(uv0)*2,GetBlur2(uv0)*2);
comp_39=`//ret = saturate(0.022/length(sin(uv3)))*float3(0.2,2.6,0.1); //MilkDrop2077 color mod
comp_40=`ret += saturate(pow(stars,2));
comp_41=`ret *= saturate(1-2*lum(ret1));
comp_42=`ret +=  ret1;
comp_43=`ret -= 0.1;
comp_44=`//ret += 2*saturate(flash)*float3(2.2,2.9,0.7); //MilkDrop2077 color mod
comp_45=`ret /= float3(2.0,2.9,2.3);
comp_46=`ret*=1.4;
comp_47=`//MilkDrop3 Brightness Mode:
comp_48=`ret *= 1.2;
comp_49=`//MilkDrop3 Color Mode:
comp_50=`//ret /= float3(1.2,1.3,-0.1);
comp_51=`}
