wave_2_per_point1=tm=(time)*0.15;
wave_2_per_point2=phs=sample*0.24;
wave_2_per_point3=
wave_2_per_point4=x=sin(tm+phs) * sin((tm+phs)*3.6) ;
wave_2_per_point5=y=cos((tm+phs)*1.3) * sin((tm+phs)*6.7);
wave_2_per_point6=
wave_2_per_point7=x=x*0.35 + 0.5;
wave_2_per_point8=y=1-(y*0.35 + 0.5);
wave_2_per_point9=
wave_2_per_point10=a=(sample)
