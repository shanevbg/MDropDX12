wavecode_4_a=1.000
wave_4_per_point1=curves=32* cos(time);
wave_4_per_point2=wave=sample*curves*tan(time);
wave_4_per_point3=x=rad*.5+.15* sin(wave) * cos(.2*time)+sample;
wave_4_per_point4=y=.5+.15*( cos(wave+time) +sqrt(sample)*3*rad);
wavecode_5_enabled=1
wavecode_5_samples=512
wavecode_5_sep=0
wavecode_5_bSpectrum=0
wavecode_5_bUseDots=1
