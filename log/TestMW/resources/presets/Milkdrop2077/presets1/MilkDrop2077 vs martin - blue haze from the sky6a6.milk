wave_0_per_frame1=t1 = 512;
wave_0_per_point1=base = t1*reg01;
wave_0_per_point2=  z0 = max(0.1,gmegabuf(base+2));  
wave_0_per_point3=  x = gmegabuf(base) / z0 * reg05;
wave_0_per_point4=  y = gmegabuf(base+1) / z0 * reg05;
wave_0_per_point5=  b = min(1,2*(y-z0));
wave_0_per_point6=  r1 = sqrt(x*x+y*y);
wave_0_per_point7=  x += q10; y+= q11;;
wave_0_per_point8=  
wave_0_per_point9=  a = gmegabuf(base+6) * max(0.1,1-z0) * max(0,1-r1);;
wave_0_per_point10=
wave_0_per_point11=t1 += 1;
wavecode_1_enabled=1
