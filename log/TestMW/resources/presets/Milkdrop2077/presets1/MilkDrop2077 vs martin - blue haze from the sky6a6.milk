wavecode_3_g=1.000
wavecode_3_b=1.000
wavecode_3_a=1.000
wave_3_per_point1=    x=sample;
wave_3_per_point2=    y=value1*.25 + .25;
wave_3_per_point3=    y = .5 - (.25 - y);
wavecode_4_enabled=1
wavecode_4_samples=512
