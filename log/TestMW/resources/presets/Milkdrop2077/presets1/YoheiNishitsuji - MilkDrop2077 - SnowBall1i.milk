wave_0_per_point1=i=t1;
wave_0_per_point2=speed=.06;
wave_0_per_point3=
wave_0_per_point4=z=megabuf(3*i+2);
wave_0_per_point5=x = megabuf(3*i)/z+.5;
wave_0_per_point6=y = megabuf(3*i+1)/z*reg32+0.5;
wave_0_per_point7=
wave_0_per_point8=out=(x>1)||(x<0)||(y>1)||(y<0)||(z<0);
wave_0_per_point9=if (out,
wave_0_per_point10=  megabuf(3*i)= (rand(2)-1)/8; //x
wave_0_per_point11=  megabuf(3*i+1)=(rand(2)-1)/8; //y
wave_0_per_point12=  megabuf(3*i+2)=rand(1);
wave_0_per_point13=,
wave_0_per_point14=  megabuf(i*3+2)-=speed/50;
wave_0_per_point15=);
wave_0_per_point16=
wave_0_per_point17=a=(1-pow(z,1))/2;
wave_0_per_point18=t1+=1;
per_frame_init_1=
per_frame_init_2=c_x = 0.5;
per_frame_init_3=c_y = 0.5;
per_frame_1=
per_frame_2=xx1 = xx1*0.9 + (bass)*0.01;
per_frame_3=xx2 = xx2*0.9 + (treb)*0.01;
per_frame_4=yy1 = yy1*0.94 + (treb+bass)*0.0075;
per_frame_5=x1 = 0.5 + (xx1-xx2)*.2;
per_frame_6=y1 = 0.4 + yy1*0.1;
per_frame_7=dt = 0.03/fps;
per_frame_8=vx2 = vx2*(1-2*dt) + dt*((x1+x3-2*x2)*10);
per_frame_9=vy2 = vy2*(1-2*dt) + dt*((y1+y3-2*y2)*10-0.5);
per_frame_10=vx3 = vx3*(1-2*dt) + dt*((x2+x4-2*x3)*10);
per_frame_11=vy3 = vy3*(1-2*dt) + dt*((y2+y4-2*y3)*10-0.5);
per_frame_12=vx4 = vx4*(1-2*dt) + dt*((x3-x4)*10);
per_frame_13=vy4 = vy4*(1-2*dt) + dt*((y3-y4)*10-0.5);
per_frame_14=x2 = x2 + vx2; y2 = y2 + vy2;
per_frame_15=x3 = x3 + vx3; y3 = y3 + vy3;
per_frame_16=x4 = x4 + vx4; y4 = y4 + vy4;
per_frame_17=vx2 = if(above(x2,0),vx2,abs(vx2)*0.5);
per_frame_18=vx2 = if(below(x2,1),vx2,-abs(vx2)*0.5);
per_frame_19=vx3 = if(above(x3,0),vx3,abs(vx3)*0.5);
per_frame_20=vx3 = if(below(x3,1),vx3,-abs(vx3)*0.5);
per_frame_21=vx4 = if(above(x4,0),vx4,abs(vx4)*0.5);
per_frame_22=vx4 = if(below(x4,1),vx4,-abs(vx4)*0.5);
per_frame_23=vy2 = if(above(y2,0),vy2,abs(vy2)*0.5);
per_frame_24=vy2 = if(below(y2,1),vy2,-abs(vy2)*0.5);
per_frame_25=vy3 = if(above(y3,0),vy3,abs(vy3)*0.5);
per_frame_26=vy3 = if(below(y3,1),vy3,-abs(vy3)*0.5);
per_frame_27=vy4 = if(above(y4,0),vy4,abs(vy4)*0.5);
per_frame_28=vy4 = if(below(y4,1),vy4,-abs(vy4)*0.5);
per_frame_29=q1 = x1;q2 = x2;q3 = x3;q4 = x4;
per_frame_30=q5 = y1;q6 = y2;q7 = y3;q8 = y4;
per_frame_31=q9 = 1/aspectx;
per_frame_32=q10 = 1/aspecty;
per_frame_33=q11 = aspectx;
per_frame_34=q12 = aspecty;
per_frame_35=q13 = sqrt(vx4*vx4 + vy4*vy4)*0.8;
per_frame_36=q14 = atan2(vx4,vy4);
per_frame_37=zoom=0.2;
per_frame_38=rot=1+time/3;
per_pixel_1=d = (pow(sqrt(sqr(x-q3)+sqr(y-q4)),2)-0.);
per_pixel_2=v = 0.03;
per_pixel_3=dx = v*(x-q23)*d;
per_pixel_4=dy = v*(y-q24)*d;
warp_1=`shader_body{
warp_2=`
warp_3=`//Shader from https://x.com/YoheiNishitsuji/status/1923362809569837131
warp_4=`//Ported to MilkDrop by MilkDrop2077
warp_5=`//MIT Licensed
warp_6=`
warp_7=`    float aspect = aspect.x / aspect.y;
warp_8=`    float2 u = (uv - 0.5) * float2(aspect, 1.0) * 4.0;
warp_9=`    float4 o = float4(0.0, 0.0, 0.0, 0.0);
warp_10=`    float t = time;
warp_11=`    float g = 0.0;
warp_12=`    
warp_13=`    for(float i = 0.0; i < 99.0; i += 1.0) {
warp_14=`        float3 p = float3(u.x, u.y, g - 6.0);
warp_15=`        float3 A = float3(0.0, 9.0, -3.0)/9.5;
warp_16=`        p.y += 1.0;
warp_17=`        
warp_18=`        // 3D rotation
warp_19=`        p = A * dot(p+p, A) - p - 0.34*cross(p, A);
warp_20=`        
warp_21=`        // 2D rotation
warp_22=`        float2x2 rot = float2x2(
warp_23=`            cos(t*0.3), -sin(t*0.3),
warp_24=`            sin(t*0.3), cos(t*0.3)
warp_25=`        );
warp_26=`        p.xz = mul(p.xz, rot);
warp_27=`        
warp_28=`        float s = 6.0;
warp_29=`        float e;
warp_30=`        
warp_31=`        // Fractal iteration
warp_32=`        for(int j = 0; j < 13; j++) {
warp_33=`            e = 16.0 / dot(p, p);
warp_34=`            s *= e;
warp_35=`            p = float3(0.0, 4.03, -0.5) - abs(abs(p)*e - float3(3.0, 4.0, 3.0));
warp_36=`        }
warp_37=`        
warp_38=`        g += 0.3 * p.y*p.y / s;
warp_39=`        o += (log2(s) - g*0.8) / 700.0 * float4(0.9, 1.0, 1.0, 0.0);
warp_40=`    }
warp_41=`    
warp_42=`    ret = float4(tanh(o.x), tanh(o.y), tanh(o.z), 1.0);
warp_43=`}
comp_1=`shader_body
comp_2=`{//MilkDrop3 Flip Mode:
comp_3=`uv = 1-uv;
comp_4=`
comp_5=`    ret = tex2D(sampler_main, uv).xyz;
comp_6=`    ret *= 1.28; //gamma
comp_7=`    ret *= hue_shader; //old hue shader effect
comp_8=`    ret *= ret; //darken
comp_9=`//MilkDrop3 Color Mode:
comp_10=`ret /= float3(1.2,1.3,0.8);
comp_11=`}
