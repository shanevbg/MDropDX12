mv_g=1.000
mv_b=0.000
mv_a=0.000
b1n=0.000
b2n=0.000
b3n=0.000
b1x=1.000
b2x=1.000
b3x=1.000
b1ed=0.250
warp_1=`shader_body
warp_2=`{
warp_3=`    float2 r = float2(1.0, 1.0);
warp_4=`    
warp_5=`    // First layer: spinning clockwise
warp_6=`    float2 uv_rotated1 = uv - 0.5; // Center coordinates
warp_7=`    float angle1 = time * 0.5; // Rotation speed (clockwise)
warp_8=`    float cos_angle1 = cos(angle1);
warp_9=`    float sin_angle1 = sin(angle1);
warp_10=`    uv_rotated1 = float2(
warp_11=`        uv_rotated1.x * cos_angle1 - uv_rotated1.y * sin_angle1,
warp_12=`        uv_rotated1.x * sin_angle1 + uv_rotated1.y * cos_angle1
warp_13=`    ) + 0.5; // Restore original coordinate space
warp_14=`    
warp_15=`    float2 p1 = (uv_rotated1 * 2.0 - r) / r.y;
warp_16=`    float d1 = length(p1) - 0.5 +bass_att/12 + 0.01 / (p1.x - p1.y);
warp_17=`    float o1 = 0.05 / abs(d1);
warp_18=`    
warp_19=`    // Second layer: spinning counterclockwise
warp_20=`    float2 uv_rotated2 = uv - 0.5; // Center coordinates
warp_21=`    float angle2 = -time * 0.5; // Rotation speed (counterclockwise)
warp_22=`    float cos_angle2 = cos(angle2);
warp_23=`    float sin_angle2 = sin(angle2);
warp_24=`    uv_rotated2 = float2(
warp_25=`        uv_rotated2.x * cos_angle2 - uv_rotated2.y * sin_angle2,
warp_26=`        uv_rotated2.x * sin_angle2 + uv_rotated2.y * cos_angle2
warp_27=`    ) + 0.5; // Restore original coordinate space
warp_28=`    
warp_29=`    float2 p2 = (uv_rotated2 * 2.0 - r) / r.y;
warp_30=`    float d2 = length(p2) - 0.5 + 0.01 / (p2.x - p2.y);
warp_31=`    float o2 = 0.08 / abs(d2);
warp_32=`    
warp_33=`    // Combine both layers
warp_34=`    ret = float3(o1 + o2, o1 + o2, o1 + o2); // Additive blending
warp_35=`}
comp_1=`#define sat saturate
comp_2=`sampler sampler_pw_noise_lq;
comp_3=`float2 uv1, uv2;
comp_4=`float3 rg, rg2, rg3, oo;
comp_5=`float li,m;
comp_6=`static const float sin60 = sin(M_PI/3), rrad=0.1;
comp_7=`static const float2 kpos = float2 (6,0);
comp_8=`
comp_9=`float3 proj (float2 eang) {
comp_10=`  float2 d = kpos-eang.yx*float2(-1,1);  //Diff zw. Ref. pq und Kamera
comp_11=`  float z = 1/(uv1.y*eang.x - uv1.x*eang.y)-(4*rand_preset.x-rand_preset.z/(rand_preset.y-length(uv1)))*sign(uv1.x);
comp_12=`  return float3 (float2 (d.y*uv1.x-d.x*uv1.y, d.y*eang.x-d.x*eang.y)*z*float2(sin60,0.4),z);}
comp_13=`
comp_14=`float rahmen2 (float2 uvi){
comp_15=`  uvi=abs(uvi);
comp_16=`  return sat(1-10*abs(max (uvi.x,uvi.y)-.48));}
comp_17=`
comp_18=`float3 ring1 (float2 uvi){
comp_19=`  float k = length(uv1)-rrad+(bass_att/80);
comp_20=`  float r=saturate(1-5000*pow(k,2));
comp_21=`  return float3 ( 1*(r>0)*(uv1.xy)*(1-r)*sign(k),r);}
comp_22=`
comp_23=`float3 ring2 (float2 uvi){
comp_24=`  float k2 = length(uv1)-rrad*2+(treb_att/50);
comp_25=`  float r2=saturate(1-5000*pow(k2,2));
comp_26=`  return float3 ( 1*(r2>0)*(uv1.xy)*(1-r2)*sign(k2),r2);}
comp_27=`
comp_28=`float3 ring3 (float2 uvi){
comp_29=`  float k3 = length(uv1)-rrad*3+(mid_att/60);
comp_30=`  float r3=saturate(1-5000*pow(k3,2));
comp_31=`  return float3 ( 1*(r3>0)*(uv1.xy)*(1-r3)*sign(k3),r3);}
comp_32=`
comp_33=`
comp_34=`shader_body
comp_35=`{
comp_36=`float2 uv0=uv;
comp_37=`uv1 = (uv-0.5)*aspect.xy ;
comp_38=`
comp_39=`rg=ring1(uv1);
comp_40=`uv += rg.xy;
comp_41=`ret = (GetPixel(uv)+GetBlur1(uv));
comp_42=`ret += (rg.z)*GetPixel(.3+.01*sin(ang*4))*1.4;
comp_43=`
comp_44=`rg2=ring2(uv1);
comp_45=`uv += rg2.xy;
comp_46=`ret = (GetPixel(uv)+GetBlur1(uv));
comp_47=`ret += (rg2.z)*GetPixel(.3+.01*sin(ang*4))*1.4;
comp_48=`
comp_49=`rg3=ring3(uv1);
comp_50=`uv += rg3.xy;
comp_51=`ret = (GetPixel(uv)+GetBlur1(uv));
comp_52=`ret += (rg3.z)*GetPixel(.3+.01*sin(ang*4))*1.4;
comp_53=`
comp_54=`
comp_55=`//ret = 0;
comp_56=`//MilkDrop3 Red Dot:
comp_57=`ret /= float3(rad*3,1,1);
comp_58=`//MilkDrop3 Color Mode:
comp_59=`ret /= float3(1.9,2.9,1.8);
comp_60=`}

