shape_3_per_frame8=
warp_1=`shader_body
warp_2=`{
warp_3=`    float t = time;
warp_4=`    float3 c = 0.0;
warp_5=`    uv = (uv_orig - 0.5) * aspect.xy * 16.0;
warp_6=`    
warp_7=`    float i = 1.0;
warp_8=`    while (i < 64.0) {
warp_9=`        float s = frac(i * 0.1) * frac((i * 0.7 + t * 0.3));
warp_10=`        
warp_11=`        if (s <= 0.95) {
warp_12=`            float x = i * 0.1;
warp_13=`            float y = i * 0.25;
warp_14=`            float w = cos(t * 0.5 + i * 0.2) * 0.2;  
warp_15=`            
warp_16=`            float f = 0.5; // Base falling speed
warp_17=`            float a = frac(i * 0.2 + frac(x * 0.1) * frac(x * 0.3) * 100.0 + w);  
warp_18=`            float b = frac(i * 0.3 + frac(y * 0.1) * abs(time) / 200 * frac(y * 0.04) * 100.0);             
warp_19=`            float2 p = -3.0 + 6.0 * float2(a, b);
warp_20=`            float l = length(uv - p * 2.8);
warp_21=`            
warp_22=`            float r2 = frac(i * 0.5 * bass_att / 33) * frac(i * 0.1);
warp_23=`            float g2 = frac(i * 0.5 * bass_att / 33) * frac(i * 0.1);
warp_24=`            float b2 = frac(i * 0.5 * bass_att / 32) * frac(i * 0.9);
warp_25=`            float3 o = float3(r2, g2, b2) * 0.5;           
warp_26=`            c += o * 0.12 / (0.001 + l * l * 1.5);
warp_27=`        }
warp_28=`        
warp_29=`        i += 1.0;
warp_30=`    }
warp_31=`    
warp_32=`    ret = float4(c, 1.0);
warp_33=`}
comp_1=`shader_body
comp_2=`{
comp_3=`    ret = GetPixel(uv);
comp_4=`//MilkDrop3 Shadows Mode:
comp_5=`ret += pow(tex2D(sampler_main,float2(uv.x,1-uv.y)).yyy+tex2D(sampler_main,1-uv).yyy,float3(3,2,1.3));
comp_6=`}
