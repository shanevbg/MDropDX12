per_frame_init_1=bassc=0;
per_frame_init_2=midc=0;
per_frame_init_3=mcount=0;
per_frame_init_4=bcount=0;
per_frame_1=decay = 12.9;
per_frame_2=warp = 0.1;
per_frame_3=
per_frame_4=bassc = if(above(bass,bassc),bassc + bass*.07,bassc-.03);
per_frame_5=midc = if(above(mid,midc),midc + mid*.07,midc-.03);
per_frame_6=
per_frame_7=q1 = bassc;
per_frame_8=q2 = midc;
per_pixel_1=zoom = rad+pow(rad-tan(12),3+sin(q2/17));
warp_1=`shader_body
warp_2=`{ret=tex2D(sampler_fc_main,uv).xyz;ret*=0.96;}
comp_1=`#define sat saturate
comp_2=`float fog, lav_gnd;
comp_3=`float2 dz, dz1, uv0, uv1, uv3;
comp_4=`float3 rsl, mod, ret0, mod2, lake;
comp_5=`static const float a = aspect.x/aspect.y, k1=16, k2 = 0.04, gmod = q21;
comp_6=`static const float hory = q6, xyscale = q7, alti = q8, dir = q2;
comp_7=`static const float2 modran = float2 (q15,q16);
comp_8=`
comp_9=`static const float2 hor = texsize.zw*float2 (1,0),ver = texsize.zw*float2 (0,1);
comp_10=`static const float3 mov = float3 (q10,q11,0);
comp_11=`
comp_12=`float3 rs_lav (float2 uvi, float berg) {  float z; float2 rs;
comp_13=`  z = 1/(uvi.y+hory)*(alti-berg*k1); 
comp_14=`  z *= z * k2;
comp_15=`  rs.x = uvi.x * a*z ; rs.y = z; 
comp_16=`  return float3(rs,z)+mov; }
comp_17=`
comp_18=`shader_body {
comp_19=`ret0 = GetPixel(uv);
comp_20=`rsl = rs_lav (uv-0.5,ret0.b*0.5+.5);
comp_21=`mod = tex2D(sampler_noise_mq, rsl*0.00007+modran.yx);
comp_22=`mod2 = tex2D(sampler_noise_mq, rsl*0.00005+modran);
comp_23=`fog = 3 + 0.5*mod2.x;
comp_24=`ret = ret0;;;
comp_25=`ret = lerp (GetBlur1(uv),ret0.r,ret0.g*3) ;
comp_26=`ret = ret.r;
comp_27=`
comp_28=`ret = lerp (ret, ret0,sat(ret0.g*ret0.g*gmod));
comp_29=`lake = max(sat (6*(ret0.b -0.9)) * pow (tex3D(sampler_noisevol_lq,0.05*rsl*float3 (1,1,0.2)),4)*4*sat(50/abs(rsl.z)),
comp_30=`            sat (4*ret0.b-fog))*normalize(mod);
comp_31=`
comp_32=`
comp_33=`//ret = max (lake,ret);
comp_34=`ret += lake;
comp_35=`//ret = ret0.g;
comp_36=`ret /= float3(-2.9,1.0,-2.7);
comp_37=`ret*=3;
comp_38=`//MilkDrop3 Color Mode:
comp_39=`ret /= float3(-0.4,1.3,-1.8);
comp_40=`//MilkDrop3 Blow Mode:
comp_41=`float3 avg_col = GetBlur2(uv);ret = abs(avg_col - ret)*2;
comp_42=`}

