bInvert=0
fWaveAlpha=1.000
fWaveScale=0.500
fWaveSmoothing=0.190
fWaveParam=0.010
fModWaveAlphaStart=0.500
fModWaveAlphaEnd=0.950
fWarpAnimSpeed=1.000
fWarpScale=1.331
fZoomExponent=1.00000
fShader=1.000
zoom=1.00400
rot=0.00000
cx=0.500
cy=0.500
dx=0.00000
dy=0.00000
warp=0.19788
sx=0.99967
sy=0.99990
wave_r=0.650
wave_g=0.650
wave_b=0.650
wave_x=0.530
wave_y=0.440
ob_size=0.000
ob_r=1.000
ob_g=0.000
ob_b=0.000
ob_a=0.700
ib_size=0.000
ib_r=0.000
ib_g=0.000
ib_b=0.000
ib_a=1.000
nMotionVectorsX=64.000
nMotionVectorsY=48.000
mv_dx=0.000
mv_dy=0.000
mv_l=0.000
mv_r=1.000
mv_g=1.000
mv_b=1.000
mv_a=0.000
b1n=0.000
b2n=0.000
b3n=0.000
b1x=1.000
b2x=1.000
b3x=1.000
b1ed=0.250
per_frame_1=mv_r = mv_r + 0.2*( 0.60*sin(0.980*time) + 0.40*sin(1.047*time) );
per_frame_2=mv_g = mv_g + 0.2*( 0.60*sin(0.835*time) + 0.40*sin(1.081*time) );
per_frame_3=mv_b = mv_b + 0.2*( 0.60*sin(0.814*time) + 0.40*sin(1.011*time) );
per_frame_4=q1 = (cx*2-1) + 0.6*( 0.60*sin(0.374*time) + 0.40*sin(0.294*time) );
per_frame_5=q2 = (cy*2-1) + 0.6*( 0.60*sin(0.393*time) + 0.40*sin(0.223*time) );
per_frame_6=ob_r = 1- 0.4*abs(q1);
per_frame_7=ob_g = 0.3*abs(q2);
per_frame_8=ob_b = 0.4*abs(q1);
per_frame_9=wave_x = 1-abs(q2)-0.05;
per_frame_10=wave_y = 1-abs(q1)-0.06;
per_frame_11=wave_r = wave_r + 0.4*( 0.60*sin(0.514*time) + 0.40*sin(1.211*time) );
per_frame_12=wave_b = wave_b + 0.4*( 0.60*sin(0.714*time) + 0.40*sin(q2) );
per_frame_13=wave_g = wave_g + 0.4*( 0.60*sin(10*q1) + 0.40*sin(10*q2) );
per_frame_14=zoom = 1;
per_frame_15=warp = 0;
per_frame_16=chng=sin(time*.5);
per_frame_17=cthr=.9999;
per_frame_18=mq21=if(above(chng,cthr),rand(3),mq21);
per_frame_19=mq22=if(above(chng,cthr),rand(3),mq22);
per_frame_20=mq23=if(above(chng,cthr),rand(3),mq23);
per_frame_21=mq24=if(above(chng,cthr),rand(2),mq24);
per_frame_22=mq25=if(above(chng,cthr),rand(2),mq25);
per_frame_23=mq26=if(above(chng,cthr),rand(2),mq26);
per_frame_24=mq27=if(above(chng,cthr),rand(1),mq27);
per_frame_25=mq28=if(above(chng,cthr),rand(1),mq28);
per_frame_26=mq29=if(above(chng,cthr),rand(1)*.3,mq29);
per_frame_27=mq31=if(above(chng,cthr),rand(1)*.3,mq31);
per_frame_28=monitor=chng;
per_frame_29=q21=mq21;q22=mq22;q23=mq23;q24=mq24;q25=mq25;q26=mq26;
per_frame_30=q27=mq27;q28=mq28;q29=mq29;q31=mq31;
per_frame_31=
per_frame_32=monitor=mq1;
per_frame_33=vol=bass+treb+mid;
per_frame_34=atime=atime+vol;
per_frame_35=q1=.4+sin(atime*.006        )*.4;
per_frame_36=q2=.4+cos(atime*.00613828348)*.4;
per_frame_37=q3=.4+sin(atime*.00598593455)*.4;
per_frame_38=monitor=q3;
per_pixel_1=du = (x*2-1) - q1;
per_pixel_2=dv = (y*2-1) - q2;
per_pixel_3=dist = sqrt(du*du+dv*dv);
per_pixel_4=ang2 = atan2(du,dv) + time*0.15;
per_pixel_5=mult = 0.04*sin(dist*0.05);
per_pixel_6=dx = mult*sin(ang2*2-1.5)*aspectx;
per_pixel_7=dy = mult*cos(ang2*2-1.5)*aspecty;
warp_1=`// CC0: Another windows terminal shader
warp_2=`// Created this based on an old shader as a background in windows terminal
warp_3=`// Shader by mrange https://www.shadertoy.com/view/DdSGzy 
warp_4=`// Ported to MilkDrop by MilkDrop2077
warp_5=`
warp_6=`#define PI 3.141592654
warp_7=`#define TAU (2.0*PI)
warp_8=`
warp_9=`// Rotate matrix helper
warp_10=`float2x2 ROT(float a) {
warp_11=`    float c = cos(a*3);
warp_12=`    float s = sin(a*3);
warp_13=`    return float2x2(c, s, -s, c);
warp_14=`}
warp_15=`
warp_16=`// HSV to RGB conversion
warp_17=`float3 hsv2rgb(float3 c) {
warp_18=`    const float4 K = float4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
warp_19=`    float3 p = abs(frac(c.xxx + K.xyz) * 6.0 - K.www);
warp_20=`    return c.z * lerp(K.xxx, saturate(p - K.xxx), c.y);
warp_21=`}
warp_22=`
warp_23=`// Tonemapping approximation
warp_24=`float3 aces_approx(float3 v) {
warp_25=`    v = max(v, 0.0);
warp_26=`    v *= 0.6;
warp_27=`    float a = 2.51;
warp_28=`    float b = 0.03;
warp_29=`    float c = 2.43;
warp_30=`    float d = 0.59;
warp_31=`    float e = 0.14;
warp_32=`    return saturate((v*(a*v+b))/(v*(c*v+d)+e));
warp_33=`}
warp_34=`
warp_35=`// Fractal distance function
warp_36=`float apolloian(float3 p, float s) {
warp_37=`    float scale = 1.0;
warp_38=`    for(int i = 0; i < 5; i++) {
warp_39=`        p = -1.0 + 2.0*frac(0.5*p+0.5);
warp_40=`        float r2 = dot(p,p);
warp_41=`        float k = s/r2;
warp_42=`        p *= k;
warp_43=`        scale *= k;
warp_44=`    }
warp_45=`    
warp_46=`    float3 ap = abs(p/scale);  
warp_47=`    float d = length(ap.xy);
warp_48=`    d = min(d, ap.z);
warp_49=`
warp_50=`    return d;
warp_51=`}
warp_52=`
warp_53=`// Distance field calculation
warp_54=`float df(float2 p) {
warp_55=`    float fz = lerp(0.75, 1.0, smoothstep(-0.9, 0.9, cos(TAU*time/300.0)));
warp_56=`    float z = 1.55*fz;
warp_57=`    p /= z;
warp_58=`    float3 p3 = float3(p, 0.1);
warp_59=`    
warp_60=`    // Apply rotations
warp_61=`    float2x2 rot0 = ROT(0.1*time);
warp_62=`    float2x2 rot1 = ROT(0.123*time);
warp_63=`    p3.xz = mul(rot0, p3.xz);
warp_64=`    p3.yz = mul(rot1, p3.yz);
warp_65=`    
warp_66=`    float d = apolloian(p3, 1.0/fz);
warp_67=`    d *= z;
warp_68=`    return d;
warp_69=`}
warp_70=`
warp_71=`// Main effect
warp_72=`float3 effect(float2 p, float2 pp) {
warp_73=`    float aa = 2.0/aspect.y;
warp_74=`    float d = df(p);
warp_75=`    
warp_76=`    float3 bcol0 = hsv2rgb(float3(0.55, 0.85, 0.85));
warp_77=`    float3 bcol1 = hsv2rgb(float3(0.33, 0.85, 0.025));
warp_78=`    
warp_79=`    float3 col = 0.1*bcol0;
warp_80=`    col += bcol1/sqrt(abs(d));
warp_81=`    col += bcol0*smoothstep(aa, -aa, (d-0.001));
warp_82=`    
warp_83=`    col *= smoothstep(1.5, 0.5, length(pp));
warp_84=`    
warp_85=`    return col;
warp_86=`}
warp_87=`
warp_88=`shader_body {
warp_89=` float aspect = aspect.x / aspect.y;
warp_90=`
warp_91=`    float2 q = uv;
warp_92=`    float2 p = -1.0 + 2.0 * q;
warp_93=`    float2 pp = p;
warp_94=`    p.x *= aspect.x;
warp_95=`    
warp_96=`    float3 col = effect(p, pp);
warp_97=`    col = aces_approx(col);
warp_98=`    col = sqrt(col);
warp_99=`    
warp_100=`    ret = float4(col, 1.0);
warp_101=`}
comp_1=`shader_body
comp_2=`{
comp_3=`    float2 uv_echo = (uv - 0.5)*0.6*float2(1,-1) + 0.5;
comp_4=`    ret = lerp( tex2D(sampler_main, uv).xyz, 
comp_5=`                tex2D(sampler_main, uv_echo).xyz, 
comp_6=`                0.50 
comp_7=`              ); //video echo
comp_8=`    ret *= 1.46; //gamma
comp_9=`    ret *= hue_shader; //old hue shader effect
comp_10=`    ret = sqrt(ret); //brighten
comp_11=`    ret *= ret; //darken
comp_12=`//MilkDrop3 Blow Mode:
comp_13=`float3 avg_col = GetBlur2(uv);ret = abs(avg_col - ret)*2;
comp_14=`//MilkDrop3 Color Mode:
comp_15=`ret /= float3(0.8,2.1,1.1);
comp_16=`}
