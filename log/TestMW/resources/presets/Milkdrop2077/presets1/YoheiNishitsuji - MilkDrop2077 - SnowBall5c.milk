per_pixel_19=
per_pixel_20=
per_pixel_21=zoom=zoom+.15*x*.05*sin(rad*time*2);
per_pixel_22=zoom=zoom+.15*(1-x)*.05*sin(rad*time*2);
warp_1=`shader_body{
warp_2=`
warp_3=`//Shader from https://x.com/YoheiNishitsuji/status/1923362809569837131
warp_4=`//Ported to MilkDrop by MilkDrop2077
warp_5=`//MIT Licensed
warp_6=`
warp_7=`    float aspect = aspect.x / aspect.y;
warp_8=`    float2 u = (uv - 0.5) * float2(aspect, 1.0) * 4.0;
warp_9=`    float4 o = float4(0.0, 0.0, 0.0, 0.0);
warp_10=`    float t = time/3;
warp_11=`    float g = 0.0;
warp_12=`    
warp_13=`    for(float i = 0.0; i < 99.0; i += 1.0) {
warp_14=`        float3 p = float3(u.x, u.y, g - 6.0);
warp_15=`        float3 A = float3(0.0, 9.0, -3.0)/9.5;
warp_16=`        p.y += 1.0;
warp_17=`        
warp_18=`        // 3D rotation
warp_19=`        p = A+0 * dot(p+p, A) - p - 0.34*cross(p, A);
warp_20=`        
warp_21=`        // 2D rotation
warp_22=`        float2x2 rot = float2x2(
warp_23=`            cos(t*0.3), -sin(t*0.3),
warp_24=`            sin(t*0.3), cos(t*0.3)
warp_25=`        );
warp_26=`        p.xz = mul(p.xz, rot);
warp_27=`        
warp_28=`        float s = 6.0+q3;
warp_29=`        float e;
warp_30=`        
warp_31=`        // Fractal iteration
warp_32=`        for(int j = 0; j < 13; j++) {
warp_33=`            e = 16.0*1.1 / dot(p, p);
warp_34=`            s *= e;
warp_35=`            p = float3(0.1+q1, 4.03, -0.5) - abs(abs(p)*e - float3(3.0, 4.0, 3.0));
warp_36=`        }
warp_37=`        
warp_38=`        g += 0.3 * p.y*p.y / s;
warp_39=`        o += (log2(s) - g*0.8) / 700.0 * float4(0.9, 1.0, 1.0, 0.0);
warp_40=`    }
warp_41=`    
warp_42=`    ret = float4(tanh(o.x), tanh(o.y), tanh(o.z), 1.0);
warp_43=`}
comp_1=`shader_body
comp_2=`{
comp_3=`    ret = tex2D(sampler_main, uv).xyz;
comp_4=`    ret = 1-ret;    
comp_5=`    
comp_6=`    ret *= 1.14; //gamma
comp_7=`    ret *= ret; //darken
comp_8=`}
