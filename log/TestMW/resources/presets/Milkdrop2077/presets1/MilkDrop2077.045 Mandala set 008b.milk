shape_3_per_frame1=sample=instance/num_inst;
shape_3_per_frame2=s=sample;
shape_3_per_frame3=t=time/5;
shape_3_per_frame4=r1=4*rad;
shape_3_per_frame5=
shape_3_per_frame6=x1= r1*sin(30*sample+3*t);
shape_3_per_frame7=y1= r1*cos(30*sample+2*t);
shape_3_per_frame8=
shape_3_per_frame9=x2= y1- r1*sin(30*sample+3*t);
shape_3_per_frame10=y2= x1+ r1*cos(30*sample+2*t);
shape_3_per_frame11=
shape_3_per_frame12=x3= x2+ r1*sin(30*sample+3*t);
shape_3_per_frame13=y3= y2+ r1*cos(30*sample+2*t);
shape_3_per_frame14=
shape_3_per_frame15=
shape_3_per_frame16=x=if(above(sample,0.277), if(above(sample,0.607),x3,x2),  x1);
shape_3_per_frame17=y=if(above(sample,0.35), if(above(sample,0.719),y3,y2),  y1);
shape_3_per_frame18=
shape_3_per_frame19=
shape_3_per_frame20=rad= rad* sin(s);
shape_3_per_frame21=a=sin(200*sample);
shape_3_per_frame22=a2=a;
shape_3_per_frame23=r=a;
shape_3_per_frame24=my_x = x;
shape_3_per_frame25=my_y = y;
shape_3_per_frame26=my_z = z;
shape_3_per_frame27=
shape_3_per_frame28=
shape_3_per_frame29=
shape_3_per_frame30=
shape_3_per_frame31=/////// rotations... by flexi
shape_3_per_frame32=
shape_3_per_frame33=d = .5;
shape_3_per_frame34=zoom = .1;
shape_3_per_frame35=
shape_3_per_frame36=
shape_3_per_frame37=
shape_3_per_frame38=
shape_3_per_frame39=w3 = q1;
shape_3_per_frame40=w2 = q3;
shape_3_per_frame41=w1 = q2;
shape_3_per_frame42=
shape_3_per_frame43=x1 = cos(w1)*my_x + sin(w1)*my_y;
shape_3_per_frame44=y1 = -sin(w1)*my_x + cos(w1)*my_y;
shape_3_per_frame45=z1 = my_z;
shape_3_per_frame46=
shape_3_per_frame47=x2 = cos(w2)*x1 + sin(w2)*z1;
shape_3_per_frame48=z2 = -sin(w2)*x1 + cos(w2)*z1;
shape_3_per_frame49=y2 = y1;
shape_3_per_frame50=
shape_3_per_frame51=y3 = cos(w3)*y2 + sin(w3)*z2;
shape_3_per_frame52=z3 = -sin(w3)*y2 + cos(w3)*z2;
shape_3_per_frame53=x3 = x2;
shape_3_per_frame54=
shape_3_per_frame55=
shape_3_per_frame56=
shape_3_per_frame57=// perspective calculation
shape_3_per_frame58=
shape_3_per_frame59=l = sqrt(x3*x3 + y3*y3);
shape_3_per_frame60=w = atan2(x3,y3);
shape_3_per_frame61=p = tan(asin(1) + atan2(d+z3,l));
shape_3_per_frame62=d = sqrt(x3*x3 + y3*y3 + (z3+d)*(z3+d));
shape_3_per_frame63=
shape_3_per_frame64=my_x = zoom*sin(w)*p;
shape_3_per_frame65=my_y = zoom*cos(w)*p;
shape_3_per_frame66=
shape_3_per_frame67=x = 0.5 + my_x;
shape_3_per_frame68=y = 0.5 + my_y;
shape_3_per_frame69=
per_frame_1=wave_x = wave_x + 0.2*( 0.60*sin(2.121*time) + 0.5*sin(1.621*time) );
per_frame_2=wave_y = wave_y + 0.2*( 0.60*sin(1.742*time) + 0.5*sin(2.322*time) );
per_frame_3=wave_r = wave_r + 0.200*( 0.60*sin(0.823*time) + 0.40*sin(0.916*time) );
per_frame_4=wave_g = wave_g + 0.500*( 0.60*sin(0.900*time) + 0.40*sin(1.023*time) );
per_frame_5=wave_b = wave_b + 0.500*( 0.60*sin(0.808*time) + 0.40*sin(0.949*time) );
per_pixel_1=zoom = zoom + 0.02 * ( sin(3*cos(1*(sqrt(1)-rad)*ang)) + 0.0 );
per_pixel_2=//cx = if(above(rad,0.3),0.5,0.3);
per_pixel_3=rot = 0.005;
warp_1=`shader_body
warp_2=`{
warp_3=`uv = lerp(uv_orig,uv,0.3);
warp_4=`
warp_5=`float2 d = texsize.zw * 3;
warp_6=`float3 dx = ( GetBlur1(uv + float2(1,0)*d) - GetBlur1(uv-float2(1,0)*d) );
warp_7=`float3 dy = ( GetBlur1(uv + float2(0,1)*d) - GetBlur1(uv-float2(0,1)*d) );
warp_8=`
warp_9=`uv += float2(lum(dx),lum(dy))*texsize.zw*9;
warp_10=`ret = tex2d(sampler_fc_main, uv) - 0.01;
warp_11=`
warp_12=`}
comp_1=`// (MWmod) sampler sampler_rand00;
comp_2=`float cross, noise, z, mask, scale;
comp_3=`float2 rs, rs0, uv1, uv2, uv3, uv4, uvt;
comp_4=`float3 ret1,ret2,struc,flash2;
comp_5=`
comp_6=`float3 Get1 (float2 uvi){return GetPixel (uvi);}
comp_7=`
comp_8=`shader_body {
comp_9=`
comp_10=`float2 uv2 = uv;
comp_11=`if(uv2.x >= 0.5) {uv2.x = 1-uv2.x;}
comp_12=`if(uv2.y >= 0.5) {uv2.y = 1-uv2.y;}
comp_13=`
comp_14=`//float1 cs = cos(0.25*3.14159);
comp_15=`//float1 sn = sin(0.25*3.14159);
comp_16=`//float2 uv3 = uv2;
comp_17=`//uv2.x = uv3.x * cs - uv3.y * sn;
comp_18=`//uv2.y = uv3.x * sn + uv3.y * cs;
comp_19=`
comp_20=`uv.x=uv2.x;
comp_21=`uv.y=uv2.y;
comp_22=`
comp_23=`float iter = 4+10*saturate (texsize.x/1024*uv.y);
comp_24=`ret = Get1(uv); ret1 = ret; ret2 = ret;
comp_25=`for (int n =1; n < 10; n++) {
comp_26=`  ret1 = max(ret1,Get1(uv+texsize.zw*float2(n,0)));
comp_27=`//  ret2 = max(ret2,Get1(uv+texsize.zw*float2(0,n)));
comp_28=`}
comp_29=`struc = ret1;
comp_30=`mask = saturate(1-16*lum(struc));
comp_31=`struc *= .07/(length(rad/3-length((ret1+ret2*0.1))+0.6));
comp_32=`
comp_33=`//BACK
comp_34=`//uv4 = (uv-0.5) * (1+0*exp(-pow ((uv.x-0.5)*3-2*q14,2)))+0.5;
comp_35=`
comp_36=`
comp_37=`//noise = (tex2D(sampler_noise_lq,2*uv4).r+0.25);
comp_38=`//noise *= 1-tex2D(sampler_noise_lq,2*uv4+texsize.zw*-4).r;
comp_39=`//(MWmod) noise *= (0.5+ 0.5*(lum(tex2D(sampler_rand00,uv)) > 0.5))*2;
comp_40=`//ret = 0.05+noise*0.5*(1-rad);  // texLum (orig *0.5)
comp_41=`
comp_42=`//ret *= saturate(1-lum(GetBlur2(uv4-0.13))*8);
comp_43=`ret = lerp (ret,struc, !mask);
comp_44=`
comp_45=`//NEW FLASH
comp_46=`
comp_47=`//ret = GetPixel(uv);
comp_48=`//ret *= 1.4;  // gamma  (orig 1.4  und  deakt)
comp_49=`//ret /= float3(1.8,-0.8,2.8);
comp_50=`}

