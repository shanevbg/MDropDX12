comp_27=`ret /= float3(-2.7,1.8,2.8);
comp_28=`//MilkDrop3 Burn Mode:
comp_29=`ret = lerp(ret,2,GetPixel(uv).z*1.16);
comp_30=`//MilkDrop3 Invert Mode:
comp_31=`ret = 1 - ret;
comp_32=`}

