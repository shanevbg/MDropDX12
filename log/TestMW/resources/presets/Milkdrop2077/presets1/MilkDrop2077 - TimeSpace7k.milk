shape_9_per_frame8=//b = abs(treb_att/5-bass);
shape_9_per_frame9=size = 0.3+bass_att/300;
shape_9_per_frame10=
shape_9_per_frame11=nc = sqrt(num_inst);
shape_9_per_frame12=xs=sin(7.662*(instance%nc)/nc)*sin(3.705*int(instance/nc)/nc);
shape_9_per_frame13=ys=cos(6.28*(instance%nc)/nc)*sin(3.14*int(instance/nc)/nc);
shape_9_per_frame14=zs=cos(3.14*int(instance/nc)/nc);
shape_9_per_frame15=
shape_9_per_frame16=//modulate to allow rotation
shape_9_per_frame17=y1 = ys*cos(q1)-zs*sin(q1);
shape_9_per_frame18=z1 = ys*sin(q1)+zs*cos(q1);
shape_9_per_frame19=x1 = z1*sin(q2)+xs*cos(q2);
shape_9_per_frame20=z2 = z1*cos(q2)-xs*sin(q2);
shape_9_per_frame21=x2 = x1*cos(q3)-y1*sin(q3);
shape_9_per_frame22=y2 = y1*cos(q3)+x1*sin(q3);
shape_9_per_frame23=
shape_9_per_frame24=//translate shape
shape_9_per_frame25=x3 = x2+q4;
shape_9_per_frame26=y3 = y2*3;
shape_9_per_frame27=z3 = z2+q5;
shape_9_per_frame28=
shape_9_per_frame29=x = 0.5 + size*(x3/(1+z3*size));
shape_9_per_frame30=y = 0.42 + size*(y3/(1+z3*size));
shape_9_per_frame31=a=below(z3,0);
