wave_0_per_point1=i=t1;
wave_0_per_point2=speed=.06;
wave_0_per_point3=
wave_0_per_point4=z=megabuf(3*i+2);
wave_0_per_point5=x = megabuf(3*i)/z+.5;
wave_0_per_point6=y = megabuf(3*i+1)/z*reg32+0.5;
wave_0_per_point7=
wave_0_per_point8=out=(x>1)||(x<0)||(y>1)||(y<0)||(z<0);
wave_0_per_point9=if (out,
wave_0_per_point10=  megabuf(3*i)= (rand(2)-1)/8; //x
wave_0_per_point11=  megabuf(3*i+1)=(rand(2)-1)/8; //y
wave_0_per_point12=  megabuf(3*i+2)=rand(1);
wave_0_per_point13=,
wave_0_per_point14=  megabuf(i*3+2)-=speed/50;
wave_0_per_point15=);
wave_0_per_point16=
wave_0_per_point17=a=(1-pow(z,1))/2;
wave_0_per_point18=t1+=1;
shapecode_0_enabled=1
shapecode_0_sides=20
shapecode_0_additive=0
shapecode_0_thickOutline=0
shapecode_0_textured=0
shapecode_0_num_inst=1024
shapecode_0_x=0.500
shapecode_0_y=0.500
shapecode_0_rad=0.15806
shapecode_0_ang=0.00000
shapecode_0_tex_ang=0.00000
shapecode_0_tex_zoom=1.00000
shapecode_0_r=0.000
shapecode_0_g=0.500
shapecode_0_b=0.000
shapecode_0_a=1.000
shapecode_0_r2=0.000
shapecode_0_g2=0.500
shapecode_0_b2=0.490
shapecode_0_a2=0.500
shapecode_0_border_r=0.000
shapecode_0_border_g=1.000
shapecode_0_border_b=1.000
shapecode_0_border_a=0.530
shape_0_per_frame1=sample=instance/num_inst;
shape_0_per_frame2=
shape_0_per_frame3=///// Sphere
shape_0_per_frame4=r1=1;
shape_0_per_frame5=q10= -1+2*sample;
shape_0_per_frame6=q11=200*sample;
shape_0_per_frame7=
shape_0_per_frame8=my_x = sqrt(r1*r1-q10*q10)*cos(q11);
shape_0_per_frame9=my_y = sqrt(r1*r1-q10*q10)*sin(q11);
shape_0_per_frame10=my_z = q10+3*sin(2*q1+time)*sin(.5*sample)*my_x*my_y;
shape_0_per_frame11=
shape_0_per_frame12=
shape_0_per_frame13=///// drago
shape_0_per_frame14=t1 = 10*sample+time*.1;
shape_0_per_frame15=x1 = .5*(.6*sin (7*t1)+.4*sin (4.3*t1)) ;
shape_0_per_frame16=y1 = .5*(.6*cos (3.3*t1)+.4*cos (6.9*t1))* sin (-100+200*sample) ;
shape_0_per_frame17=z1 = .5*(.6*cos (4.1*t1)+.4*cos (6.9*t1)) * cos (-50+100*sample) ;
shape_0_per_frame18=
shape_0_per_frame19=
shape_0_per_frame20=my_x = if(above(sample,.45)*below(sample,.55),x1,my_x);
shape_0_per_frame21=my_y = if(above(sample,.45)*below(sample,.55),y1,my_y);
shape_0_per_frame22=my_z = if(above(sample,.45)*below(sample,.55),z1,my_z);
shape_0_per_frame23= 
shape_0_per_frame24=
shape_0_per_frame25=/////// rotations... by flexi
shape_0_per_frame26=
shape_0_per_frame27=d = 2.5; 
shape_0_per_frame28=zoom = 1;
shape_0_per_frame29=
shape_0_per_frame30=w3 = .6*sin(q1);
shape_0_per_frame31=w2 = .6*sin(q3);
shape_0_per_frame32=w1 = q2;
shape_0_per_frame33=
shape_0_per_frame34=x1 = cos(w1)*my_x + sin(w1)*my_y;
shape_0_per_frame35=y1 = -sin(w1)*my_x + cos(w1)*my_y;
shape_0_per_frame36=z1 = my_z;
shape_0_per_frame37=
shape_0_per_frame38=x2 = cos(w2)*x1 + sin(w2)*z1;
shape_0_per_frame39=z2 = -sin(w2)*x1 + cos(w2)*z1;
shape_0_per_frame40=y2 = y1;
shape_0_per_frame41=
shape_0_per_frame42=y3 = cos(w3)*y2 + sin(w3)*z2;
shape_0_per_frame43=z3 = -sin(w3)*y2 + cos(w3)*z2;
shape_0_per_frame44=x3 = x2;
shape_0_per_frame45=
shape_0_per_frame46=// perspective calculation
shape_0_per_frame47=
shape_0_per_frame48=l = sqrt(x3*x3 + y3*y3);
shape_0_per_frame49=w = atan2(x3,y3)+sin(time/3);
shape_0_per_frame50=p = tan(asin(1) + atan2(d+z3,l));
shape_0_per_frame51=d = sqrt(x3*x3 + y3*y3 + (z3+d)*(z3+d));
shape_0_per_frame52=
shape_0_per_frame53=my_x = zoom*sin(w)*p;
shape_0_per_frame54=my_y = zoom*cos(w)*p;
shape_0_per_frame55=
shape_0_per_frame56=x = 0.5 + my_x/q6;
shape_0_per_frame57=y = 0.5 + my_y/q5;
shape_0_per_frame58=
shape_0_per_frame59=
shape_0_per_frame60=////////// sphere
shape_0_per_frame61=rad=rad/d;
shape_0_per_frame62=b=sin(3.14*sample+.3*time);
shape_0_per_frame63=r=.9*b;
shape_0_per_frame64=g=.9*b;
shape_0_per_frame65=b2=.9*b;
shape_0_per_frame66=r2=.9*b2;
shape_0_per_frame67=g2=.9*b2;
shape_0_per_frame68=border_r=r;
shape_0_per_frame69=border_g=g;
shape_0_per_frame70=border_b=b;
shape_0_per_frame71=
shape_0_per_frame72=
shape_0_per_frame73=////// drago
shape_0_per_frame74=
shape_0_per_frame75=rad= if(above(sample,.45)*below(sample,.55), .02*rad+12*rad*(sample-.45), rad);
shape_0_per_frame76=ang= if(above(sample,.45)*below(sample,.55), 300*(sample-.55)*time,0);
shape_0_per_frame77=sides= if(above(sample,.45)*below(sample,.55), 14*(1-10*(sample-.45)),20);
shape_0_per_frame78=
shape_0_per_frame79=r= if(above(sample,.45)*below(sample,.55),sample,r);
shape_0_per_frame80=g= if(above(sample,.45)*below(sample,.55),sample,g);
shape_0_per_frame81=b= if(above(sample,.45)*below(sample,.55),sample,b);
shape_0_per_frame82=r2= if(above(sample,.45)*below(sample,.55),.1,r2);
shape_0_per_frame83=g2= if(above(sample,.45)*below(sample,.55),.1,g2);
shape_0_per_frame84=b2= if(above(sample,.45)*below(sample,.55),.1,b2);
shape_0_per_frame85=
shape_0_per_frame86=a2= if(above(sample,.45)*below(sample,.55),.6,a2);
shape_0_per_frame87=border_a= if(above(sample,.45)*below(sample,.55),0,.5);
per_frame_1=decay=.6;
per_frame_2=
per_frame_3=q5=aspectx;
per_frame_4=q6=aspecty;
per_frame_5=
per_frame_6=t10=t10+2/fps;
per_frame_7=t10=t10*above(50,t10);
per_frame_8=q10=t10;
per_frame_9=
per_frame_10=//// flexi's beat counter
per_frame_11=bt1 = bt1*0.95 + sqr(bass*4)*30/fps;
per_frame_12=mt1 = mt1*0.95 + sqr(mid*4)*30/fps;
per_frame_13=bt2 = bt2 + bt1*0.005;
per_frame_14=mt2 = mt2 + mt1*0.005;
per_frame_15=q1 = mt2 *0.01;
per_frame_16=q2 = bt2 *0.03;
per_frame_17=
per_frame_18=rot=.01*q1;
per_frame_19=dx=-.01*q2;
per_frame_20=dy=-.02*(q1+q2);
warp_1=`#define tex sampler_spirale3
warp_2=`sampler tex;
warp_3=`
warp_4=`shader_body
warp_5=`{
warp_6=`
warp_7=`float2 xy1=0;
warp_8=`float2 xymod=uv-.5;
warp_9=`
warp_10=`xy1.x=sin(time/13)*xymod.x-cos(time/13)*xymod.y/3;
warp_11=`xy1.y=cos(time/13)*xymod.x+sin(time/13)*xymod.y;
warp_12=`
warp_13=`uv=xy1+aspect.xy;
warp_14=`
warp_15=`ret = tex2D(tex, uv ).xyz;
warp_16=`
warp_17=`}
comp_1=`float a,b,c;
comp_2=`shader_body
comp_3=`{
comp_4=`float2 uv2 = uv;
comp_5=`if(uv2.x >= 0.5) {uv2.x = 1-uv2.x;}
comp_6=`if(uv2.y >= 0.5) {uv2.y = 1-uv2.y;}
comp_7=`
comp_8=`//float1 cs = cos(0.25*3.14159);
comp_9=`//float1 sn = sin(0.278*3.424333);
comp_10=`//float2 uv3 = uv2;
comp_11=`//uv2.x = uv3.x * cs - uv3.y * sn;
comp_12=`//uv2.y = uv3.x * sn + uv3.y * cs;
comp_13=`
comp_14=`uv.x=uv2.x;
comp_15=`uv.y=uv2.y;
comp_16=`
comp_17=`
comp_18=`float3 base = GetBlur3(uv) + GetBlur2(uv) + GetBlur1(uv) + tex2D(sampler_main, uv)*0.886 - 0.466 ;
comp_19=`a =base.x/12;b = base.y/8; c = base.x/3;
comp_20=`c = c + b + a-b;
comp_21=`a = a + c + a*c;
comp_22=`base = 0.2+c;
comp_23=`ret = base*(0.552-base)*(1-base)*2*float3(0.55,1.688,2.25) + pow(base,2)*float3(2.29,1.688,1.74); //MilkDrop2077 color mod
comp_24=`//ret.xy = ret.yx;
comp_25=`ret = ret*(1-ret)*3; //MilkDrop2077 solarize effect
comp_26=`//MilkDrop3 Color Mode:
comp_27=`ret /= float3(1.7,1.7,2.9);
comp_28=`//MilkDrop3 Burn Mode:
comp_29=`ret = lerp(ret,2,GetPixel(uv).z*1.16);
comp_30=`//MilkDrop3 Invert Mode:
comp_31=`ret = 1 - ret;
comp_32=`}

