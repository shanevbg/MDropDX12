per_frame_init_1=
per_frame_init_2=n=50;  loop(n,  sample=i/n;
per_frame_init_3=
per_frame_init_4=gmegabuf(6*i)   = -1+rand(3); 
per_frame_init_5=gmegabuf(6*i+1) = -1+rand(3); 
per_frame_init_6=
per_frame_init_7=i=i+1;);
per_frame_1=
per_frame_2=////////////////////////  BOIDS
per_frame_3=i1=0;                   
per_frame_4=
per_frame_5=q2=.5+.5*(.6*sin(.62*time)+.4*sin(.45*time));
per_frame_6=q3=.5+.5*(.6*sin(.42*time)+.4*sin(.81*time));           /// leader path
per_frame_7=
per_frame_8=loop(n, 
per_frame_9=
per_frame_10=x1=gmegabuf(6*i1);      y1=gmegabuf(6*i1+1);    vx1=gmegabuf(6*i1+2);
per_frame_11=vy1=gmegabuf(6*i1+3);   vx2=gmegabuf(6*i1+4);   vy2=gmegabuf(6*i1+5);
per_frame_12=
per_frame_13=x1 = x1 + 20*vx1/fps;
per_frame_14=y1 = y1 + 20*vy1/fps;                       
per_frame_15=vx1 = vx2 + (cex/n-x1)/150 + (q2-x1)/50 + 0*(vx/n-vx1)/2;
per_frame_16=vy1 = vy2 + (cey/n-y1)/150 + (q3-y1)/50 + 0*(vy/n-vy1)/2;
per_frame_17=
per_frame_18=i2=0;     vx2=0;     vy2=0;   r=0;   
per_frame_19=
per_frame_20=loop(n, 
per_frame_21=
per_frame_22=x2=gmegabuf(6*i2);      y2=gmegabuf(6*i2+1);                 
per_frame_23=
per_frame_24=d=sqrt(sqr(x2-x1)+sqr(y2-y1));            /// keeping boids apart
per_frame_25=d1=below(d,.05+.1*(.1*time)%2);
per_frame_26=vx2=vx2-.02*if(d1,x2-x1,0);
per_frame_27=vy2=vy2-.02*if(d1,y2-y1,0);
per_frame_28=
per_frame_29=gmegabuf(6*i2+4)=vx2;   gmegabuf(6*i2+5)=vy2;
per_frame_30=i2=i2+1; );
per_frame_31=gmegabuf(6*i1)=x1;      gmegabuf(6*i1+1)=y1;    gmegabuf(6*i1+2)=vx1;   gmegabuf(6*i1+3)=vy1;
per_frame_32=i1=i1+1; );
per_frame_33=
per_frame_34=
per_frame_35=cex=0;    cey=0;    vx=0;    vy=0;    i=0;      
per_frame_36=
per_frame_37=loop (n,
per_frame_38=
per_frame_39=cex=cex + gmegabuf(6*i);
per_frame_40=cey=cey + gmegabuf(6*i+1);             //// boids center
per_frame_41=vx=vx + gmegabuf(6*i+2);     
per_frame_42=vy=vy + gmegabuf(6*i+3);             //// boids medium velocity
per_frame_43=
per_frame_44=i=i+1; );
per_frame_45=
per_frame_46=q1=n;
per_frame_47=
per_frame_48=
per_frame_49=
per_frame_50=//////////
per_frame_51=
per_frame_52=wave_a=0;
per_frame_53=decay=.6;
per_frame_54=
per_frame_55=
per_frame_56=rot=.004*( cex+cey);     
per_frame_57=dx=.2*cex; 
per_frame_58=dy=.2*cey; 
per_frame_59=
per_frame_60=q10=cex+cey; 
per_frame_61=q6 = aspecty;
warp_1=`shader_body
warp_2=`{ret=GetPixel(uv);
warp_3=`float2 mo=uv-uv_orig;
warp_4=`ret=GetPixel(uv_orig+mo*lum(ret));
warp_5=`ret=ret*0.99-0.002;
warp_6=`}
comp_1=`float a,b,c;
comp_2=`shader_body
comp_3=`{
comp_4=`    float3 base = GetBlur3(uv) + GetBlur2(uv) + GetBlur1(uv) + tex2D(sampler_main, uv)*0.77 - 0.48 ;
comp_5=`a =base.x/12;b = base.y/8; c = base.x/3;
comp_6=`c = c + b + a-b;
comp_7=`a = a + c + a*c;
comp_8=`base = 0.2+c;
comp_9=`ret = base*(.8-base)*(1-base)*2*float3(0.7,2.5,2.3) + pow(base,2)*float3(2.9,2.5,1.3); //MilkDrop2077 color mod
comp_10=`//ret.xy = ret.yx;
comp_11=`//MilkDrop3 Burn Mode:
comp_12=`ret = lerp(ret,2,GetPixel(uv).z*1.36);
comp_13=`}

