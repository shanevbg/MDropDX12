warp_1=`shader_body
warp_2=`{
warp_3=`uv = lerp(uv_orig,uv,0.3);
warp_4=`
warp_5=`float2 d = texsize.zw * 3;
warp_6=`float3 dx = ( GetBlur1(uv + float2(1,0)*d) - GetBlur1(uv-float2(1,0)*d) );
warp_7=`float3 dy = ( GetBlur1(uv + float2(0,1)*d) - GetBlur1(uv-float2(0,1)*d) );
warp_8=`
warp_9=`uv += float2(lum(dx),lum(dy))*texsize.zw*9;
warp_10=`ret = tex2d(sampler_fc_main, uv) - 0.01;
warp_11=`
warp_12=`}
comp_1=`static float2 hor = float2 (texsize.z,0);
comp_2=`static float2 ver = float2 (0, texsize.w);
comp_3=`static float2x2 rot45 = float2x2(0.7,0.7,-0.7,0.7);
comp_4=`float2 rs, rs0, uv2, uv3,uv4,dz;
comp_5=`float3 noise, ret1, neu;
comp_6=`#define GP GetPixel
comp_7=`
comp_8=`shader_body {
comp_9=`static float2 center = float2(.5,.2+rand_preset.x*0.4);
comp_10=`float2 uv1 = (uv-center );
comp_11=`
comp_12=`ret1 = 0;
comp_13=`int anz = 3;
comp_14=`int n = 0;
comp_15=`dz=0;
comp_16=`while (n < anz) {
comp_17=`  float dist = 1-frac(1.0/anz*n); //evtl sqrt !;
comp_18=`  float inten =  saturate(1-dist);
comp_19=`  uv3 = .5*anz*uv1*dist + center;
comp_20=`  float mask = (uv3.x>0) && (uv3.x<1) &&  (uv3.y>0) && (uv3.y<1);
comp_21=`  mask = max(0.5,mask);
comp_22=`  dz.x += inten*(lum(GP(uv3+hor))- lum(GP (uv3-hor)));
comp_23=`  dz.y += inten*(lum(GP(uv3+ver))- lum(GP (uv3-ver)));
comp_24=`  dz *= length(dz)>length(texsize.zw)*8;
comp_25=`  neu = max(GP(uv3+dz*0.1*inten),GetBlur3(uv3)*.50*rand_preset.y);
comp_26=`  ret1 = max(ret1,neu*inten*mask);
comp_27=`n++;
comp_28=`}
comp_29=`
comp_30=`uv1= mul(uv1,rot45);
comp_31=`dz = mul(dz ,rot45);
comp_32=`float2 uv6 = sin(10*uv1+dz*12 + time*.2);
comp_33=`float3 mus = .06/length(uv6) * (1+length(dz)*length(texsize.xy)*0.012*(0.25+2*GetBlur1(frac(1-2*uv))));
comp_34=`
comp_35=`ret = sqrt(ret1)*(.1+rand_preset.z*0.4+8*mus*saturate(1-rad));
comp_36=`ret = 1-exp(-ret*1.2);
comp_37=`//ret = GetPixel(uv0);
comp_38=`//MilkDrop3 Solarize Mode:
comp_39=`ret = ret*(1-ret)*4;
comp_40=`}
[PRESET1_END]

