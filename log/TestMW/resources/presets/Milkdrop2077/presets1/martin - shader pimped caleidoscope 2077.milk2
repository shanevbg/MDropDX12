per_frame_40=//Beste raussuchen
per_frame_41=sig = 0; quali = 0; bestsig = -1;
per_frame_42=loop (num_sig,
per_frame_43=  m = sig*blocksize+num_res*12; // Start Infoblock;
per_frame_44=  tmp = gmegabuf(m+3)/gmegabuf(m+2) ;
per_frame_45=  if (tmp > quali, quali = tmp; bestsig = sig;, 0);
per_frame_46=sig += 1);
per_frame_47=
per_frame_48=index = 0; maxind1 = 0; maxv *= dec_s;
per_frame_49=loop (num_res, 
per_frame_50=  n = bestsig*blocksize+index*12; // Start Infoblock;
per_frame_51=  tmpv = gmegabuf(n+3);
per_frame_52=  if (tmpv > maxv, maxv=tmpv; maxind1=index, 0);
per_frame_53=index += 1;);
per_frame_54=
per_frame_55=BPM   = minbpm * pow(maxbpm/minbpm,maxind1/num_res);
per_frame_56=if (BMP < 150, trel1 += BPM/60*dt, trel1 +=BPM/120*dt);
per_frame_57=q10 = trel1;
per_frame_58=
per_frame_59=//Vol delay chain 
per_frame_60=vol = (bass+mid+treb);
per_frame_61=vol_=vol_*0.9 + 0.1*vol;
per_frame_62=tvol = tvol*0.7 + 0.3*(vol-vol_);
per_frame_63=n = 50100; loop (100, gmegabuf (n) = gmegabuf (n-1); n -= 1; ); gmegabuf (50000) = atan(tvol);
per_frame_64=monitor = BPM;
per_frame_65=q6 = gmegabuf(50000);
per_frame_66=q7 = sqrt(max(0,vol_-0.3));
per_frame_67=
per_frame_68=tr1 += vol*dt;
per_frame_69=q8 = tr1;
per_pixel_1=warp = .0; rot = .0;
per_pixel_2=scale = 0.2;
per_pixel_3=
per_pixel_4=x0 = .5+scale*pow(gmegabuf(50000),1); y0 = .5+scale*pow(gmegabuf(50020),1);
per_pixel_5=
per_pixel_6=tt = sqrt (pow(x-x0,2) + pow(y-y0,2));
per_pixel_7=
per_pixel_8=zoom = 1+tt*0.2;
per_pixel_9=
per_pixel_10=zoom = 0.99+ 0.1*(0.4+pow(gmegabuf(50000+rad*20),1));
per_pixel_11=zoom -= 0.03*((sin(ang*3)<0)-0.5);
per_pixel_12=
per_pixel_13=
warp_1=`float3 Get1 (float2 uvi)
warp_2=`{return (GetPixel(uvi)+GetPixel(uvi+texsize.zw)+GetPixel(uvi-texsize.zw)
warp_3=`+GetPixel(uvi+texsize.zw*float2(1,0)) +GetPixel(uvi+texsize.zw*float2(-1,0)) 
warp_4=`+GetPixel(uvi+texsize.zw*float2(0,1)) +GetPixel(uvi+texsize.zw*float2(0,-1)))/7;}
warp_5=`
warp_6=`
warp_7=`shader_body
warp_8=`{
warp_9=`float2 dither_uv = uv_orig*texsize.xy*texsize_noise_lq.zw * 0.4 + rand_frame.xy;
warp_10=`float2 udith = tex2D(sampler_noise_lq,uv*8+rand_frame)-0.5;
warp_11=`ret= tex2D( sampler_main, uv + udith*0.00).xyz;
warp_12=`
warp_13=`ret += (ret.xyz - GetBlur1(uv_orig+0.0*bass))*0.35;
warp_14=`ret *= 0.9;
warp_15=`ret += (tex2D(sampler_noise_lq, dither_uv).xyz-0.1).r*0.02 * saturate(1-treb_att);
warp_16=`
warp_17=`ret = lerp(ret.xyz, lum(ret.xyz), 0.1)*(0.95-0.05*lum(GetBlur3(uv)));
warp_18=`}
comp_1=`static const int anz = 3;
comp_2=`float3 ret1, neu, blur;
comp_3=`float2 uv3;
comp_4=`shader_body
comp_5=`{
comp_6=`float2 pos = float2 (sin(q10*3.14), cos(q10*3.14+q8*.04));
comp_7=`float r1 = frac(q10/2+time*0.2);
comp_8=`float r2 = frac(q10/4);
comp_9=`float2 uv2;
comp_10=`float ang2, c, s;
comp_11=`uv -= .5;
comp_12=`uv *= aspect.xy;    
comp_13=`ret1 = (roam_sin+0.5)/(0.01+length((uv)*r1-pos*0.07*q7))*0.015*q7;
comp_14=`ret1 += (roam_sin+0.5).bgr/(0.01+length((uv)*r1+pos*0.07*q7))*0.015*q7;
comp_15=`ret1 += (roam_cos+0.5)/(0.02+8*pow(length(uv)-1*r1,2))*0.01*q7;
comp_16=`ret1*= (1+lum(ret1))/2;
comp_17=`float n = 1;
comp_18=`while (n <= anz) {
comp_19=`  ang2 = n/anz*3.1416;
comp_20=`  c = cos(ang2);
comp_21=`  s = sin(ang2);
comp_22=`  uv2.x =  uv.x*c - uv.y*s;
comp_23=`  uv2.y =  uv.x*s + uv.y*c;
comp_24=`  uv3= abs(frac(uv2*aspect.yx)-.5);
comp_25=`  neu =  max(GetPixel (uv3),GetBlur1(uv3))/2 ;
comp_26=`  ret1 = max(ret1,neu+ret1);
comp_27=`n++;
comp_28=`}
comp_29=`ret = ret1*(1-rad);
comp_30=`
comp_31=`//ret = GetPixel(uv+0.5);
comp_32=`}
[PRESET2_END]
