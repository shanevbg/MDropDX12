shape_0_per_frame1=a = above(q3,2);
shape_0_per_frame2=a2 = above(q3,2)*0.8;
shape_0_per_frame3=
shape_0_per_frame4=xx = if(above(q3,6),xx,rand(100)*0.01);
shape_0_per_frame5=yy = if(above(q3,6),yy,rand(100)*0.01);
shape_0_per_frame6=radi = if(above(q3,5),radi,rand(100)*0.01);
shape_0_per_frame7=
shape_0_per_frame8=rad = radi;
shape_0_per_frame9=
shape_0_per_frame10=x = xx;
shape_0_per_frame11=y = yy;
shape_0_per_frame12=
shape_0_per_frame13=
shape_0_per_frame14=r = 0.5 + 0.5*sin(q1*1.22) + 0.1;
shape_0_per_frame15=g = 0.4 + 0.4*sin(q1*1.307);
shape_0_per_frame16=b = 0.4 + 0.4*sin(q1*1.959);
shape_0_per_frame17=
shape_0_per_frame18=
shape_0_per_frame19=r2 = 0.5 + 0.5*sin(q1*1.622) + 0.1;
shape_0_per_frame20=g2 = 0.4 + 0.4*sin(q1*1.507);
shape_0_per_frame21=b2 = 0.4 + 0.4*sin(q1*1.6559);
warp_1=`#define SPD 1.
warp_2=`#define RYS 10.
warp_3=`#define RNG 512.
warp_4=`#define TWF 2.
warp_5=`
warp_6=`float col(float d, float a) {
warp_7=`    return pow((tan(a*RYS + pow(d*2., sin(SPD)*TWF)*0) + tan(d*RNG) + 2.)/2., 2000.);
warp_8=`}
warp_9=`
warp_10=`shader_body {
warp_11=`    float2 d = (uv - .5)*texsize.xy/texsize.y;
warp_12=`    float l = length(d), a = atan2(d.y, d.x);
warp_13=`    ret = float4(col(l, a), col(l*1.3, time+a), col(l*1.3, a), 1);
warp_14=`}
comp_1=`float a,b,c;
comp_2=`shader_body
comp_3=`{
comp_4=`float2 uv2 = uv;
comp_5=`if(uv2.x >= 0.5) {uv2.x = 1-uv2.x;}
comp_6=`if(uv2.y >= 0.5) {uv2.y = 1-uv2.y;}
comp_7=`
comp_8=`//float1 cs = cos(0.25*3.14159);
comp_9=`//float1 sn = sin(0.278*3.424333);
comp_10=`//float2 uv3 = uv2;
comp_11=`//uv2.x = uv3.x * cs - uv3.y * sn;
comp_12=`//uv2.y = uv3.x * sn + uv3.y * cs;
comp_13=`
comp_14=`uv.x=uv2.x;
comp_15=`uv.y=uv2.y;
comp_16=`
comp_17=`
comp_18=`    float3 base = GetBlur3(uv) + GetBlur2(uv) + GetBlur1(uv) + tex2D(sampler_main, uv)*0.886 - 0.466 ;
comp_19=`a =base.x/12;b = base.y/8; c = base.x/3;
comp_20=`c = c + b + a-b;
comp_21=`a = a + c + a*c;
comp_22=`base = 0.2+c;
comp_23=`ret = base*(0.552-base)*(1-base)*2*float3(0.55,1.688,2.25) + pow(base,2)*float3(2.29,1.688,1.74); //MilkDrop2077 color mod
comp_24=`//ret.xy = ret.yx;
comp_25=`ret = ret*(1-ret)*4; //MilkDrop2077 solarize effect
comp_26=`//MilkDrop3 Color Mode:
comp_27=`ret /= float3(2.4,2.3,1.6);
comp_28=`ret *= 1.2;
comp_29=`//MilkDrop3 Shadows Mode:
comp_30=`ret += pow(tex2D(sampler_main,float2(uv.x,1-uv.y)).yyy+tex2D(sampler_main,1-uv).yyy,float3(1,2,3));
comp_31=`//MilkDrop3 Burn Mode:
comp_32=`ret = lerp(ret,2,GetPixel(uv).z*1.36);
comp_33=`}

