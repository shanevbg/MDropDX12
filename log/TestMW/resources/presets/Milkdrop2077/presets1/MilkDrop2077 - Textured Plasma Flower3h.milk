warp_1=`#define N 5.0
warp_2=`#define S 0.5
warp_3=`#define B 0.05
warp_4=`#define M 0.0
warp_5=`
warp_6=`#define img sampler_Pattern_005
warp_7=`sampler img;
warp_8=`
warp_9=`shader_body
warp_10=`{
warp_11=`    float2 q = (uv - 0.5) * float2(aspect.x / aspect.y, 1);
warp_12=`    float w = time * S;
warp_13=`    float3 c = 0;
warp_14=`    float2 h = float2(atan2(q.x + sin(w * M) * 0.5, q.y), length(q * 3.5));
warp_15=`    h.y += cos(h.x * N - w) * 0.3;
warp_16=`    h.x += sin(h.y * 2 - w) * 0.3;
warp_17=`    q = abs(frac(cos(h.x) * h.y * float2(1, sin(h.x))) - 0.5);
warp_18=`    float d = length(q);
warp_19=`    float2 e = float2(0.008, 0);
warp_20=`    float2 g = float2(atan2(q.x - e.x + sin(w * M) * 0.5, q.y), length((q - e) * 3.5));
warp_21=`    g.y += cos(g.x * N - w) * 0.3;
warp_22=`    g.x += sin(g.y * 2 - w) * 0.3;
warp_23=`    float a = length(abs(frac(cos(g.x) * g.y * float2(1, sin(g.x))) - 0.5));
warp_24=`    float2 f = float2(atan2(q.x, q.y - e.x), length((q - e.yx) * 3.5));
warp_25=`    f.y += cos(f.x * N - w) * 0.3;
warp_26=`    f.x += sin(f.y * 2 - w) * 0.3;
warp_27=`    float b = length(abs(frac(cos(f.x) * f.y * float2(1, sin(f.x))) - 0.5));
warp_28=`    float3 m = normalize(float3(bass_att, treb_att * 2, -1) + float3((a - d) / e.x, (b - d) / e.x, -1) * B);
warp_29=`    float3 l = float3(cos(time) * 0.1, sin(time) * 0.2, -1);
warp_30=`    float3 k = l - float3(q, 0);
warp_31=`    float r = max(length(k), 0.001);
warp_32=`    k /= r;
warp_33=`    float t = (d * 0.9 + 0.1) / (1 + r * r * 0.15);
warp_34=`    float u = pow(max(dot(m, k), 0), 4) * 0.7 + pow(max(dot(m, k), 0), 8) * 0.3;
warp_35=`    float v = pow(max(dot(reflect(-k, m), -normalize(float3(q, 1))), 0), 12);
warp_36=`    float3 x = smoothstep(0.05, 0.75, pow(tex2D(img, q + q).xyz * tex2D(img, q + q).xyz, float3(0.75, 0.8, 0.85)));
warp_37=`    c = sqrt(clamp((x * (u * float3(0.5, 0.9, 1) * 2 + 0.5) + float3(1, 1, 1) * v * 2) * t, 0, 1));
warp_38=`    ret = float4(c, 1);
warp_39=`}
comp_1=`#define sat saturate
comp_2=`float glow, tmp, lamp, dist, bdist, b2dist, dist_c, smask;
comp_3=`float2 dz, uv1, uv3, uv4;
comp_4=`static const float3 CamPos = float3(q4,q5,q6);
comp_5=`static const float myzoom = q7,  res = 255, res2 = 64, tele = q16;
comp_6=`static const float3x3 RotMat = float3x3(q20,q21,q22,q23,q24,q25,q26,q27,q28);
comp_7=`
comp_8=`float2 fstep2 (float2 xy) {return 1.0/res*round(res*xy);}
comp_9=`
comp_10=`float GetDist(float2 uvi) {float2 tmp; tmp = (tex2D (sampler_fc_main, uvi).gb); 
comp_11=`return 1.0078125-tmp.y -0.015625*tmp.x;} // = 1-(tmp.y + 1.0/res2*(tmp.x-.50));}
comp_12=`
comp_13=`float GetDistB(float2 uvi)  {return 1-GetBlur1(uvi).b;}
comp_14=`float3 screen3;
comp_15=`float3 lavcol (float t) {return saturate(float3(pow(t,1),pow(t,2.),pow(t,5)));}
comp_16=`
comp_17=`static float3 t = float3(q20,q23,q26);
comp_18=`static float3 s = float3(q21,q24,q27);
comp_19=`static float3 ts = -cross(s,t);
comp_20=`static float3 pos = float3 (1,1,1);
comp_21=`
comp_22=`float3 project (float dist) {  float z;
comp_23=`  z = 18*dist/mul(cross(ts,-t),screen3);
comp_24=`  return float3(mul(float2x3(ts,t),cross(pos,screen3))-z,-z);}
comp_25=`
comp_26=`shader_body {
comp_27=`screen3 = float3 ((uv-.5)*aspect.xy,tele*0+1);
comp_28=`float3 uv2 = project(.1);
comp_29=`float3 sky = sat(lavcol (1-(abs(.3/uv2.z))))-.8;
comp_30=`
comp_31=`bdist = min(GetDist(uv),GetDistB(uv));;
comp_32=`
comp_33=`sky *= sat(1*bdist-2);
comp_34=`ret = sat(lerp (1, sky, bdist));
comp_35=`
comp_36=`float struc = lerp(GetPixel(uv).r, GetBlur1((uv-5)/5+5).r,GetBlur1(uv).r-.8);
comp_37=`ret += lavcol(struc)*(.2-pow(bdist,1+5*mid_att));
comp_38=`//ret = struc;
comp_39=`}
comp_40=`
