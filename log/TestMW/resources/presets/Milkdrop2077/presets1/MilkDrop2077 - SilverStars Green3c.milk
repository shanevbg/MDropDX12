per_frame_81=q12=q11;
per_frame_82=q31=tan(time*.1)/cos(time*.1)+2;
per_frame_83=q32=tan(time*.098)*sin(time*.101)+2;
per_frame_84=chng=sin(time*.5);
per_frame_85=cthr=.9999;
