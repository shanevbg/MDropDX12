per_frame_63=warp = 0;
per_frame_64=
per_frame_65=wave_b = if(below(treb, 1.8),1-.025*int(rand(10)),0);
per_frame_66=wave_g = wave_g*sqr(.01*int(rand(100)));
per_frame_67=decay = .9999+.0001+0*if(equal(frame % 10,0),.95,1);
per_frame_68=monitor = wave_g;
