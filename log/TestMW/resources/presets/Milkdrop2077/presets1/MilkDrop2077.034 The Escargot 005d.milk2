warp_1=`float2 uv0, uv1;
warp_2=`float d;
warp_3=`static const float2 par = float2 (q1,q2);
warp_4=`
warp_5=`shader_body
warp_6=`{
warp_7=`uv0 = 3*uv;
warp_8=`uv1 = uv0;
warp_9=`d= length(uv1);
warp_10=`
warp_11=`for ( int n=0; (n <5) && (n<14*d) ; n++ )
warp_12=`{
warp_13=`uv1 += cos(uv1.yx+par.yx) + uv0 - par;
warp_14=`d=frac(.08*length (uv1)*2);
warp_15=`}
warp_16=`
warp_17=`ret= d*float3 (1.8,1.7,2.8);
warp_18=`}
comp_1=`// (MWmod) sampler sampler_rand00;
comp_2=`float cross, noise, z, mask, scale;
comp_3=`float2 rs, rs0, uv1, uv2, uv3, uv4, uvt;
comp_4=`float3 ret1,ret2,struc,flash2;
comp_5=`
comp_6=`float3 Get1 (float2 uvi){return GetPixel (uvi);}
comp_7=`
comp_8=`shader_body {
comp_9=`
comp_10=`
comp_11=`
comp_12=`
comp_13=`
comp_14=`
comp_15=`float iter = 4+10*saturate (texsize.x/1024*uv.y);
comp_16=`ret = Get1(uv); ret1 = ret; ret2 = ret;
comp_17=`for (int n =1; n < 10; n++) {
comp_18=`  ret1 = max(ret1,Get1(uv+texsize.zw*float2(n,0)));
comp_19=`//  ret2 = max(ret2,Get1(uv+texsize.zw*float2(0,n)));
comp_20=`}
comp_21=`struc = ret1;
comp_22=`mask = saturate(1-16*lum(struc));
comp_23=`struc *= .06/(length(rad/2-length((ret1+ret2*0.2))+0.6));
comp_24=`
comp_25=`//BACK
comp_26=`//uv4 = (uv-0.5) * (1+0*exp(-pow ((uv.x-0.5)*3-2*q14,2)))+0.5;
comp_27=`
comp_28=`
comp_29=`noise = (tex2D(sampler_noise_lq,2*uv4).r+0.25);
comp_30=`noise *= 1-tex2D(sampler_noise_lq,2*uv4+texsize.zw*-4).r;
comp_31=`// (MWmod) noise *= (0.5+ 0.5*(lum(tex2D(sampler_rand00,uv)) > 0.5))*2;
comp_32=`ret = 0.05+noise*0.5*(1-rad);  // texLum (orig *0.5)
comp_33=`
comp_34=`ret *= saturate(1-lum(GetBlur2(uv4-0.13))*8);
comp_35=`ret = lerp (ret,struc, !mask);
comp_36=`
comp_37=`//NEW FLASH
comp_38=`
comp_39=`//ret = GetPixel(uv);
comp_40=`//ret *= 1.4;  // gamma  (orig 1.4  und  deakt)
comp_41=`//ret /= float3(1.8,-0.8,2.8);
comp_42=`//MilkDrop3 Color Mode:
comp_43=`ret /= float3(1.9,1.2,1.2);
comp_44=`}
