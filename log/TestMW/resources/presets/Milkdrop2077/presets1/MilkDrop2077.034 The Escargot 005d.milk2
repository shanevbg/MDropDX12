wave_4_per_point36=x = (x-.5)*0.75 + 0.5;
wave_4_per_point37=y = oy*fov/oz + 0.46;
wave_4_per_point38=
wave_4_per_point39=b = 1+sin(sp);
wave_4_per_point40=g = 0.5 + 0.5*sin(sample*1.57);
wave_4_per_point41=r = 0.5 + 0.5*cos(sample*1.57);
wave_4_per_point42=a = 0.5 + (oz + 2)*0.25;
per_frame_1=mv_r = mv_r + 0.2*( 0.60*sin(0.980*time) + 0.40*sin(1.047*time) );
per_frame_2=mv_g = mv_g + 0.2*( 0.60*sin(0.835*time) + 0.40*sin(1.081*time) );
per_frame_3=mv_b = mv_b + 0.2*( 0.60*sin(0.814*time) + 0.40*sin(1.011*time) );
per_frame_4=q1 = (cx*2-1) + 0.6*( 0.60*sin(0.374*time) + 0.40*sin(0.294*time) );
per_frame_5=q2 = (cy*2-1) + 0.6*( 0.60*sin(0.393*time) + 0.40*sin(0.223*time) );
per_frame_6=ob_r = 1- 0.4*abs(q1);
per_frame_7=ob_g = 0.3*abs(q2);
per_frame_8=ob_b = 0.4*abs(q1);
per_frame_9=wave_r = wave_r + 0.4*( 0.60*sin(0.514*time) + 0.40*sin(1.211*time) );
per_frame_10=wave_b = wave_b + 0.4*( 0.60*sin(0.714*time) + 0.40*sin(q2) );
per_frame_11=wave_g = wave_g + 0.4*( 0.60*sin(10*q1) + 0.40*sin(10*q2) );
per_frame_12=
per_pixel_1=zoom = zoom + 0.06*sin(rad*12 + ang*3 + time*-3.4)*(1-rad);
per_pixel_2=rot = rot * (1-rad);
warp_1=`sampler sampler_Pattern_045;
warp_2=`
warp_3=`shader_body
warp_4=`{
warp_5=`    // sample previous frame
warp_6=`   ret = tex2D( sampler_Pattern_045, uv);
warp_7=`}
comp_1=`shader_body
comp_2=`{
comp_3=`
comp_4=`
comp_5=`
comp_6=`
comp_7=`
comp_8=`//MilkDrop3 Zoom Mode:
comp_9=`uv = 0.05+ 0.9*uv;
comp_10=`
comp_11=`float3 rnd = tex2D(sampler_noise_lq, rand_frame.xy + uv*texsize.xy*texsize_noise_lq.zw)*2-1;
comp_12=`
comp_13=`ret = GetPixel(uv);
comp_14=`
comp_15=`float2 d = texsize.zw * 8;
comp_16=`float3 dx = ( GetBlur1(uv + float2(1,0)*d) - GetBlur1(uv-float2(1,0)*d) );
comp_17=`float3 dy = ( GetBlur1(uv + float2(0,1)*d) - GetBlur1(uv-float2(0,1)*d) );
comp_18=`
comp_19=`uv -= float2(lum(dx),lum(dy))*texsize.zw*32;
comp_20=`
comp_21=`
comp_22=`ret = pow(abs(GetBlur3(uv+rnd.xy*texsize.zw*5)*2-GetPixel(uv))*1.6,2)*0.9;
comp_23=`
comp_24=`//MilkDrop3 Color Mode:
comp_25=`ret /= float3(2.0,1.8,0.8);
comp_26=`}
[PRESET2_END]
