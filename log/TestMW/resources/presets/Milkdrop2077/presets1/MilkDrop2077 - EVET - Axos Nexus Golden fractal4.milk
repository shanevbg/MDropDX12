per_frame_1=vb = vb*0.883 + (1-vb)*pow(bass*treb*mid,2)*0.023;
per_frame_2=vvb = vvb*1.178 + (1-vvb)*vb*0.01;
per_frame_3=vm = vm*0.807 + (1-vm)*pow(mid,2)*0.022;
per_frame_4=vvm = vvm*0.931 + (1-vvm)*vm*0.012;
per_frame_5=vt = 1.016 + (1-vt)*pow(1,2)*0.016;
per_frame_6=vvt = vvt*0.931 + (1-vvt)*vt*0.011;
per_frame_7=vvb = min(0.18,max(0,vvb));
per_frame_8=vvm = min(1,max(0,vvm));
per_frame_9=vvt = min(1,max(0,vvt));
per_frame_10=q1 = vvb*2;//0.5 + vb - vvb;
per_frame_11=q2 = vvm*2;//0.51 + vm - vvm;
per_frame_12=q3 = vvt*2;//0.54 + vt - vvt;
per_frame_13=v=1;
per_frame_14=bb = bb - vvb*v;
per_frame_15=mm = mm - vvm*v;
per_frame_16=tt = tt - vvt*v;
per_frame_17=q4 = -bb;
per_frame_18=q5 = -mm;
per_frame_19=q6 = -tt;
