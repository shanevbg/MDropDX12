shape_0_per_frame9=
shape_0_per_frame10=rad = .022/(z*zmax/2)*reg32 ;
shape_0_per_frame11=
shape_0_per_frame12=out=(x>1)||(x<0)||(y>1)||(y<0)||(z<0);
shape_0_per_frame13=if (out,
