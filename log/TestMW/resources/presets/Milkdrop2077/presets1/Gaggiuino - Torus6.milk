MILKDROP_PRESET_VERSION=201
PSVERSION=4
PSVERSION_WARP=4
PSVERSION_COMP=3
[preset00]
fRating=5.000
fGammaAdj=1.460
fDecay=0.935
fVideoEchoZoom=1.007
fVideoEchoAlpha=0.500
nVideoEchoOrientation=2
nWaveMode=15
bAdditiveWaves=1
bWaveDots=0
bWaveThick=1
bModWaveAlphaByVolume=0
bMaximizeWaveColor=1
bTexWrap=1
bDarkenCenter=0
bRedBlueStereo=0
bBrighten=1
bDarken=1
bSolarize=0
bInvert=0
fWaveAlpha=0.001
fWaveScale=0.625
fWaveSmoothing=0.900
fWaveParam=0.000
fModWaveAlphaStart=0.880
fModWaveAlphaEnd=1.980
fWarpAnimSpeed=0.498
fWarpScale=100.000
fZoomExponent=1.00183
fShader=1.000
zoom=0.99815
rot=0.00000
cx=0.500
cy=0.500
dx=0.00000
dy=0.00000
warp=0.01000
sx=1.00180
sy=0.99990
wave_r=0.000
wave_g=0.000
wave_b=0.000
wave_x=0.500
wave_y=0.500
ob_size=0.000
ob_r=0.360
ob_g=0.290
ob_b=0.290
ob_a=1.000
ib_size=0.000
ib_r=1.000
ib_g=0.000
ib_b=1.000
ib_a=1.000
nMotionVectorsX=64.000
nMotionVectorsY=48.000
mv_dx=0.000
mv_dy=0.000
mv_l=1.000
mv_r=1.060
mv_g=1.000
mv_b=0.819
mv_a=0.000
b1n=0.000
b2n=0.000
b3n=0.000
b1x=1.000
b2x=1.000
b3x=1.000
b1ed=0.250
warp_1=`shader_body 
warp_2=`{
warp_3=`    // Aspect-correct coordinates
warp_4=`    float aspect_ratio = aspect.x / aspect.y;
warp_5=`    float2 centered_uv = (uv_orig - 0.5) * 2.0 * float2(aspect_ratio, 1.0);
warp_6=`    
warp_7=`    float4 col = float4(0,0,0,0);  // Start with black
warp_8=`    float iter = 0.0;               // Iteration counter
warp_9=`    
warp_10=`    // Main rendering loop (64 iterations)
warp_11=`    for(col.b = 1.0; iter < 64.0; iter += 1.0) 
warp_12=`    { 
warp_13=`        // Distance field calculation
warp_14=`        float dist = length(float2(
warp_15=`            col.a = length(col.xz) - 0.72,  // Circular shape
warp_16=`            col.y                            // Vertical component
warp_17=`        )) - 0.5;                           // Radius adjustment
warp_18=`        
warp_19=`        // Accumulate monochrome effect
warp_20=`        col += float4(centered_uv, 1.0, 0.0) * dist;
warp_21=`    }
warp_22=`    
warp_23=`    // Pattern
warp_24=`    float angleDiff = atan2(col.y, col.w) - atan2(col.z+q1, col.x);
warp_25=`    float pattern = sin(18.0 * (angleDiff - time));
warp_26=`    
warp_27=`    // Convert to grayscale with contrast adjustment
warp_28=`    float grayscale = dot(col.rgb, float3(0.299, 0.587, 0.114));
warp_29=`    grayscale = 1.5 * pow(grayscale + pattern, 1.5); // Contrast boost
warp_30=`    
warp_31=`    // Vignette effect
warp_32=`    float2 centerUV = uv_orig - 0.5;
warp_33=`    float vignette = 1.0 - smoothstep(0.3, 0.7, dot(centerUV, centerUV));
warp_34=`    
warp_35=`    // Final black and white output
warp_36=`    ret = grayscale;
warp_37=`}
comp_1=`shader_body
comp_2=`{
comp_3=`
comp_4=`float2 uv2 = uv;
comp_5=`uv2.x=1-uv2.x;
comp_6=`
comp_7=`    float2 d  = texsize.zw*4;
comp_8=`    float2 d2 = texsize.zw*4;
comp_9=`
comp_10=`    float3 dx  = ( GetBlur1(uv +float2(1,0)*d )-GetBlur1(uv2-float2(1,0)*d2) );
comp_11=`    float3 dx2 = ( GetBlur1(uv2+float2(1,0)*d2)-GetBlur1(uv -float2(0,1)*d ) );
comp_12=`
comp_13=`    float3 dy  = ( GetBlur1(uv2+float2(0,1)*d2)-GetBlur1(uv -float2(1,0)*d ) );
comp_14=`    float3 dy2 = ( GetBlur1(uv +float2(0,1)*d )-GetBlur1(uv2-float2(0,1)*d2) );
comp_15=`
comp_16=`
comp_17=`float2 uv_bg  = uv2 - float2(dx2.y,dy2.y)*texsize.zw*16;
comp_18=`float2 uv_bg2 = uv  - float2(dx.y ,dy.y )*texsize.zw*16;
comp_19=`
comp_20=`        ret = (GetBlur2(uv_bg )-GetBlur1(uv_bg2)*1+GetPixel(uv_bg )*0.9 + (-dx.y  + dy.y )*0.4).y*0.8*float3(1.0,1.1,1.2);
comp_21=`float3 ret2 = (GetBlur2(uv_bg2)-GetBlur1(uv_bg )*1+GetPixel(uv_bg2)*0.9 + (-dx2.y + dy2.y)*0.4).y*0.8*float3(1.2,1.0,1.1);
comp_22=`
comp_23=`float2 uv_m  = uv2 - float2(dx2.x,dy.x )*texsize.zw*8;
comp_24=`float2 uv_m2 = uv  - float2(dx.x ,dy2.x)*texsize.zw*8;
comp_25=`
comp_26=`ret  = lerp(ret , 2*float3(0.0,0.5,1.0), GetBlur3(uv_m2 - float2(dx2.y,dy.y )*0.4).x*0.4);
comp_27=`ret2 = lerp(ret2, 2*float3(0.5,1.0,0.0), GetBlur3(uv_m  - float2(dx.y ,dy2.y)*0.4).x*0.4);
comp_28=`
comp_29=`ret  = lerp(ret , 2*float3(0.5,1.0,1.0), GetBlur2(uv_m  - float2(dx.y ,dy2.y)*0.2).x*0.4);
comp_30=`ret2 = lerp(ret2, 2*float3(1.0,0.5,1.0), GetBlur2(uv_m2 - float2(dx2.y,dy.y )*0.2).x*0.4);
comp_31=`
comp_32=`ret = lerp(ret, 2*float3(1,1,0.8), GetBlur1(uv_m - float2(dx.y,dy.y)*0.1).x*0.2);
comp_33=`//ret = lerp(ret, float3(0.5,0,1), GetPixel(uv_m).x*0.4);
comp_34=`
comp_35=`//ret = .7-ret2;
comp_36=`//ret2=.7-ret;
comp_37=`//ret-=ret2;
comp_38=`//MilkDrop3 Color Mode:
comp_39=`ret /= float3(1.9,2.5,2.6);
comp_40=`//MilkDrop3 Solarize Mode:
comp_41=`ret = ret*(1-ret)*4;
comp_42=`//MilkDrop3 Invert Mode:
comp_43=`ret = 1 - ret;
comp_44=`}
