b3x=1.000
b1ed=0.250
warp_1=`
warp_2=`//Shader from https://x.com/YoheiNishitsuji/status/1946193239486431531
warp_3=`//Ported to MilkDrop by MilkDrop2077
warp_4=`//MIT Licensed
warp_5=`
warp_6=`// HSV to RGB conversion
warp_7=`float3 hsv(float h, float s, float v) {
warp_8=`    float4 K = float4(1.0, 2.0/3.0, 1.0/3.0, 3.0);
warp_9=`    float3 p = abs(frac(h + K.xyz) * 6.0 - K.www);
warp_10=`    return v * lerp(K.xxx, saturate(p - K.xxx), s);
warp_11=`}
warp_12=`
warp_13=`// 3D rotation matrix
warp_14=`float3x3 rotate3D(float angle, float3 axis) {
warp_15=`    axis = normalize(axis);
warp_16=`    float s = sin(angle);
warp_17=`    float c = cos(angle);
warp_18=`    float oc = 1.0 - c;
warp_19=`    return float3x3(
warp_20=`        oc * axis.x * axis.x + c, oc * axis.x * axis.y - axis.z * s, oc * axis.z * axis.x + axis.y * s,
warp_21=`        oc * axis.x * axis.y + axis.z * s, oc * axis.y * axis.y + c, oc * axis.y * axis.z - axis.x * s,
warp_22=`        oc * axis.z * axis.x - axis.y * s, oc * axis.y * axis.z + axis.x * s, oc * axis.z * axis.z + c
warp_23=`    );
warp_24=`}
warp_25=`shader_body{
warp_26=`    // Calculate aspect ratio correction
warp_27=`    float aspect = aspect.x / aspect.y;
warp_28=`
warp_29=`uv = (uv_orig - 0.5) * float2(aspect.x, 1.0);
warp_30=`uv.x *= 0.8;  // Compress horizontally
warp_31=`float t = time;
warp_32=`float3 o = float3(0.0, 0.0, 0.0);  // Output color
warp_33=`float g = 0.0;  // Ray position
warp_34=`float e = 0.0;  // Scale factor
warp_35=`float s = 0.0;  // Distance field
warp_36=`
warp_37=`for(float i = 0.0; i < 64.0; i++) {
warp_38=`    e = 2.0;
warp_39=`    float3 p = mul(float3(uv * g * 3.0, g), rotate3D(t * 0.5 - 8.0, float3(2.0 + sin(t * 0.5) * 2.0, 1.0, 1.0)));
warp_40=`    p.z = fmod(t * 0.5 / 1.047 + p.z, e) - e;
warp_41=`    p.x += 0.6;
warp_42=`
warp_43=`    for(int j = 0; j < 21; j++) {
warp_44=`        p = abs(p.zyx) - 1.0;
warp_45=`        s = dot(p, p);
warp_46=`        e /= s;
warp_47=`        p /= s + 0.03;
warp_48=`    }
warp_49=`
warp_50=`    g -= p.z / e * 0.5 + 0.002;
warp_51=`    o += 1e-5 + hsv(p.y, p.y * 5.0 + s, 3.0) * 9e-6 * e / s / s;
warp_52=`}
warp_53=`
warp_54=`ret = float4(o, 1.0);
warp_55=`}
comp_1=`float d;
comp_2=`float3 emboss, dx, dy;
comp_3=`shader_body
comp_4=`{
comp_5=`
comp_6=`    d = texsize.zw*1;
comp_7=`    dx = ( GetPixel(uv+float2(1,0)*d)-GetPixel(uv-float2(1,0)*d) )*8;
comp_8=`    d = texsize.zw*2;
comp_9=`    dx += ( GetPixel(uv+float2(1,0)*d)-GetPixel(uv-float2(1,0)*d) )*4;
comp_10=`    d = texsize.zw*3;
comp_11=`    dx += ( GetPixel(uv+float2(1,0)*d)-GetPixel(uv-float2(1,0)*d) )*2;
comp_12=`    d = texsize.zw*4;
comp_13=`    dx += ( GetPixel(uv+float2(1,0)*d)-GetPixel(uv-float2(1,0)*d) );
comp_14=`
comp_15=`
comp_16=`float3 wires = (dx.x*0.15 + 0.5)*GetBlur3(uv).x*lerp(float3(2.3,0.4,2.7),float3(2.4,0.5,2.5),GetBlur2(uv).z*2);
comp_17=`ret = lerp(GetPixel(uv).z*float3(0.8,0.1,0.5),1,wires);
comp_18=`
comp_19=`    d = texsize.zw * 8;
comp_20=`    dx = ( GetBlur1(uv + float2(1,0)*d) - GetBlur1(uv-float2(1,0)*d) );
comp_21=`    dy = ( GetBlur1(uv + float2(0,1)*d) - GetBlur1(uv-float2(0,1)*d) );
comp_22=`
comp_23=`uv = uv - float2(dx.x,dy.x)*0.08;
comp_24=`
comp_25=`
comp_26=`ret = lerp(ret,float3(1.5,0,1.6)-0.2,GetBlur2(uv).y);
comp_27=`ret = lerp(ret,float3(0.1,0.3,0.8)+1,GetPixel(uv).y*1.2);
comp_28=`
comp_29=`//MilkDrop3 Color Mode:
comp_30=`ret /= float3(-1.4,2.5,2.6);
comp_31=`//MilkDrop3 Burn Mode:
comp_32=`ret = lerp(ret,2,GetPixel(uv).z*1.36);
comp_33=`}
