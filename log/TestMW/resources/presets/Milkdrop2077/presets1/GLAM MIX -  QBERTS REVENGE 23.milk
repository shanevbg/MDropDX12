shape_0_per_frame1=i=instance;   sa=i/1014;     
shape_0_per_frame2=
shape_0_per_frame3=s1=((i/6)%13)/13;   s2=((i/6)%169)/169; 
shape_0_per_frame4=
shape_0_per_frame5=
shape_0_per_frame6=x0= -s1+s2;             y0= 1-s1-s2;    
shape_0_per_frame7=x1 = x0+ .04*y0-.04;    y1 = y0- .04*x0-.04;
shape_0_per_frame8=
shape_0_per_frame9=d = -2*time+ 5*y1   ; 
shape_0_per_frame10=
shape_0_per_frame11=y1 += .15*sin(d)   ; 
shape_0_per_frame12=
shape_0_per_frame13=
shape_0_per_frame14=z1= .45+.15*sin(.2*time);
shape_0_per_frame15=x1 *=  z1;    y1 *=  z1;
shape_0_per_frame16=
shape_0_per_frame17=
shape_0_per_frame18=t2 = 169*6.28*sa +.55*sa  +1.57  ; 
shape_0_per_frame19=z2 = .09*z1;
shape_0_per_frame20=x2 = z2*sin(t2);    y2 = z2*cos(t2);     
shape_0_per_frame21=
shape_0_per_frame22=
shape_0_per_frame23=x=.5 + x1+x2/q6;
shape_0_per_frame24=y=.5 + y1+y2; 
shape_0_per_frame25=
shape_0_per_frame26=rad = 2.01*z2;     ang=3.14/4+t2;
shape_0_per_frame27=
shape_0_per_frame28=t3=.6+ .4*sin(.5*d); 
shape_0_per_frame29=t4=.6+ .4*cos(.5*d); 
shape_0_per_frame30=p=.1+.4*(i/2)%3;   
shape_0_per_frame31=
shape_0_per_frame32=b = p*t3;     b2=b;
shape_0_per_frame33=g = p*t4;     g2=g;
shape_0_per_frame34=r = g*g*g;      r2=r;
shape_0_per_frame35= 
per_frame_1=decay=0;  
per_frame_2=q6=aspecty;
per_frame_3=
per_frame_4=p+=bass;
per_frame_5=q1=10*sin(.15*time+.001*p);
per_frame_6=//q1=3.15;
warp_1=`shader_body
warp_2=`{
warp_3=`float2 uv_m = 1.0 - abs( frac( uv * 0.5 ) * 2.0 - 1.0 ); // Eo.S' mirror code
warp_4=`ret.x = tex2D( sampler_fc_main, uv_m ).z; // first julia fractal iteration
warp_5=`ret.y = lerp(lerp(tex2D( sampler_fc_main, uv_m ).x, ret.x,0.5), 
warp_6=`             GetPixel(uv_orig).y,
warp_7=`             0.75); // 75% of motion blur to the green channel
warp_8=`
warp_9=`
warp_10=`float2 d = texsize.zw*6;
warp_11=`float2 uv_z = (uv_orig-0.5)*0.998 + 0.5; // a small dose of zoom-in
warp_12=`float3 dx = ( GetBlur1(uv_z + float2(1,0)*d) - GetBlur1(uv_z-float2(1,0)*d) );
warp_13=`float3 dy = ( GetBlur1(uv_z + float2(0,1)*d) - GetBlur1(uv_z-float2(0,1)*d) );
warp_14=`uv_z -=float2(dx.z,dy.z)*texsize.zw*2; //shortening of the nebulous matter
warp_15=`ret.z = max((tex2d(sampler_fc_main,uv_m).x-0.5)*3*saturate(1-length(uv_orig-0.5)*3.2), // feeded by the inner of the red channel
warp_16=`             tex2d(sampler_fc_main,uv_z).z);
warp_17=`ret.z += (tex2d(sampler_fc_main,uv_z).z - GetBlur1(saturate(uv_z)).z)*0.02; // sort of geiss' skin dot code
warp_18=`}
comp_1=`#define GP GetPixel
comp_2=`#define GB GetBlur1
comp_3=`sampler sampler_pw_noise_lq;
comp_4=`static float2 hor = float2 (texsize.z,0);
comp_5=`static float2 ver = float2 (0, texsize.w);
comp_6=`float2 uv1,uv10,uv2,uv3,uv6,dz,dz0,dz1;
comp_7=`float3 noise, ret1, ret2, neu, mus;
comp_8=`
comp_9=`float matan (float x)
comp_10=`{return x*(1.061 - abs(x)*0.274);}
comp_11=`
comp_12=`float matan2 (float im, float re)
comp_13=`{float x;
comp_14=`   if (abs(re) > abs(im)) 
comp_15=`   {x = matan (im/re); 
comp_16=`    if (re<0) {x += M_PI;}
comp_17=`   }
comp_18=`   else
comp_19=`   {x = M_PI/2 -matan (re/im); 
comp_20=`   if (im<0) {x += M_PI;}
comp_21=`   } 
comp_22=`  return (x>=M_PI? x-2*M_PI: x);
comp_23=`}
comp_24=`
comp_25=`
comp_26=`shader_body {//MilkDrop3 Zoom Mode:
comp_27=`uv = 0.25 + 0.5*uv;
comp_28=`
comp_29=`uv10 = (uv-.5)*aspect.xy; 
comp_30=`float ang1 = matan2 (uv10.x,uv10.y)/M_PI;
comp_31=`float ang2 = 0.5 + (1.0 - abs( frac(ang1 * 0.5) * 2 - 1.0 )-.5); 
comp_32=`float z = 0.02;
comp_33=`uv1 = float2 (.6+3*z-z/length (uv10), ang2).yx;
comp_34=`ret1= ret2= 0;
comp_35=`dz= dz1=0;
comp_36=`uv3 = uv1;
comp_37=`float mask = saturate(4*uv3.y) * saturate(rad*1);
comp_38=`uv3 = frac(uv3);
comp_39=`dz0.x = (lum(GP(uv3+hor))- lum(GP(uv3-hor)));
comp_40=`dz0.y = (lum(GP(uv3+ver))- lum(GP(uv3-ver)));
comp_41=`dz0.x += 2*(lum(GB(uv3+hor))- lum(GB(uv3-hor)));
comp_42=`dz0.y += 2*(lum(GB(uv3+ver))- lum(GB(uv3-ver)));
comp_43=`dz +=  mask*dz0/2;
comp_44=`ret1 = max(ret1,(GP(uv3)+GB(uv3))/2*mask);
comp_45=`ret2 = abs(GetPixel(uv3)-GetBlur1(uv3));
comp_46=`
comp_47=`mus = 1.2/length(sin(12*(uv1+dz/2 + 2.25*(ret1-0.5)) +time))*rad*(1-rad);
comp_48=`
comp_49=`float stars = 0;
comp_50=`int anz = 6;
comp_51=`uv2 = float2 (0.02/length (uv10), ang2).yx;
comp_52=`for (int n=1; n <= anz; n++) 
comp_53=`{
comp_54=`  float2 uv4 = 8.0*((1.0+n)*(uv2+(dz+(ret1-.5)) + 0.1*n )+ float2(0,time*.1));
comp_55=`  float smask = saturate(tex2D (sampler_pw_noise_lq,uv4/256)-.95);
comp_56=`  stars = max(stars,(0.1/pow(length(frac(uv4)-.5),2)*smask));
comp_57=`n++;
comp_58=`}
comp_59=`
comp_60=`//mus = max(mus,stars);
comp_61=`uv2 = float2 (22*length (uv10), ang2).yx;
comp_62=`uv2 = uv2*.2+float2(0.07*time,.5);
comp_63=`uv2=frac(uv2);
comp_64=`float3 bk = GetBlur2(uv2) * 2*(1-rad) + .2;
comp_65=`ret = sqrt(ret1)*(1+ret2)*(.25+mus) ;
comp_66=`ret *= 1+6*length(dz);
comp_67=`ret += saturate(stars)*.7;
comp_68=`ret += 2*bk* saturate(1-lum(ret1)*16)*sqrt(mid_att+1)*saturate(0.035/(0.001+sqrt(length(uv10))));
comp_69=`
comp_70=`ret *= 3.7-rad;
comp_71=`ret -= 0.3;
comp_72=`//ret = GetPixel(uv);
comp_73=`//MilkDrop3 Color Mode:
comp_74=`ret /= float3(2.7,1.6,1.6);
comp_75=`}
