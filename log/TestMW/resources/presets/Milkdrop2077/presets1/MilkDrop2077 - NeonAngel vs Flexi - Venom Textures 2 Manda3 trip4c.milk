comp_74=`
comp_75=`//ret = .7-ret2;
comp_76=`//ret2=.7-ret;
comp_77=`//ret-=ret2;
comp_78=`//MilkDrop3 Color Mode:
comp_79=`ret /= float3(1.8,0.8,1.2);
comp_80=`//MilkDrop3 Solarize Mode:
comp_81=`ret = ret*(1-ret)*4;
comp_82=`}
