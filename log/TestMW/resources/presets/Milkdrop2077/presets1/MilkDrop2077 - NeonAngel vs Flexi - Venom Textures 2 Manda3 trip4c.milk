per_frame_17=monitor=mq1;
per_frame_18=vol=bass+treb+mid;
per_frame_19=atime=atime+vol;
per_frame_20=q11=.4+sin(atime*.006        )*.4;
per_frame_21=q12=.4+cos(atime*.00613828348)*.4;
per_frame_22=q13=.4+sin(atime*.00598593455)*.4;
per_frame_23=monitor=q13;
per_frame_24=
per_frame_25=q8 =oldq8+ 0.001*(pow(1.2*bass+0.4*bass_att+0.2*treb+0.2*treb_att+0.2*mid+0.2*mid_att,6)/fps) +0.1/fps;
per_frame_26=oldq8 = q8;
per_frame_27=ob_r = 0.3 - 0.3*(0.5*sin(q8*0.701)+ 0.3*cos(q8*0.438));
per_frame_28=ob_g = 0.6- 0.4*sin(q8*2.924);
per_frame_29=ob_b = 0.35 - 0.3*cos(q8*0.816);
per_frame_30=warp =0;
per_frame_31=ib_size = 0.0;
per_frame_32=ib_r = ib_r + 0.5*sin(q8*3.034);
per_frame_33=ib_g = ib_g + 0.5*sin(q8*2.547);
per_frame_34=ib_b = ib_b - 0.5*sin(q8*1.431);
per_frame_35=ib_r =0;
per_frame_36=ib_g =0;
per_frame_37=ib_b =0;
per_frame_38=volume = 0.15*(bass_att+bass+mid+mid_att);
per_frame_39=beatrate = if(equal(beatrate,0),1,if(below(volume,0.01),1,beatrate));
per_frame_40=lastbeat = if(equal(lastbeat,0),time,lastbeat);
per_frame_41=meanbass_att = 0.1*(meanbass_att*9 + bass_att);
per_frame_42=peakbass_att = if(above(bass_att,peakbass_att),bass_att,peakbass_att);
per_frame_43=beat = if(above(volume,0.8),if(below(peakbass_att - bass_att, 0.05*peakbass_att),if(above(time - lastbeat,0.1+0.5*(beatrate-0.1)),1,0),0),0);
per_frame_44=beatrate = max(if(beat,if(below(time-lastbeat,2*beatrate),0.1*(beatrate*9 + time - lastbeat),beatrate),beatrate),0.1);
per_frame_45=peakbass_att = if(equal(beat,0),if(above(time - lastbeat,2*beatrate),peakbass_att*0.95,peakbass_att*0.995),bass_att);
per_frame_46=lastbeat = if(beat,time,lastbeat);
per_frame_47=mybeat = if(beat,mybeat+1,mybeat);
per_frame_48=mybeat = if(above(mybeat,7),0,mybeat);
per_frame_49=mybeat2 = if(equal(mybeat,1),1,0);
per_frame_50=q7 = if(beat*mybeat2,0.001+0.0001*int(rand(40)),oldq7);
per_frame_51=oldq7=q7;
per_frame_52=q6 = if(beat*mybeat2,0.001+0.0001*int(rand(40)),oldq6);
per_frame_53=oldq6=q6;
per_frame_54=q5= if(beat*mybeat2,0.001+0.0001*int(rand(40)),oldq5);
per_frame_55=oldq5=q5;
per_frame_56=q4 = if(beat*mybeat2,0.001+0.0001*int(rand(40)),oldq4);
per_frame_57=oldq4=q4;
per_frame_58=Flag = If(beat*mybeat2,if(int(rand(2))-1,1,0),oldFlag);
per_frame_59=oldflag = flag;
per_frame_60=Ratio = If(Beat*mybeat2,100+int(rand(60)),oldRatio);
per_frame_61=OldRatio = Ratio;
per_frame_62=q3 = if(beat*mybeat2,if(flag,ratio,0.75*ratio),oldq3);
per_frame_63=oldq3=q3;
per_frame_64=q2 = if(beat*mybeat2,if(flag,0.75*ratio,ratio),oldq2);
per_frame_65=oldq2=q2;
per_pixel_1=thresh = above(bass_att,thresh)*2+(1-above(bass_att,thresh))*((thresh-1.3)*0.96+1.3);
per_pixel_2=dx_r = equal(thresh,2)*0.015*sin(5*time)+(1-equal(thresh,2))*dx_r;
per_pixel_3=dy_r = equal(thresh,2)*0.015*sin(6*time)+(1-equal(thresh,2))*dy_r;
per_pixel_4=
per_pixel_5=xy = above(sin(time),0)*x + below(sin(1.34*time),0)*y + above((bass_att),1.1)*-1;
per_pixel_6=
per_pixel_7=dx = dx + dx_r;
per_pixel_8=dy = dy + dy_r;
per_pixel_9=sx = sx - abs(12*dx_r*(xy*sin(xy*bass_att*1.25)));
per_pixel_10=sy = sy - abs(12*dy_r*(xy*sin(xy*bass_att*1.25)));
per_pixel_11=rot = rot + 22*dx_r*(xy*cos(4*xy*treb_att));
per_pixel_12=cx = cx + 8*dx_r*(xy*sin(xy*mid_att*1.1));
per_pixel_13=cy = cy + 8*dy_r*(xy*sin(xy*mid_att*1.1));
per_pixel_14=num = 8;
per_pixel_15=pi = 3.141592654;
per_pixel_16=radi = (y-.5)*.75;
per_pixel_17=radi = (y-.5);
per_pixel_18=radi = pow(radi*radi + (x-.5)*(x-.5),.5);
per_pixel_19=
per_pixel_20=an = ang + pi + time;
per_pixel_21=an = an - pi*2*int(an/(pi*2));
per_pixel_22=
per_pixel_23=mod = .1;
per_pixel_24=
per_pixel_25=seg = ang + pi;
per_pixel_26=seg = seg/(pi*2)*num;
per_pixel_27=seg = int(seg);
per_pixel_28=seg = seg - equal(seg,num);
per_pixel_29=
per_pixel_30=anga = (ang + pi) - (pi*2/num)*seg;
per_pixel_31=anga = if(equal(seg%2,0),(pi*2/num) - anga,anga);
per_pixel_32=//anga = anga + pi/6; // num = 6
per_pixel_33=anga = anga + pi/4; // num = 8
per_pixel_34=//anga = anga + .85; // num = 10
per_pixel_35=
per_pixel_36=
per_pixel_37=ox = .5 - radi*sin(anga);
per_pixel_38=oy = .5 + radi*cos(anga);
per_pixel_39=
per_pixel_40=//rot = if(equal(seg,0),rot,0);
per_pixel_41=
per_pixel_42=dx = equal(seg,3)*(x-ox);
per_pixel_43=dy = equal(seg,3)*(y-oy);
per_pixel_44=
per_pixel_45=dx = above(seg,0)*(x-ox);
per_pixel_46=dy = above(seg,0)*(y-oy);
per_pixel_47=
per_pixel_48=//dx = equal(seg,1)*(x - .5)*2;
warp_1=`sampler sampler_worms;
warp_2=`float3 color, mus;
warp_3=`float dx,dy;
warp_4=`shader_body {
warp_5=`
warp_6=`
warp_7=`float2 uv1 = (uv-.5) * aspect.xy;
warp_8=`
warp_9=`float2 uv6 = uv1;
warp_10=`float z = q27*.55*length(uv1)+q30;
warp_11=`float2 d = normalize(uv1);
warp_12=`float2 rs = clamp(tan(z)*d/5,-2,2);
warp_13=`//vitesse serge
warp_14=`
warp_15=`if (q28 ==1) {rs *= sin(uv*2) ;}
warp_16=`
warp_17=`uv += rs*dot(rs,rs)/30;
warp_18=`//coupe serge
warp_19=`
warp_20=`//uv6 = (uv-.5)*(1 + 1*q1*q27);
warp_21=`//uv6 = mul(uv6,float2x2(_qa));
warp_22=`
warp_23=`mus = .1/(sqrt(uv6.y+.002));
warp_24=`mus = abs(mus);
warp_25=`mus *= float3 (.8,.6,1.2);
warp_26=`
warp_27=`
warp_28=`float3 blur = GetBlur1(frac(uv));
warp_29=`
warp_30=`float3 crisp= tex2D(sampler_main,uv);
warp_31=`
warp_32=`float3 ret1 = crisp - blur*.05 + .06*mus;
warp_33=`ret = ret1 * .99 -  .02;
warp_34=`
warp_35=`
warp_36=`}
