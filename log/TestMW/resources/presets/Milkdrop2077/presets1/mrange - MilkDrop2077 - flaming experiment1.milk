MILKDROP_PRESET_VERSION=201
PSVERSION=4
PSVERSION_WARP=4
PSVERSION_COMP=3
[preset00]
fRating=5.000
fGammaAdj=1.460
fDecay=0.935
fVideoEchoZoom=1.007
fVideoEchoAlpha=0.500
nVideoEchoOrientation=2
nWaveMode=15
bAdditiveWaves=1
bWaveDots=0
bWaveThick=1
bModWaveAlphaByVolume=0
bMaximizeWaveColor=1
bTexWrap=1
bDarkenCenter=0
bRedBlueStereo=0
bBrighten=1
bDarken=1
bSolarize=0
bInvert=0
fWaveAlpha=0.001
fWaveScale=0.625
fWaveSmoothing=0.900
fWaveParam=0.000
fModWaveAlphaStart=0.880
fModWaveAlphaEnd=1.980
fWarpAnimSpeed=1.459
fWarpScale=2.007
fZoomExponent=1.00000
fShader=1.000
zoom=0.99990
rot=0.00000
cx=0.500
cy=0.500
dx=0.00000
dy=0.00000
warp=0.01000
sx=0.99990
sy=1.00000
wave_r=0.000
wave_g=0.000
wave_b=0.000
wave_x=0.500
wave_y=0.500
ob_size=0.000
ob_r=1.000
ob_g=0.000
ob_b=1.000
ob_a=1.000
ib_size=0.260
ib_r=0.250
ib_g=0.250
ib_b=0.250
ib_a=0.000
nMotionVectorsX=64.000
nMotionVectorsY=48.000
mv_dx=0.000
mv_dy=0.000
mv_l=1.000
mv_r=1.060
mv_g=1.000
mv_b=0.819
mv_a=0.000
b1n=0.000
b2n=0.000
b3n=0.000
b1x=1.000
b2x=1.000
b3x=1.000
b1ed=0.250
warp_1=`shader_body{
warp_2=`  
warp_3=`//Shader from https://www.shadertoy.com/view/wX33zX
warp_4=`//Ported to MilkDrop by MilkDrop2077
warp_5=`//license: CC0 
warp_6=`
warp_7=`
warp_8=`    float3 o = float3(0,0,0);
warp_9=`    float t = time;
warp_10=`    float2 r = float2(1.0, 1.0/aspect.x);
warp_11=`    
warp_12=`    for(float i=0.0, z=0.0, d=0.0, j=0.0; i<88.0; i+=1.0) {
warp_13=`        // Ray setup
warp_14=`        float2 centered_uv = (uv-0.5)*r*2.0;
warp_15=`        float3 p = z*normalize(float3(centered_uv,1.0));
warp_16=`        p.z -= 4.0;
warp_17=`        float3 P = p;
warp_18=`        
warp_19=`        // Space transformation
warp_20=`        float angle = P.y*P.y/4.0 + 2.0*P.y - t;
warp_21=`        float2x2 rot = float2x2(cos(angle), -sin(angle), sin(angle), cos(angle));
warp_22=`        p.xz = float2(p.x*rot[0][0] + p.z*rot[0][1], p.x*rot[1][0] + p.z*rot[1][1]);
warp_23=`        p.x += sin(0.2*t - p.x);
warp_24=`        
warp_25=`        // Turbulence (fractal noise)
warp_26=`        float turbulence = 9.0;
warp_27=`        for(j=8.0; j>5.0; j-=1.0) {
warp_28=`            turbulence /= 0.8;
warp_29=`            p += 0.4*(p.y+2.0)*cos(p.zxy*turbulence - 3.0*t)/turbulence;
warp_30=`        }
warp_31=`        
warp_32=`        // Distance field
warp_33=`        j = length(p-P);
warp_34=`        p = abs(p);
warp_35=`        d = abs(min(
warp_36=`            max(p.z-0.1, p.x-1.0-0.3*P.y),
warp_37=`            max(p.x-0.2, p.z-1.0-0.3*P.y)
warp_38=`        )) + 9e-3;
warp_39=`        
warp_40=`        // Color calculation
warp_41=`        float3 P_color = 1.0 + sin(0.5 + j - P.y + P.z + float3(2,3,4));
warp_42=`        
warp_43=`        // Volumetric rendering
warp_44=`        o += P_color.x/d * P_color;
warp_45=`        
warp_46=`        // Ray marching step
warp_47=`        z += d/8.0;
warp_48=`    }
warp_49=`    
warp_50=`    // Tone mapping with music reactivity
warp_51=`    float brightness = 0.8 + 0.2*bass_att;
warp_52=`    ret = float4(tanh(o/2e3 * brightness), 1.0);
warp_53=`}
comp_1=`shader_body
comp_2=`{//MilkDrop3 Flip Mode:
comp_3=`uv = 1-uv;
comp_4=`
comp_5=` ret = GetPixel(uv);
comp_6=`}
