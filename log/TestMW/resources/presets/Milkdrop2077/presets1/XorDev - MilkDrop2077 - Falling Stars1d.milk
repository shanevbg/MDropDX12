warp_1=`shader_body
warp_2=`{
warp_3=`
warp_4=`    //Shader By XorDev (x.com/XorDev), ported to MilkDrop by MilkDrop2077
warp_5=`    // Center coordinates and aspect ratio correction
warp_6=`    float aspect = aspect.x / aspect.y;
warp_7=`
warp_8=`    uv = (uv - 0.5) * float2(aspect.x, 1.0);
warp_9=`    float3 col = float3(0,0,0);
warp_10=`    
warp_11=`    // Loop for fractal pattern
warp_12=`    for(float i = 1.0; i <= 50.0; i++)
warp_13=`    {
warp_14=`        // Inline rotate2D: rotation matrix for angle i*i
warp_15=`        float angle = i * i;
warp_16=`        float cos_a = cos(angle);
warp_17=`        float sin_a = sin(angle);
warp_18=`        
warp_19=`        // Transform coordinates
warp_20=`        float2 p = uv * 120.0 / i + time * 0.5;
warp_21=`        float2 q;
warp_22=`        
warp_23=`        // Apply rotation
warp_24=`        q = float2(
warp_25=`            p.x * cos_a - p.y * sin_a,
warp_26=`            p.x * sin_a + p.y * cos_a
warp_27=`        );
warp_28=`        
warp_29=`        // Fractal calculation
warp_30=`        q = frac(q) - 0.5;
warp_31=`        float dist = length(q);
warp_32=`        
warp_33=`        // Inline HSV to RGB conversion
warp_34=`        float h = i * 3.14159265359; // i*PI
warp_35=`        float s = 1.0;
warp_36=`        float v = 1.0;
warp_37=`        float c = v * s;
warp_38=`        float x = c * (1.0 - abs(fmod(h / (3.14159265359/3.0), 2.0) - 1.0));
warp_39=`        float m = v - c;
warp_40=`        float3 rgb;
warp_41=`        if(h < 3.14159265359/3.0)      rgb = float3(c, x, 0.0);
warp_42=`        else if(h < 2.0*3.14159265359/3.0) rgb = float3(x, c, 0.0);
warp_43=`        else if(h < 3.14159265359)     rgb = float3(0.0, c, x);
warp_44=`        else if(h < 4.0*3.14159265359/3.0) rgb = float3(0.0, x, c);
warp_45=`        else if(h < 5.0*3.14159265359/3.0) rgb = float3(x, 0.0, c);
warp_46=`        else                           rgb = float3(c, 0.0, x);
warp_47=`        rgb += float3(m, m, m);
warp_48=`        
warp_49=`        // Accumulate color
warp_50=`        col += rgb / dist * i / 8000.0;
warp_51=`    }
warp_52=`    
warp_53=`    // Final color operation
warp_54=`    col *= col;
warp_55=`    
warp_56=`    // Final output
warp_57=`    ret = float4(col, 1.0);
warp_58=`}
comp_1=`#define sat saturate
comp_2=`float glow, tmp, lamp, dist, bdist, b2dist, dist_c, smask;
comp_3=`float2 dz, uv1, uv3, uv4;
comp_4=`static const float3 CamPos = float3(q4,q5,q6);
comp_5=`static const float myzoom = q7,  res = 255, res2 = 64, tele = q16;
comp_6=`static const float3x3 RotMat = float3x3(q20,q21,q22,q23,q24,q25,q26,q27,q28);
comp_7=`
comp_8=`float2 fstep2 (float2 xy) {return 1.0/res*round(res*xy);}
comp_9=`
comp_10=`float GetDist(float2 uvi) {float2 tmp; tmp = (tex2D (sampler_fc_main, uvi).gb); 
comp_11=`return 1.0078125-tmp.y -0.015625*tmp.x;} // = 1-(tmp.y + 1.0/res2*(tmp.x-.50));}
comp_12=`
comp_13=`float GetDistB(float2 uvi)  {return 1-GetBlur1(uvi).b;}
comp_14=`float3 screen3;
comp_15=`float3 lavcol (float t) {return saturate(float3(pow(t,1),pow(t,2.),pow(t,5)));}
comp_16=`
comp_17=`static float3 t = float3(q20,q23,q26);
comp_18=`static float3 s = float3(q21,q24,q27);
comp_19=`static float3 ts = -cross(s,t);
comp_20=`static float3 pos = float3 (1,1,1);
comp_21=`
comp_22=`float3 project (float dist) {  float z;
comp_23=`  z = 18*dist/mul(cross(ts,-t),screen3);
comp_24=`  return float3(mul(float2x3(ts,t),cross(pos,screen3))-z,-z);}
comp_25=`
comp_26=`shader_body {//MilkDrop3 Flip Mode:
comp_27=`uv = 1-uv;
comp_28=`
comp_29=`screen3 = float3 ((uv-.5)*aspect.xy,tele*0+1);
comp_30=`float3 uv2 = project(.1);
comp_31=`float3 sky = sat(lavcol (1-(abs(.3/uv2.z))))-.8;
comp_32=`
comp_33=`bdist = min(GetDist(uv),GetDistB(uv));;
comp_34=`
comp_35=`sky *= sat(1*bdist-2);
comp_36=`ret = sat(lerp (1, sky, bdist));
comp_37=`
comp_38=`float struc = lerp(GetPixel(uv).r, GetBlur1((uv-5)/5+5).r,GetBlur1(uv).r-.8);
comp_39=`ret += lavcol(struc)*(.2-pow(bdist,1+5*mid_att));
comp_40=`//ret = struc;
comp_41=`}
comp_42=`
comp_43=`//-------------------------------------------
