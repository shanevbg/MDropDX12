shape_0_per_frame33=
shape_0_per_frame34=x1 = cos(w1)*my_x + sin(w1)*my_y;
shape_0_per_frame35=y1 = -sin(w1)*my_x + cos(w1)*my_y;
shape_0_per_frame36=z1 = my_z;
shape_0_per_frame37=
shape_0_per_frame38=x2 = cos(w2)*x1 + sin(w2)*z1;
shape_0_per_frame39=z2 = -sin(w2)*x1 + cos(w2)*z1;
shape_0_per_frame40=y2 = y1;
shape_0_per_frame41=
