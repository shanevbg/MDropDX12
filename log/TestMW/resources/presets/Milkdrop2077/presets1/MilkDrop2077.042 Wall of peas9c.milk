shape_0_per_frame77=sides= if(above(sample,.45)*below(sample,.55), 14*(1-10*(sample-.45)),20);
shape_0_per_frame78=
shape_0_per_frame79=r= if(above(sample,.45)*below(sample,.55),sample,r);
