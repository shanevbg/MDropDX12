shapecode_1_g2=0.445
shapecode_1_b2=0.940
shapecode_1_a2=0.000
shapecode_1_border_r=1.000
shapecode_1_border_g=1.000
shapecode_1_border_b=0.500
shapecode_1_border_a=0.000
shape_1_per_frame1=sounds=(bass+treb+mid);
shape_1_per_frame2=att=(bass_att+treb_att+mid_att)/13;
shape_1_per_frame3=att=(bass_att+treb_att+mid_att)/13;
shape_1_per_frame4=r2=r2+(0.25*sin(time*16.28))-bass;
shape_1_per_frame5=g2=g2+(1.25*sin(time*16.28))-bass;
shape_1_per_frame6=
shape_1_per_frame7=rad=0.4;
shape_1_per_frame8=//x=x+0.243*tan(time/2)+sounds*0.09;
shape_1_per_frame9=//y=y+0.217*sin((time/1.5)+(sounds*0.3));
shapecode_2_enabled=1
shapecode_2_sides=16
shapecode_2_additive=0
shapecode_2_thickOutline=0
shapecode_2_textured=0
shapecode_2_num_inst=353
shapecode_2_x=0.503
shapecode_2_y=0.500
shapecode_2_rad=0.03760
shapecode_2_ang=0.00000
shapecode_2_tex_ang=0.00000
shapecode_2_tex_zoom=1.11234
shapecode_2_r=1.000
shapecode_2_g=1.000
shapecode_2_b=1.000
shapecode_2_a=1.000
shapecode_2_r2=0.000
shapecode_2_g2=0.000
shapecode_2_b2=0.000
shapecode_2_a2=0.000
shapecode_2_border_r=1.000
shapecode_2_border_g=1.000
shapecode_2_border_b=1.000
shapecode_2_border_a=0.000
shape_2_per_frame1=
shape_2_per_frame2=sample=instance/num_inst;
shape_2_per_frame3=rad=.05+.04*sin(sample);
shape_2_per_frame4=/////  Knot - reduced frequencies for slower movement
shape_2_per_frame5=q10=125*sample;  // Halved the base frequency
shape_2_per_frame6=my_x = -.22*cos(q10)-1.28*sin(q10)-.44*cos(2*q10)-.78*sin(2*q10);  // Reduced harmonics
shape_2_per_frame7=my_y= -.1*cos(1.5*q10)-.27*sin(1.5*q10)+.38*cos(3*q10)+.46*sin(3*q10);  // Adjusted frequencies
shape_2_per_frame8=my_z=.7*cos(2*q10)-.4*sin(2*q10);  // Reduced frequency
shape_2_per_frame9=/////// rotations... by flexi
shape_2_per_frame10=d = .2; 
shape_2_per_frame11=zoom = 1;
shape_2_per_frame12=w3 = q1;
shape_2_per_frame13=w2 = q2;
shape_2_per_frame14=w1 = q3;
shape_2_per_frame15=x1 = cos(w1)*my_x + sin(w1)*my_y;
shape_2_per_frame16=y1 = -sin(w1)*my_x + cos(w1)*my_y;
shape_2_per_frame17=z1 = my_z;
shape_2_per_frame18=x2 = cos(w2)*x1 + sin(w2)*z1;
shape_2_per_frame19=z2 = -sin(w2)*x1 + cos(w2)*z1;
shape_2_per_frame20=y2 = y1;
shape_2_per_frame21=y3 = cos(w3)*y2 + sin(w3)*z2;
shape_2_per_frame22=z3 = -sin(w3)*y2 + cos(w3)*z2;
shape_2_per_frame23=x3 = x2;
shape_2_per_frame24=// perspective calculation
shape_2_per_frame25=l = sqrt(x3*x3 + y3*y3);
shape_2_per_frame26=w = atan2(x3,y3);
shape_2_per_frame27=p = tan(asin(1) + atan2(d+z3,l));
shape_2_per_frame28=d = sqrt(x3*x3 + y3*y3 + (z3+d)*(z3+d));
shape_2_per_frame29=my_x = zoom*sin(w)*p;
shape_2_per_frame30=my_y = zoom*cos(w)*p;
shape_2_per_frame31=// Slowed down the position modulation
shape_2_per_frame32=p1 = .2*sin(sample*25);  // Reduced from 50
shape_2_per_frame33=p2 = .2*sin(sample*40);  // Reduced from 80
shape_2_per_frame34=x = .5+my_x*p1;
shape_2_per_frame35=y = .5+my_y*p2;
shape_2_per_frame36=// Slowed down color changes
shape_2_per_frame37=r = .4*sin(sample*40);   // Reduced from 80
shape_2_per_frame38=b = .8*sin(sample*33);   // Reduced from 66
shape_2_per_frame39=g = .6*sin(sample*60);   // Reduced from 120
per_frame_1=mv_r = mv_r + 0.2*( 0.60*sin(0.980*time) + 0.40*sin(1.047*time) );
per_frame_2=mv_g = mv_g + 0.2*( 0.60*sin(0.835*time) + 0.40*sin(1.081*time) );
per_frame_3=mv_b = mv_b + 0.2*( 0.60*sin(0.814*time) + 0.40*sin(1.011*time) );
per_frame_4=q1 = (cx*2-1) + 0.6*( 0.60*sin(0.374*time) + 0.40*sin(0.294*time) );
per_frame_5=q2 = (cy*2-1) + 0.6*( 0.60*sin(0.393*time) + 0.40*sin(0.223*time) );
per_frame_6=ob_r = 1- 0.4*abs(q1);
per_frame_7=ob_g = 0.3*abs(q2);
per_frame_8=ob_b = 0.4*abs(q1);
per_frame_9=wave_r = wave_r + 0.4*( 0.60*sin(0.514*time) + 0.40*sin(1.211*time) );
per_frame_10=wave_b = wave_b + 0.4*( 0.60*sin(0.714*time) + 0.40*sin(q2) );
per_frame_11=wave_g = wave_g + 0.4*( 0.60*sin(10*q1) + 0.40*sin(10*q2) );
per_frame_12=
per_pixel_1=zoom = zoom + 0.06*sin(rad*12 + ang*3 + time*-3.4)*(1-rad);
per_pixel_2=rot = rot * (1-rad);
warp_1=`sampler sampler_Pattern_045;
warp_2=`
warp_3=`shader_body
warp_4=`{
warp_5=`    // sample previous frame
warp_6=`   ret = tex2D( sampler_Pattern_045, uv);
warp_7=`}
comp_1=`sampler sampler_pw_noise_lq;
comp_2=`
comp_3=`float2 rs;
comp_4=`float3 noise, ret1;
comp_5=`
comp_6=`shader_body {
comp_7=`uv = 0.05+ 0.9*uv;
comp_8=`float corr = texsize.xy*texsize_noise_lq.zw;
comp_9=`float2 uv1 = (uv-.5-.0*float2(q1,q2) )*aspect.xy;
comp_10=`//uv = mul(uv-.5,float2x2(_qa))+.5;
comp_11=`
comp_12=`//uv1 = mul(uv1,float2x2(_qa));
comp_13=`uv1*= aspect.yx;
comp_14=`float h1 = 3+q1*4;
comp_15=`
comp_16=`float z = h1/abs(uv1.y) ;
comp_17=`
comp_18=`rs.x = uv1.x *z ;
comp_19=`float mask = saturate (1-z / 40);
comp_20=`rs.y = z + time*3;
comp_21=`
comp_22=`float2 uv6 = sin(rs);
comp_23=`noise = 1-sqrt(length(uv6));
comp_24=`noise *= (noise >= .1) *mask;
comp_25=`ret1 = noise;
comp_26=`
comp_27=`
comp_28=`ret = GetPixel(uv+ret1/2)*1.5 -.1*ret1;    
comp_29=`}

