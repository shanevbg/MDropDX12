warp_1=`shader_body {
warp_2=`float3 noise = tex2D(sampler_noise_mq,uv_orig*8+rand_frame);
warp_3=`float k1=0.7;
warp_4=`ret = max(GetPixel(uv)*k1,GetBlur1(uv));
warp_5=`ret = ret*0.98-0.01*lum(GetBlur1(uv))-0.01*(noise.x>0.85);
warp_6=`}
comp_1=`shader_body
comp_2=`{
comp_3=`float2 uv1 = (uv-0.5)*aspect.xy;
comp_4=`
comp_5=`float rad2 = length(uv1) + .05;
comp_6=`float rad1 = .1/rad2 ;
comp_7=`
comp_8=`float2 uv2 = float2 (ang/3.14, rad1*1.5);
comp_9=`uv2.y = uv2.y  +0.1*time;
comp_10=`uv2.x = uv2.x  +.02*time;
comp_11=`
comp_12=`float2 uv3 = float2 (ang/3.14, rad1);
comp_13=`uv3.y = uv3.y  + q30 ;
comp_14=`uv3.x = uv3.x  + time/25;
comp_15=`
comp_16=`
comp_17=`float3 crisp = GetPixel(uv2) + 2*GetPixel(uv3);
comp_18=`crisp += 2*GetBlur2(frac(uv)) + 2*GetBlur2(frac(uv3));
comp_19=`
comp_20=`float3 lay1 = float3 (1,1,1)*uv.y*pow(1.05-rad,18);
comp_21=`
comp_22=`crisp = 3*crisp * pow(0.5,1);
comp_23=`
comp_24=`float mask = saturate(1-12*rad*bass_att);
comp_25=`
comp_26=`ret = crisp + lay1*mask + mask * GetPixel(uv);
comp_27=`
comp_28=`
comp_29=`   // ret *= 2.00; //gamma
comp_30=`   // float3 retish = 1 - ret*(1-ret)*4; //solarize
comp_31=`//    ret =  + GetBlur3(uv)*2+ret+ret;
comp_32=`//MilkDrop3 Color Mode:
comp_33=`ret /= float3(1.2,1.9,2.7);
comp_34=`//MilkDrop3 Burn Mode:
comp_35=`ret = lerp(ret,2,GetPixel(uv).z*1.36);
comp_36=`}
