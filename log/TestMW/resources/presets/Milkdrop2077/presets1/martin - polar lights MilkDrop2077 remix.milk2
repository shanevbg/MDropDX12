per_frame_init_8=loop (num_sig,
per_frame_init_9=  index = 0;
per_frame_init_10=  loop (num_res,
per_frame_init_11=    n = blocksize*sig + 12*index;
per_frame_init_12=    BPM      = minbpm * pow(maxbpm/minbpm,index/num_res);
per_frame_init_13=    gmegabuf(n) = BPM;
per_frame_init_14=    index += 1;
per_frame_init_15=  );
per_frame_init_16=sig+=1);
per_frame_init_17=
per_frame_init_18=pi = 3.1416;
per_frame_init_19=OCTAVE = (num_res) * log(2) / log (MAXBPM / MINBPM);
per_frame_init_20=
per_frame_init_21=prog = 0;
per_frame_init_22=bindex = rand(8);
per_frame_init_23=count5 = rand(8);
per_frame_1=dt = min (1/fps,0.1) ; //Stability !
per_frame_2=dec_f = 0.8; dec_m = 1 - 4*dt; dec_s = 1 - dt;
per_frame_3=
per_frame_4=beat = max (max (bass, mid), treb); 
per_frame_5=avg = avg*dec_s + beat*(1-dec_s);
per_frame_6=is_beat = above(beat, .5+avg+peak) * above (time, t0+.25);
per_frame_7=t0 = is_beat*time + (1-is_beat)*t0;
per_frame_8=peak = is_beat * beat + (1-is_beat)*peak*dec_m;
per_frame_9=bindex = (bindex + is_beat) %8;
per_frame_10=bindex2 += is_beat*!bindex;
per_frame_11=q24 = is_beat;
per_frame_12=
per_frame_13=
per_frame_14=//Vol delay chain 
per_frame_15=vol = (bass+mid+treb);
per_frame_16=tr2  += vol*dt;
per_frame_17=q6 = tr2;
per_frame_18=
per_frame_19=vol_=vol_*0.8 + 0.2*vol;
per_frame_20=tvol = tvol*0.8 + 0.2*(vol-vol_);
per_frame_21=n = 50100; loop (100, gmegabuf (n) = gmegabuf (n-1); n -= 1; ); gmegabuf (50000) = tvol;
per_frame_22=q1 = vol-vol_;
per_frame_23=
per_frame_24=q5 = 0.025*sin(time*0.17);
per_frame_25=monitor = q6;
per_frame_26=
per_frame_27=
per_frame_28=q8 = sin(tr2*0.078);
per_frame_29=q9 = sin(tr2*0.019);
per_frame_30=
per_frame_31=wx += q8*dt/2;
per_frame_32=wy += (1+q9)*dt/2;
per_frame_33=q18 = wx;
per_frame_34=q19 = wy;
per_frame_35=q32=aspecty;
per_pixel_1=warp = .0; rot = .0;
per_pixel_2=
per_pixel_3=zoom = 0.99+ 0.06*abs(pow(gmegabuf(50000+rad*30),1));
per_pixel_4=zoom -= -q5*((sin(ang*3+q6*0.2)<0)-0.5);
per_pixel_5=
per_pixel_6=dx = q8*(1-rad*2)*0.003;
per_pixel_7=dy = q9*(1-rad*2)*0.003;
warp_1=`shader_body
warp_2=`{
warp_3=`float2 dither_uv = uv_orig*texsize.xy*texsize_noise_lq.zw + rand_frame.xy;
warp_4=`float2 udith = tex2D(sampler_noise_lq,uv*4+rand_frame)-0.5;
warp_5=`ret= tex2D( sampler_main, uv + udith*0.002);
warp_6=`
warp_7=`ret += (ret.xyz - GetBlur1(uv))*0.4;
warp_8=`ret *= 0.91;
warp_9=`
warp_10=`ret += (tex2D(sampler_noise_lq, dither_uv).xyz-0.5).r*0.02 * saturate(1-treb_att);
warp_11=`
warp_12=`ret = lerp(ret.xyz, 1*lum(ret.xyz), 0.03)*(0.92-0.2*lum(GetBlur1(uv)));
warp_13=`
warp_14=`//ret = 0;
warp_15=`}
comp_1=`#define sat saturate
comp_2=`float z, z0, w0, radi;
comp_3=`float2 uv1, uv2;
comp_4=`static const int anz = 30;
comp_5=`static const float2 ver = texsize.zw*float2(q8*0.1,1);
comp_6=`
comp_7=`shader_body {
comp_8=`//WASSER
comp_9=`uv1 = uv-float2(0.5,0.6);
comp_10=`float z = .3/(uv1.y);
comp_11=`float2 rs0 = float2 (uv1.x * z, z);
comp_12=`float2 rs = (rs0 + float2 (0,time));
comp_13=`float3 water = tex2D(sampler_noise_hq,rs)+tex2D(sampler_noise_hq,rs*2+time*0.3)/2-0.75;
comp_14=`float2 uv_wat = uv+water*0.03/z;
comp_15=`
comp_16=`float mask = saturate(2/z)*(rand_preset.x > 0.3);
comp_17=`
comp_18=`uv = lerp (uv,uv_wat,mask);
comp_19=`float3 shine = GetPixel(uv); radi = 1;
comp_20=`
comp_21=`for (int n=1; n <= anz;  n++)
comp_22=`{ 
comp_23=`  shine = shine+0.5*(1-1.0*n/anz)*GetBlur1(frac(uv+radi*ver));
comp_24=`radi += 8;
comp_25=`}
comp_26=`ret = pow(shine/1.5*(1-mask*0.7),.8);
comp_27=`
comp_28=`
comp_29=`//MilkDrop3 Color Mode:
comp_30=`ret /= float3(-1.4,-1.5,0.6);
comp_31=`}
[PRESET2_END]
