shape_1_per_frame1=i=2*instance;    
shape_1_per_frame2=
shape_1_per_frame3=sample=instance/1024;    p=q1*3.14*sample+.4*time;
shape_1_per_frame4=
shape_1_per_frame5=x=gmegabuf(i);   y=gmegabuf(i+1);
shape_1_per_frame6=
shape_1_per_frame7=zoom=.2+.03*q1*(1+.5*sin(.1*time));
shape_1_per_frame8=
shape_1_per_frame9=x= .5+.01*zoom*x/q6;      y= .5+.01*zoom*y;
shape_1_per_frame10=
shape_1_per_frame11=rad=rad*zoom*(1+.6*sin(p))/(1+.05*q1); 
shape_1_per_frame12=
shape_1_per_frame13=r2=.5+.3*sin(p);
shape_1_per_frame14=g2=.5-.3*sin(p);
per_frame_1=dec_med = pow (0.7, 30/fps);
per_frame_2=dec_slow = pow (0.99, 30/fps);
per_frame_3=beat = max (max (bass, mid), treb); 
per_frame_4=
per_frame_5=beat = bass+mid+treb;
per_frame_6=beat = beat*beat;
per_frame_7=
per_frame_8=avg = avg*dec_slow + beat*(1-dec_slow);
per_frame_9=is_beat = above(beat, 1.2*avg+peak) * above (time, t0+.2);
per_frame_10=t0 = is_beat*time + (1-is_beat)*t0;
per_frame_11=peak = is_beat * beat + (1-is_beat)*peak*dec_med;
per_frame_12=index = (index + is_beat) %8;
per_frame_13=indexa = (indexa + is_beat) %5;
per_frame_14=index2 = (index2 + is_beat*bnot(index))%2;
per_frame_15=
per_frame_16=q20 = avg;
per_frame_17=q21 = beat;
per_frame_18=q22 = peak;
per_frame_19=q23 = index;
per_frame_20=q24 = is_beat;
per_frame_21=q26 = bass_att + mid_att + treb_att + 1;
per_frame_22=q27 = index + 1;
per_frame_23=q28 = -index2 + indexa/5;
per_frame_24=q29 = index2;
per_frame_25=monitor = q29;
per_frame_26=k1 =  is_
per_frame_27=beat*equal(index%2,0);
per_frame_28=p1 =  k1*(p1+1) + (1-k1)*p1;
per_frame_29=p2 = dec_med * p2+ (1-dec_med)*p1;
per_frame_30=rott = p2 * 3.1416/4;
per_frame_31=
per_frame_32=q1 = cos(rott);
per_frame_33=q2 = sin(rott);
per_frame_34=q3 = -q2;
per_frame_35=q4 = q1;
per_frame_36=
per_frame_37=ds = ds*dec_med + q24*(1-dec_med);
per_frame_38=q25 = q24;
per_frame_39=//q25 = above(ds,.5);
per_frame_40=
per_frame_41=q10 = above (q2,.1);
per_frame_42=
per_frame_43=t_rel = time*8;
per_frame_44=//q25 = below((t_rel)-int(t_rel),.2);
per_frame_45=
per_frame_46=
per_frame_47=p3 = p3*dec_med + (1-dec_med) * (200*index + .0*q26);
per_frame_48=q30 = p3 ;
per_frame_49=
per_frame_50=p4 = dec_med*p4 + (1-dec_med)*q27;
per_frame_51=q31 = p4;
per_frame_52=
per_frame_53=zoom = 1.01;
per_frame_54=warp = 0;
warp_1=`#define sat saturate
warp_2=`#define snh sampler_noise_hq
warp_3=`float2 uv0, uv1, uv2, uv3, uvd;
warp_4=`
warp_5=`float2 noise (float2 uvi) {uvi+= time*0.001;
warp_6=`return tex2D(snh,uvi) +tex2D(snh,uvi*2)/2 +tex2D(snh,uvi*5)/5-1;}
warp_7=`
warp_8=`shader_body {
warp_9=`uv0 = uv;
warp_10=`uv1 = uv-.5;
warp_11=`float k = 16*lum(GetBlur1(uv_orig))*(3.14);
warp_12=`
warp_13=`uv3 = mul(uv1,float2x2(cos(k),sin(k),-sin(k),cos(k)));
warp_14=`uvd = .25*lum(GetBlur1(uv_orig))*uv3;
warp_15=`uv += uvd;
warp_16=`float3 crisp = tex2D(sampler_fw_main,uv);
warp_17=`float2 diff = (uv-uv_orig);
warp_18=`crisp = lerp (crisp, GetPixel(uv_orig+2*diff), 0.5);
warp_19=`
warp_20=`ret = crisp * (1-0.2*lum(GetBlur1(uv)))- 0.1 *rad*rad;;
warp_21=`ret = ret*float3(1,1,0) - 0.01;
warp_22=`
warp_23=`uv = uv1*aspect.xy+0.5;
warp_24=`uv2 = uv+noise(uv/2)*0.07;
warp_25=`ret.b = exp(- 12*abs(0.3-uv2.x)) * (1-pow(uv1.y*2.5,2))*0.4; 
warp_26=`ret.b *= 1+pow(tex2D(sampler_noise_lq,uv*0.1+noise(uv2+time*.0019)*.004).r,3);
warp_27=`}
comp_1=`shader_body
comp_2=`{
comp_3=`  rad = pow(rad,0.7)*1;
comp_4=`  float2 ang_hq = atan2(uv.x-0.5,uv.y-0.5) - rad*q1;
comp_5=`
comp_6=`
comp_7=`  float ang2 = frac(ang_hq/6.28*5 + q2);
comp_8=`  ang2 = abs(ang2) ;
comp_9=`  float2 uv2 = 0.5 + rad*0.5*float2(cos(ang2),sin(ang2));    
comp_10=`
comp_11=`  uv = uv2;
comp_12=`    ret = tex2D(sampler_main, uv).xyz;
comp_13=`    ret *= 1.00; //gamma
comp_14=`//MilkDrop3 Color Mode:
comp_15=`ret /= float3(2.0,1.3,0.4);
comp_16=`//MilkDrop3 Burn Mode:
comp_17=`ret = lerp(ret,2,GetPixel(uv).z*1.36);
comp_18=`}

