per_frame_182=//suny = -0.3 + 0.3*cos(0.4*time);
per_frame_183=sunx = 0 + 0*0.03*sin(0.4*time);
per_frame_184=suny= 0 + 0*0.04*cos(0.23*time);
per_frame_185=q31 = sunx;
per_frame_186=q32 = suny;
warp_1=`#define tex sampler_pattern_023
warp_2=`sampler tex;
warp_3=`
warp_4=`shader_body
warp_5=`{
warp_6=`
warp_7=`float2 xy1=0;
warp_8=`float2 xymod=uv-.5;
warp_9=`
warp_10=`xy1.x=sin(time/3)*xymod.x-cos(time/3)*xymod.y/3;
warp_11=`xy1.y=cos(time/3)*xymod.x+sin(time/3)*xymod.y;
warp_12=`
warp_13=`uv=xy1+aspect.xy;
warp_14=`
warp_15=`ret = tex2D(tex, uv ).xyz;
warp_16=`
warp_17=`//MilkDrop3 Sharpness Mode:
warp_18=`ret = lerp(ret, tex2D(sampler_main,uv_orig), 0.3);
warp_19=`}
comp_1=`shader_body
comp_2=`{
comp_3=`
comp_4=`
comp_5=`    ret = tex2D(sampler_main, uv).xyz;
comp_6=`    float L = lum(ret);
comp_7=`    float bw = saturate(cos(L*17 + 3 + uv.x*30)*30 - 21);
comp_8=`    float L2 = lum(GetBlur1(uv));
comp_9=`    float bw2 = saturate(cos(L*17 + 3 + uv.x*30)*3 - 2.7);
comp_10=`
comp_11=`    ret = float3(2.8,2.8,1.2)*ret.x +
comp_12=`          float3(2,0.4,2)*ret.y + 
comp_13=`          float3(0.1,1.3,1.2)*ret.z;
comp_14=`    ret *= 0.37;
comp_15=`
comp_16=`    ret = ret*ret * (1 + bw2*4);
comp_17=`
comp_18=`ret /= float3(0.7,0.7,1.6);
comp_19=`ret*=3;
comp_20=`//MilkDrop3 Color Mode:
comp_21=`ret /= float3(1.2,1.4,1.1);
comp_22=`}

