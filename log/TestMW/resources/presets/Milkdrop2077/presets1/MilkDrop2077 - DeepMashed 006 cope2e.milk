per_frame_1=wave_a = 0;
per_frame_2=//decay = 0.1;
per_frame_3=
per_frame_4=vol = (bass_att + treb_att + mid_att)*.333333;
per_frame_5=
per_frame_6=tic = min(time-tin,.1);
per_frame_7=tin = time;
per_frame_8=
per_frame_9=ra = 10;
per_frame_10=treb_avg = tic*(treb_avg*(1/tic - ra) + ra*treb);
per_frame_11=mid_avg = tic*(mid_avg*(1/tic - ra) + ra*mid);
per_frame_12=bass_avg = tic*(bass_avg*(1/tic - ra) + ra*bass);
per_frame_13=vav = tic*(vav*(1/tic - ra) + ra*(bass+treb+mid)*.33333);
per_frame_14=
per_frame_15=tt = tt + tic*treb_avg;
per_frame_16=mt = mt + tic*mid_avg;
per_frame_17=bt = bt + tic*bass_avg;
per_frame_18=
per_frame_19=sp = abs(vav - slide)*.1;
per_frame_20=slide = if(above(slide,vav),slide-tic*sp,slide+tic*sp) + (1-toc)*vav;
per_frame_21=toc = 1;
per_frame_22=
per_frame_23=vt = vt + tic*slide;
per_frame_24=
per_frame_25=q1 = bt;
per_frame_26=q2 = mt;
per_frame_27=q3 = tt;
per_frame_28=q4 = slide*1;
per_frame_29=q5 = vt*.05 + 150;
per_frame_30=
per_frame_31=q6 = .01;//tic;
warp_1=`float2 uv0, uv1;
warp_2=`float d;
warp_3=`static const float2 par = float2 (q1,q2);
warp_4=`
warp_5=`shader_body
warp_6=`{
warp_7=`uv0 = 3*uv;
warp_8=`uv1 = uv0;
warp_9=`d= length(uv1);
warp_10=`
warp_11=`for ( int n=0; (n <5) && (n<14*d) ; n++ )
warp_12=`{
warp_13=`uv1 += cos(uv1.yx+par.yx) + uv0 - par;
warp_14=`d=frac(.08*length (uv1)*2);
warp_15=`}
warp_16=`
warp_17=`ret= d*float3 (1.8,1.7,2.8);
warp_18=`}
comp_1=`// (MWmod) sampler sampler_rand00;
comp_2=`float cross, noise, z, mask, scale;
comp_3=`float2 rs, rs0, uv1, uv2, uv3, uv4, uvt;
comp_4=`float3 ret1,ret2,struc,flash2;
comp_5=`
comp_6=`float3 Get1 (float2 uvi){return GetPixel (uvi);}
comp_7=`
comp_8=`shader_body {
comp_9=`//MilkDrop3 Multiplicate Mode:
comp_10=`uv = 1- abs( frac((uv-.5)*1.5 * 0.5 ) * 2 - 1.0 );
comp_11=`
comp_12=`
comp_13=`
comp_14=`
comp_15=`
comp_16=`
comp_17=`float iter = 4+10*saturate (texsize.x/1024*uv.y);
comp_18=`ret = Get1(uv); ret1 = ret; ret2 = ret;
comp_19=`for (int n =1; n < 10; n++) {
comp_20=`  ret1 = max(ret1,Get1(uv+texsize.zw*float2(n,0)));
comp_21=`//  ret2 = max(ret2,Get1(uv+texsize.zw*float2(0,n)));
comp_22=`}
comp_23=`struc = ret1;
comp_24=`mask = saturate(1-16*lum(struc));
comp_25=`struc *= .06/(length(rad/2-length((ret1+ret2*0.2))+0.6));
comp_26=`
comp_27=`//BACK
comp_28=`//uv4 = (uv-0.5) * (1+0*exp(-pow ((uv.x-0.5)*3-2*q14,2)))+0.5;
comp_29=`
comp_30=`
comp_31=`noise = (tex2D(sampler_noise_lq,2*uv4).r+0.25);
comp_32=`noise *= 1-tex2D(sampler_noise_lq,2*uv4+texsize.zw*-4).r;
comp_33=`// (MWmod) noise *= (0.5+ 0.5*(lum(tex2D(sampler_rand00,uv)) > 0.5))*2;
comp_34=`ret = 0.05+noise*0.5*(1-rad);  // texLum (orig *0.5)
comp_35=`
comp_36=`ret *= saturate(1-lum(GetBlur2(uv4-0.13))*8);
comp_37=`ret = lerp (ret,struc, !mask);
comp_38=`
comp_39=`//NEW FLASH
comp_40=`for (int n = 1; n <= 3; n++)
comp_41=`{
comp_42=`  uvt = tex2D(sampler_noise_lq,n*0.074+q25).xy;
comp_43=`  uv3 = uv4-uvt;
comp_44=`  uv3 = mul (uv3,float2x2 (q23,q24,-q24,q23));
comp_45=`  cross = (0.0001+abs (uv3.x+uv3.y) *abs (uv3.x-uv3.y)) * length(uv3);
comp_46=`  flash2 = (3*q22/cross) *GetBlur1(uvt) * (uvt.x < 0.9)* (uvt.x > 0.1)* (uvt.y < 0.9)* (uvt.y > 0.1);
comp_47=`  flash2 += 100000*mask*q22*saturate(1-2*length (uv3-0.1)) *noise*GetBlur1(uvt);
comp_48=`  ret += flash2;
comp_49=`}
comp_50=`//ret = GetPixel(uv);
comp_51=`//ret *= 1.4;  // gamma  (orig 1.4  und  deakt)
comp_52=`//ret /= float3(1.8,-0.8,2.8);
comp_53=`ret /= float3(1.0,1.8,2.1);
comp_54=`//MilkDrop3 Color Mode:
comp_55=`ret /= float3(1.4,1.5,0.3);
comp_56=`//MilkDrop3 Rainbow Mode:
comp_57=`ret *= 1*normalize ((tex2D (sampler_noise_hq,(uv+q4/2)/6)));
comp_58=`}
