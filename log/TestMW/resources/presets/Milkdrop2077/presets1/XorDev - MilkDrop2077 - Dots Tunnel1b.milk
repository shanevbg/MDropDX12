shape_0_init1=i=0;
shape_0_init2=loop (1024,
shape_0_init3=  z=rand(1)+.1;
shape_0_init4=  megabuf(i+2) = z;
shape_0_init5=  megabuf(i)  = (rand(1)-0.5)/z;
shape_0_init6=  megabuf(i+1)= (rand(1)-.5)/z;
shape_0_init7=i+=3;);
shape_0_per_frame1=i=instance;
shape_0_per_frame2=k1 = i/num_inst;
shape_0_per_frame3=zmax = 7;
shape_0_per_frame4=speed=.15;
shape_0_per_frame5=
shape_0_per_frame6=z=megabuf(3*i+2);
shape_0_per_frame7=x = megabuf(3*i)/z+.5;
shape_0_per_frame8=y = megabuf(3*i+1)/z*reg32+0.5;
shape_0_per_frame9=
shape_0_per_frame10=rad = .022/(z*zmax)*reg32 ;
shape_0_per_frame11=
shape_0_per_frame12=out=(x>1)||(x<0)||(y>1)||(y<0)||(z<0);
shape_0_per_frame13=if (out,
shape_0_per_frame14=  megabuf(3*i)= (rand(2)-1); //x
shape_0_per_frame15=  megabuf(3*i+1)=(rand(2)-1); //y
shape_0_per_frame16=  megabuf(3*i+2)=1;
shape_0_per_frame17=,
shape_0_per_frame18=  megabuf(i*3+2)-=speed/fps;
shape_0_per_frame19=);
shape_0_per_frame20=
shape_0_per_frame21=a=1-pow(z,4);
shape_0_per_frame22=a*=0.6;
warp_1=`shader_body
warp_2=`{
warp_3=`   //Shader By XorDev (x.com/XorDev), ported to MilkDrop by MilkDrop2077  
warp_4=`        // Setup coordinates
warp_5=`        float2 r = aspect.xy;
warp_6=`        float2 p = (uv_orig * 2.0 - 1.0) * r / r.y;
warp_7=`        float t = time;
warp_8=`        
warp_9=`        // Initialize output color
warp_10=`        float4 o = float4(0,0,0,0);
warp_11=`        
warp_12=`        // Main spiral effect loop
warp_13=`        for(float i = 1.0; i <= 9.0; i += 1.0) {
warp_14=`            // Calculate polar coordinates
warp_15=`            float angle = atan2(p.y, p.x) + i +time/8;
warp_16=`            float radius = log(length(p)) - t/i + i*i;
warp_17=`            
warp_18=`            // Create spiral pattern
warp_19=`            float2 spiral = sin(float2(angle, radius) * i) - 0.5;
warp_20=`            float dist = length(min(spiral, 1.0));
warp_21=`            
warp_22=`            // Color bands
warp_23=`            float4 color_band = (cos(i + float4(6,1,2,3)) + 1.0) / dist;
warp_24=`            o += color_band;
warp_25=`        }
warp_26=`        
warp_27=`        // Final color processing
warp_28=`        o = tanh(o*o/400.0);
warp_29=`        
warp_30=`        // Output with audio reactivity
warp_31=`        float audio = bass_att * 0.3 + treb_att * 0.1;
warp_32=`        ret = float4(o.rgb * (1.0 + audio), 1.0);
warp_33=`    
warp_34=`}
comp_1=`shader_body
comp_2=`{
comp_3=`    ret = GetPixel(uv);
comp_4=`}
