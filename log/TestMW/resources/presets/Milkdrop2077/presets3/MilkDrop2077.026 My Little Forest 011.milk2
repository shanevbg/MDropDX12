code_1=rotate=time*0.0625;
code_2=new_scale=max(0.30, (0.16 + 0.55*bass_att))*0.78 + sin(time/1.60*6.283*speed)*0.02;
code_3=sx=new_scale;
code_4=sy=new_scale;
[SPRITE1_END]
