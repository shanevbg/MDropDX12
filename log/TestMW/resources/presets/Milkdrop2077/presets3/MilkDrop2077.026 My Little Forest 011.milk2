SpriteBurn=1
SpriteX=-0.067500
SpriteY=0.005000
SpriteSX=-0.480000
SpriteSY=-0.480000
SpriteRot=0.000000
SpriteSpeed=0.000000
SpriteRepeatX=1.000000
