shape_1_per_frame1=sample=instance/num_inst;
shape_1_per_frame2=
shape_1_per_frame3=///// Sphere
shape_1_per_frame4=r1=1;
shape_1_per_frame5=q10= -1+2*sample;
shape_1_per_frame6=q11=200*sample;
shape_1_per_frame7=
shape_1_per_frame8=my_x = sqrt(r1*r1-q10*q10)*cos(q11);
shape_1_per_frame9=my_y = sqrt(r1*r1-q10*q10)*sin(q11);
shape_1_per_frame10=my_z = q10+3*sin(2*q1+time)*sin(.5*sample)*my_x*my_y;
shape_1_per_frame11=
shape_1_per_frame12=
shape_1_per_frame13=///// drago
shape_1_per_frame14=t1 = 10*sample+time*.1;
shape_1_per_frame15=x1 = .5*(.6*sin (7*t1)+.4*sin (4.3*t1)) ;
shape_1_per_frame16=y1 = .5*(.6*cos (3.3*t1)+.4*cos (6.9*t1))* sin (-100+200*sample) ;
shape_1_per_frame17=z1 = .5*(.6*cos (4.1*t1)+.4*cos (6.9*t1)) * cos (-50+100*sample) ;
shape_1_per_frame18=
shape_1_per_frame19=
shape_1_per_frame20=my_x = if(above(sample,.45)*below(sample,.55),x1,my_x);
shape_1_per_frame21=my_y = if(above(sample,.45)*below(sample,.55),y1,my_y);
shape_1_per_frame22=my_z = if(above(sample,.45)*below(sample,.55),z1,my_z);
shape_1_per_frame23= 
shape_1_per_frame24=
shape_1_per_frame25=/////// rotations... by flexi
shape_1_per_frame26=
shape_1_per_frame27=d = 2; 
shape_1_per_frame28=zoom = 1;
shape_1_per_frame29=
shape_1_per_frame30=w3 = .6*sin(q1);
shape_1_per_frame31=w2 = .6*sin(q3);
shape_1_per_frame32=w1 = q2;
shape_1_per_frame33=
shape_1_per_frame34=x1 = cos(w1)*my_x + sin(w1)*my_y;
shape_1_per_frame35=y1 = -sin(w1)*my_x + cos(w1)*my_y;
shape_1_per_frame36=z1 = my_z;
shape_1_per_frame37=
shape_1_per_frame38=x2 = cos(w2)*x1 + sin(w2)*z1;
shape_1_per_frame39=z2 = -sin(w2)*x1 + cos(w2)*z1;
shape_1_per_frame40=y2 = y1;
shape_1_per_frame41=
shape_1_per_frame42=y3 = cos(w3)*y2 + sin(w3)*z2;
shape_1_per_frame43=z3 = -sin(w3)*y2 + cos(w3)*z2;
shape_1_per_frame44=x3 = x2;
shape_1_per_frame45=
shape_1_per_frame46=// perspective calculation
shape_1_per_frame47=
shape_1_per_frame48=l = sqrt(x3*x3 + y3*y3);
shape_1_per_frame49=w = atan2(x3,y3);
shape_1_per_frame50=p = tan(asin(1) + atan2(d+z3,l));
shape_1_per_frame51=d = sqrt(x3*x3 + y3*y3 + (z3+d)*(z3+d));
shape_1_per_frame52=
shape_1_per_frame53=my_x = zoom*sin(w)*p;
shape_1_per_frame54=my_y = zoom*cos(w)*p;
shape_1_per_frame55=
shape_1_per_frame56=x = 0.5 + my_x/q6;
shape_1_per_frame57=y = 0.5 + my_y/q5;
shape_1_per_frame58=
shape_1_per_frame59=
shape_1_per_frame60=////////// sphere
shape_1_per_frame61=rad=rad/d;
shape_1_per_frame62=b=sin(3.14*sample+.3*time);
shape_1_per_frame63=r=.9*b;
shape_1_per_frame64=g=.9*b;
shape_1_per_frame65=b2=.9*b;
shape_1_per_frame66=r2=.9*b2;
shape_1_per_frame67=g2=.9*b2;
shape_1_per_frame68=border_r=r;
shape_1_per_frame69=border_g=g;
shape_1_per_frame70=border_b=b;
shape_1_per_frame71=
shape_1_per_frame72=
shape_1_per_frame73=////// drago
shape_1_per_frame74=
shape_1_per_frame75=rad= if(above(sample,.45)*below(sample,.55), .02*rad+12*rad*(sample-.45), rad);
shape_1_per_frame76=ang= if(above(sample,.45)*below(sample,.55), 300*(sample-.55)*time,0);
shape_1_per_frame77=sides= if(above(sample,.45)*below(sample,.55), 14*(1-10*(sample-.45)),20);
shape_1_per_frame78=
shape_1_per_frame79=r= if(above(sample,.45)*below(sample,.55),sample,r);
shape_1_per_frame80=g= if(above(sample,.45)*below(sample,.55),sample,g);
shape_1_per_frame81=b= if(above(sample,.45)*below(sample,.55),sample,b);
shape_1_per_frame82=r2= if(above(sample,.45)*below(sample,.55),.1,r2);
shape_1_per_frame83=g2= if(above(sample,.45)*below(sample,.55),.1,g2);
shape_1_per_frame84=b2= if(above(sample,.45)*below(sample,.55),.1,b2);
shape_1_per_frame85=
shape_1_per_frame86=a2= if(above(sample,.45)*below(sample,.55),.6,a2);
shape_1_per_frame87=border_a= if(above(sample,.45)*below(sample,.55),0,.5);
