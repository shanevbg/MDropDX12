shape_1_per_frame4=qx=x-.5;qy=y-.5;qrad=sqrt(sqr(qx)-sqr(qy));
shape_1_per_frame5=qbal=(bal*max(qx,qrad));qvol=vol*max(qrad,qy);
shape_1_per_frame6=dir*=if(above(bass,1.3),-1,1)*div;
shape_1_per_frame7=d=0.2*instance/n;//bass*0.4;
shape_1_per_frame8=ra=mid*time*3.1824*treb; 
shape_1_per_frame9=
shape_1_per_frame10=ti2=time*samp2-int(time*samp2)*(1-sample);
shape_1_per_frame11=rad=rad+d*abs(qrad*2*ti2+sample);
shape_1_per_frame12=x=.5+qbal+dir*cos(ra)*d*.005-dir*sin(-d+0.5*mid*time)*d*10;
shape_1_per_frame13=y=.5+(qvol*qbal*(1+samp2))+dir*sin(ra)*d*.005+dir*cos(-d+0.5*mid*time)*d*10;
shape_1_per_frame14=additive=even*bhit;
shape_1_per_frame15=
shape_1_per_frame16=border_r=1/(ti2*2-1);border_g=1/(ti2*2-1+qvol-vol-bhit);;
