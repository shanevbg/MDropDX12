per_frame_init_1=// A grayish blob
per_frame_init_2=// 2007.02.01 - raron
per_frame_init_3=
per_frame_init_4=q1 = 0.4;
per_frame_init_5=q2 = 0.4;
per_frame_init_6=
per_frame_init_7=q16=22/7;
per_frame_1=q3 = 32 + 32 * cos(time * 4);
per_frame_2=q4 = 2 + 24 * sin(time* 1.4);
per_frame_3=q5 = 32 - 32 * sin(time * 2.1);
per_frame_4=q6 = 24 + 24 * cos(time * 1.3);
per_frame_5=bhit=above(bass*.95,max(bass_att,.5));
per_frame_6=bs=bass_att*(1-.3*bhit)+(.3*bass*bhit);
per_frame_7=thit=above(treb*.95,max(treb_att,.5));
per_frame_8=ts=treb_att*(1-.3*thit)+(.3*treb*thit);
per_frame_9=mhit=above(mid,max(.2,mid_att));
per_frame_10=ms=mid_att*(1-.3*mhit)+(.3*mid*mhit);
per_frame_11=pie=q16;pi2=2*pie;;
per_frame_12=lft=(time*9+bs+ms)/pi2;
per_frame_13=lfos=sin(lft); lfoc=cos(lft);
per_frame_14=q12=lfos; q13=lfoc;
per_frame_15=zoom = 0.9 + bs * 0.05;
per_frame_16=rot = 0.2 *ms- 0.2 * bs;
per_frame_17=wrap=0;
per_frame_18=wave_a*=bhit-sample;wave_usedots=mhit-1;
per_frame_19=wave_x+=5; wave_x-=int(wave_x);
per_frame_20=wave_mystery=(ts*2-1)*equal(frame%13,0);
per_frame_21=//dx=q19;
per_frame_22=wq=max(0,wq+int(wave_a+.1)); qw=(time-int(time))*5;wq=max(wq-qw,0);
per_frame_23=qr=pi2*(rand(15)*.1)*tan(wq);wave_a+=qr;wave_a=min(1,max(0,wave_a));
per_frame_24=//wave_b*=(1-abs(y-.5)+(.25*(max(0,qy)*y)));
per_pixel_1=qx=x-.5; qy=y-.5; aqrad=((rad +.1*q12)*2-1); qrad=aqrad*if(below(aqrad,0),.1,1); zoom = zoom *.9+ (qrad*2-1)* 0.41;
per_pixel_2=rot-=zoom;
per_pixel_3=q19=(1-abs(qy)+(.25*(max(0,qy)*y)));
per_pixel_4=dx=q19;wave_a*=abs(qx)+.5*sin(time*9-mid_att-mid-dx);
per_pixel_5=wave_x*=1-abs(qx+.2*dx);wave_y*=1+.3*cos(wave_x*(qy))
warp_1=`sampler sampler_rand02;
warp_2=`float4  texsize_rand02;    // ...it's smart enough to get it from just this.
warp_3=`shader_body
warp_4=`{
warp_5=`    // sample previous frame
warp_6=`    uv = uv_orig;
warp_7=`    float3 main = tex2D( sampler_main, uv ).xyz;
warp_8=`
warp_9=`    float zoom = 1+main.x*.1;
warp_10=`    float rot = (main.y-main.z)*.1;
warp_11=`    float2 zcr = float2(.5,.5);
warp_12=`    float2 cr = float2(.5+q7*.3,.5+q6*.3);
warp_13=`    float2 newuv = uv;
warp_14=`
warp_15=`    ///////////////////rotation////////////////
warp_16=`    newuv = uv - cr;
warp_17=`    float s = sin(rot);
warp_18=`    float c = cos(rot);
warp_19=`    newuv = float2( (uv.x-cr.x)*c-(uv.y-cr.y)*s , (uv.x-cr.x)*s+(uv.y-cr.y)*c  );
warp_20=`    newuv = newuv + cr;
warp_21=`    ///////////////////rotation////////////////
warp_22=`
warp_23=`    ///////////////////zoom////////////////
warp_24=`    newuv = newuv-zcr;
warp_25=`    newuv = newuv * zoom;
warp_26=`    newuv= newuv+zcr;
warp_27=`    ///////////////////zoom////////////////
warp_28=`
warp_29=`
warp_30=`    float3 colorwarp = tex2D( sampler_main, newuv ).xyz *1.02;
warp_31=`
warp_32=`    float3 color = tex2D(sampler_rand02, (uv-0.5)*0.2 + 0.5 ).xyz;
warp_33=`    ret = ( (  colorwarp ) );
warp_34=`    // darken (decay) over time
warp_35=`    ret *= 0.98; //or try: ret -= 0.004;
warp_36=`}
comp_1=`float tim, tsin, tcos, psin, pcos;
comp_2=`sampler sampler_fw_rand01, sampler_pw_rand02, sampler_fc_rand04, sampler_pc_rand03;
comp_3=`float3 li1, li2, li3, li4, cmin, cmix, cmcos;
comp_4=`
comp_5=`
comp_6=`shader_body
comp_7=`{
comp_8=`tim=(min(q17,time)/(18+(2/(mid_att+treb))));   
comp_9=`tcos=cos(tim); 
comp_10=`tsin=sin(tim); 
comp_11=`psin=1-(1-progress);
comp_12=`pcos=(1-progress);
comp_13=`
comp_14=`    // sample previous frame
comp_15=`      // sample jpegs
comp_16=`li1 = tex2D(sampler_fw_rand01, uv_orig ).xyz*.5+.5*tcos*psin;   
comp_17=`li2 = tex2D(sampler_pw_rand02, uv_orig ).xyz*.5+.5*tsin*psin;   
comp_18=`li3 = tex2D(sampler_pc_rand03, uv_orig ).xyz*.5+.5*tcos*pcos;   
comp_19=`li4 = tex2D(sampler_fc_rand04, uv_orig ).xyz*.5+.5*tsin*pcos;
comp_20=`      //mix em
comp_21=`
comp_22=`cmix=max(li1,max(li2,max(li3,li4)));
comp_23=`cmin=max((min(li2,li4)*.5)*tsin,(min(li1,li3)*.5)*tcos);
comp_24=`cmcos = (1.5-rad)+5.5+(.5*tcos)+float3(1/3,2/3,3/3);
comp_25=`cmcos.x -=int(cmcos.x); 
comp_26=`cmcos.y -=int(cmcos.y); 
comp_27=`cmcos.z -=int(cmcos.z);
comp_28=` 
comp_29=`ret =1.1*(GetMain (uv))*(.2*lerp(cmix,1-cmin,rad*.25+.019*max(psin,max(pcos,max(tsin,tcos)))));
comp_30=`ret-=.365;
comp_31=` ret*=-.2+ret+(GetBlur3 (uv));;
comp_32=`
comp_33=`ret=ret*.5-.05*tcos;
comp_34=`
comp_35=`  ret +=.35*(GetBlur3 (uv))-.264*cmin.xyz*(cmcos+.4-ret);
comp_36=` 
comp_37=`    // darken (decay) over time
comp_38=`    //ret *= (0.65+.01351*cmcos); //or try: ret -= 0.004;
comp_39=`    //add em//+(GetBlur3 (uv));
comp_40=`   ret+= .3013*tex2D( sampler_main, uv ).xyz/(ret*2);
comp_41=`   ret -=.134*cmix-(.164*ret);
comp_42=`    
comp_43=`}
