shape_3_per_frame2=bhit=above(bass,max(1.4,bass_att));sample=instance+1/n; sample-=int(sample);samp2=pairs/(n*.5);
shape_3_per_frame3=bal=reg08; vol=reg07;div=even*2-1;
shape_3_per_frame4=qx=x-.5;qy=y-.5;qrad=sqrt(sqr(qx)-sqr(qy));
shape_3_per_frame5=qbal=(bal*max(qx,qrad));qvol=vol*max(qrad,qy);
shape_3_per_frame6=dir*=if(above(bass,1.3),-1,1)*div;
shape_3_per_frame7=d=0.2*instance/n;//bass*0.4;
shape_3_per_frame8=ra=mid*time*3.1824*treb; 
shape_3_per_frame9=
shape_3_per_frame10=ti2=time*samp2-int(time*samp2)*(1-sample);
shape_3_per_frame11=rad=rad+d*abs(qrad*2*ti2+sample);
shape_3_per_frame12=x=.5+qbal+dir*cos(ra)*d*.005-dir*sin(-d+0.5*mid*time)*d*10;
shape_3_per_frame13=y=.5+(qvol*qbal*(1+samp2))+dir*sin(ra)*d*.005+dir*cos(-d+0.5*mid*time)*d*10;
shape_3_per_frame14=additive=even*bhit;
shape_3_per_frame15=
shape_3_per_frame16=border_r=1/(ti2*2-1);border_g=1/(ti2*2-1+qvol-vol-bhit);;
shape_3_per_frame17=border_b=min(border_r,(1-border_r))+min(border_g,(1-border_g));
shape_3_per_frame18=border_a=(1-additive)*(border_r+border_g+border_b)-int(border_r+border_g+border_b);
shape_3_per_frame19=r=border_b;g=border_r;b=borderg;r2=g;g2=b;b2=r;
shape_3_per_frame20=a=sample*vol+qrad*samp2;
per_frame_1=wave_r = wave_r + 0.3*sin(time*1.254);
per_frame_2=wave_g = wave_g +0.3*sin(time*0.952);
per_frame_3=wave_b = wave_b + 0.3*sin(time*0.824);
per_frame_4=ob_r = 0.5 + 0.4*sin(time*1.324);
per_frame_5=ob_g = 0.5 + 0.4*cos(time*1.371);
per_frame_6=ob_b = 0.5+0.4*sin(2.332*time);
per_frame_7=ib_r = 0.5 + 0.25*sin(time*1.424);
per_frame_8=ib_g = 0.25 + 0.25*cos(time*1.871);
per_frame_9=ib_b = 0.5+0.5*sin(2.273*time);
per_frame_10=volume = 0.15*(bass+bass_att+treb+treb_att+mid+mid_att);
per_frame_11=xamptarg = if(equal(frame%15,0),min(0.5*volume*bass_att,0.5),xamptarg);
per_frame_12=xamp = xamp + 0.5*(xamptarg-xamp);
per_frame_13=xdir = if(above(abs(xpos),xamp),-sign(xpos),if(below(abs(xspeed),0.1),2*above(xpos,0)-1,xdir));
per_frame_14=xaccel = xdir*xamp - xpos - xspeed*0.055*below(abs(xpos),xamp);
per_frame_15=xspeed = xspeed + xdir*xamp - xpos - xspeed*0.055*below(abs(xpos),xamp);
per_frame_16=xpos = xpos + 0.001*xspeed;
per_frame_17=dx = xpos;
per_frame_18=yamptarg = if(equal(frame%15,0),min(0.3*volume*treb_att,0.5),yamptarg);
per_frame_19=yamp = yamp + 0.5*(yamptarg-yamp);
per_frame_20=ydir = if(above(abs(ypos),yamp),-sign(ypos),if(below(abs(yspeed),0.1),2*above(ypos,0)-1,ydir));
per_frame_21=yaccel = ydir*yamp - ypos - yspeed*0.055*below(abs(ypos),yamp);
per_frame_22=yspeed = yspeed - cy
per_frame_23=yspeed + ydir*yamp - ypos - yspeed*0.055*below(abs(ypos),yamp);
per_frame_24=ypos = ypos + 0.001*yspeed;
per_frame_25=dy = ypos;
per_frame_26=adj=time/((40-mid_att-mid-bass+treb)*10);
per_frame_27=zoom = cx;
per_frame_28=echo_alpha=.7+.72*cos(adj)-int(echo_alpha)-.23;
per_frame_29=wrap=int(abs(echo_alpha));
per_frame_30=echo_alpha-=wrap*.5+.5*cos(adj*2-1);
per_frame_31=qez=-cx*(q20*2-1)+.9*sin(adj);
per_frame_32=echo_zoom=max(-1,min(1,qez-int(qez)));
per_frame_33=
per_frame_34=echo_zoom*=100;
per_frame_35=echo_zoom=if(above(echo_zoom+1,1),echo_zoom,1-abs(echo_zoom)*.01);
per_frame_36=monitor=echo_alpha;
per_pixel_1=myzoom = log(sqrt(2)-rad) -0.25;
per_pixel_2=t1=(time/((4+y)-mid_att));qx=x-.5;qy=y-.5;qq=abs(qx)*.5+1*sin(1-(abs(qy)));echo_zoom=echo_zoom+.3*sin(t1*qq);
per_pixel_3=zoom = if(above(rad,0.4),myzoom,(0.5*sqrt(2)-rad));
per_pixel_4=myzoom = myzoom - rot;
per_pixel_5=cx =  cos(myzoom);
per_pixel_6=acho_alpha*=.71+.2*cos(t1*qq);
warp_1=`sampler sampler_rand00;
warp_2=`
warp_3=`
warp_4=`shader_body
warp_5=`{
warp_6=`    // sample previous frame
warp_7=`    //uv = uv_orig;
warp_8=`    float3 main = tex2D( sampler_main, uv_orig).xyz;
warp_9=`
warp_10=`    float zoom = 1+main.x*.1;
warp_11=`    float rot = (main.y-main.z)*.1;
warp_12=`    float2 zcr = float2(.5,.5);
warp_13=`    float2 cr = float2(.5+q7*.3,.5+q6*.3);
warp_14=`    float2 newuv = uv;
warp_15=`
warp_16=`    ///////////////////rotation////////////////
warp_17=`    newuv = uv - cr;
warp_18=`    float s = sin(rot);
warp_19=`    float c = cos(rot);
warp_20=`    newuv = float2( (uv.x-cr.x)*c-(uv.y-cr.y)*s , (uv.x-cr.x)*s+(uv.y-cr.y)*c  );
warp_21=`    newuv = newuv + cr;
warp_22=`    ///////////////////rotation////////////////
warp_23=`
warp_24=`    ///////////////////zoom////////////////
warp_25=`    newuv = newuv-zcr;
warp_26=`    newuv = newuv * zoom;
warp_27=`    newuv= newuv+zcr;
warp_28=`    ///////////////////zoom////////////////
warp_29=`
warp_30=`
warp_31=`    float3 colorwarp = tex2D( sampler_main, newuv ).xyz *1.02;
warp_32=`
warp_33=`    float3 color = tex2D(sampler_rand00, (uv-0.5)*0.2 + 0.5 ).xyz;
warp_34=`    ret = ( (  colorwarp ) );
warp_35=`    // darken (decay) over time
warp_36=`    ret *= 0.98; //or try: ret -= 0.004;
warp_37=`
warp_38=`//   ret = tex2D( sampler_main, uv ).xyz;
warp_39=`    
warp_40=`    // darken (decay) over time
warp_41=`//    ret *= 0.95; //or try: ret -= 0.004;
warp_42=`ret *=.8+ tex2d(sampler_rand00,lerp(uv,uv_orig,.12+.02*q22))-.73*ret;
warp_43=`}
comp_1=`shader_body
comp_2=`{
comp_3=`  float2 uv_flipped = float2(1 - uv.x,uv.y);    // '1' auto-replicates to float2(1,1)
comp_4=`            ret = max( tex2D(sampler_main, uv).xyz, 
comp_5=`                       tex2D(sampler_main, uv_flipped).xyz );
comp_6=`            ret = pow(ret, float3(.88+0.5*(bass-bass_att*treb_att)*sin(time*0.15), 1.12+0.5*(bass-bass_att*mid_att)*sin(time*0.13),1+0.5*(bass-bass_att*treb_att)*sin(time*0.12))); 
comp_7=`}
