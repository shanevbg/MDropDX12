per_frame_1=wave_x = wave_x + 0.1*sin(5*bass);
per_frame_2=wave_y = wave_y + 0.1*sin(5*bass);
per_frame_3=wave_r = wave_r + 1;
per_frame_4=wave_g =wave_g + rand(2);
per_frame_5=wave_b = 0;
per_frame_6=rot = rot + if (above(bass,0), +0.02*sin(6*bass) - 0.025*cos(4.75*bass), 0);
per_pixel_1=zoom = zoom + 0.05*rad;
warp_1=`shader_body
warp_2=`{
warp_3=`
warp_4=`    float2 dither_uv = uv_orig*texsize.xy*texsize_noise_lq.zw*2 + rand_frame.xy;
warp_5=`    uv+= (tex2D(sampler_noise_lq, dither_uv).xy-0.5)*texsize.zw;
warp_6=`
warp_7=`    // PAINTERLY EFFECT:
warp_8=`    float2 t = -0.004 + 0.04*saturate(float2(bass,treb)-1);
warp_9=`    float2 uv2 = uv;
warp_10=`    float2 delta2 = texsize.zw*float2(1,1);
warp_11=`    float3 blurry_color = tex2D( sampler_main, 
warp_12=`        lerp(uv,uv_orig,-1) + delta2 ).xyz;
warp_13=`    uv2.xy += (blurry_color.xy-0.4) * t;
warp_14=`    //uv2.xy -= (blurry_color.zx-0.37) * s;
warp_15=`
warp_16=`    // sample previous frame
warp_17=`    ret = tex2D( sampler_main, uv2 ).xyz;
warp_18=`
warp_19=`    // darken over time
warp_20=`    ret -= 0.0008 + (tex2D(sampler_noise_lq, dither_uv)-0.5)*0.02;    
warp_21=`}
comp_1=`#define base01 sampler_rand01 
comp_2=`#define base02 sampler_main 
comp_3=`sampler sampler_rand01;
comp_4=`
comp_5=`shader_body
comp_6=`{
comp_7=`
comp_8=`float2 uv1 = uv-.5;
comp_9=`
comp_10=`float3 ret1 = tex2D(sampler_main, uv) +0.03*(1-rad);
comp_11=`
comp_12=`
comp_13=`float2 hor = float2 (texsize.z,0);
comp_14=`float2 ver = float2 (0,texsize.w);
comp_15=`float dx = GetPixel (uv-hor) - GetPixel (uv+hor);
comp_16=`float dy = GetPixel (uv-ver) - GetPixel (uv+ver);
comp_17=`float2 dz = float2 (dx,dy);
comp_18=`
comp_19=`uv1 = uv1*0+.3*cos(uv1*2) - dz;;
comp_20=`float dots = saturate(.04/length(uv1));
comp_21=`uv1 = uv1*0+.3*cos(uv1*12) - 9*dz;;
comp_22=`float3 dots2 = saturate(.04/length(uv1));
comp_23=`ret = dots + GetPixel(uv)*10*dots2; //orig *12
comp_24=`
comp_25=`//ret.xyz=sin((ret.xyz+lum(ret1))*M_PI*0.5);
comp_26=`//ret.xyz=sin(cos(ret.xyz*3+ret1.xyz*5.5+_qc.zyx*26*(lum(ret1).xxx*0.1+0.9).xyz)*M_PI*0.5);
comp_27=`//ret.y=sin(cos(ret.y*3+ret1.y*5.5+_qc.y*26*(lum(ret1)*0.1+0.9))*M_PI*0.5);
comp_28=`//ret.z=sin(sin(ret.z*3+ret1.z*5.5+_qc.x*26*(lum(ret1)*0.1+0.9))*M_PI*0.5);
comp_29=`ret*=ret;
comp_30=`}
