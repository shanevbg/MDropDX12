shape_0_per_frame1=is=instance+.5; in=instance; num=num_inst; smpl=is/num; sample=in/num; div=1/num; pls=in*2-is; wrp=(x-.5+cos(div*time*(y+x)-smpl))+(sample-y)-pls*sigmoid(x,y*bass_att);
shape_0_per_frame2=lfo=1+1*sin(time/reg19); lfo1=sin(time*1/fps)*pls+(in+mid_att); adc=above(count,num); count=if(adc,0,.2/fps+count); adc2=above(coun2,num); coun2=if(adc2,0,adc+coun2); 
shape_0_per_frame3=each=equal(in, int(count)); simp=sample*2-1;
shape_0_per_frame4=b1=bass_att; m1=mid_att; t1=treb_att; 
shape_0_per_frame5=b2=bass; m2=mid; t2=treb;
shape_0_per_frame6=b3=above(b2,b1)*above(b1,bend);m3=above(m2,m1)*above(m1,mend);t3=above(t2,t1)*above(t1,tend);
shape_0_per_frame7=beat=(b2*b3)+(m2*m3)-(t2*t3);
shape_0_per_frame8=bend=b1; mend=m1; tend=t1;
shape_0_per_frame9=x2=sin(time+sample)*.5+.4*cos((smpl/count)*wrp);
shape_0_per_frame10=y2=smpl+(.2*pls)*sin(time+div)+.4*sin(sample*wrp);
shape_0_per_frame11=rad=.1+.02*(each*sin(div-1/count))+.02*lfo1+.3*cos(pls+q1-x);
shape_0_per_frame12=rad=if(each, .1*lfo,rad)/num;
shape_0_per_frame13=
shape_0_per_frame14=x=(x2*.15)+.5; y=(y2*.15)+.5;
shape_0_per_frame15=x=x+reg20;
shape_0_per_frame16=
shape_0_per_frame17=lfo=1+1*cos(time*b1+m1/reg19); 
shape_0_per_frame18=x=x+(.2*lfo)*sin(simp+sample*time);
shape_0_per_frame19=y=y+(.2*lfo)*cos(simp+sample*time);
