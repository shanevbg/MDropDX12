warp_11=`ret +=lerp((.71*q22)* tex2d(sampler_rand01 ,uv_orig),(.71*q23)* tex2d(sampler_rand02 ,uv_orig), ret*2-1);
warp_12=`//ret +=1*(0.7+0.3*cos(frame/fps+mid_att+bass_att%frame/1000/frame))- tex2d(sampler_rand02 ,uv_orig);
warp_13=`    ret -=.34;//= 0.795; //or try: ret -= 0.004;
warp_14=`
warp_15=`}
comp_1=`sampler sampler_rand00;
comp_2=`
