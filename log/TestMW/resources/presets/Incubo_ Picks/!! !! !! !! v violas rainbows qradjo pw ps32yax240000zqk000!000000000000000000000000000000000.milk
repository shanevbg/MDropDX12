per_frame_init_1=proxy = 3; pos_z = proxy*100;
per_frame_init_2=movz = 0;
per_frame_init_3=avg = 0;
per_frame_init_4=avg_= 2;
per_frame_1=dec_m = pow (0.95, 30/fps); dec_s = pow (0.99, 30/fps);
per_frame_2=
per_frame_3=beat = bass+mid+treb; 
per_frame_4=avg = avg*dec_s + beat*(1-dec_s);
per_frame_5=avg_ = avg_*dec_s + avg*(1-dec_s);
per_frame_6=is_beat = above(beat, 4+avg+peak) * above (time, t0+1);
per_frame_7=t0 = is_beat*time + (1-is_beat)*t0;
per_frame_8=peak = is_beat * beat + (1-is_beat)*peak*dec_m;
per_frame_9=index = (index + is_beat) %16;
per_frame_10=//index2 = (index2 + is_beat*bnot(index))%8;
per_frame_11=q20 = avg_/3;
per_frame_12=q22 = max(0,peak-.0)+.01;
per_frame_13=q24 = is_beat;
per_frame_14=q27 = index +1;
per_frame_15=
per_frame_16=push = (avg-2.5)/3;
per_frame_17=ax = -(xang + min(max(push,-.7),.7))/3; //Divisor: 1/Frequenz
per_frame_18=
per_frame_19=ax = if (below(ax,0),ax*2,ax);
per_frame_20=vx = vx *(1-1/fps)+ ax/fps; //1/fps: Daempfung
per_frame_21=xang = xang + vx/fps; 
per_frame_22=// WINKEL
per_frame_23=zang = 0; 
per_frame_24=yang = - .5*sin(time/16); 
per_frame_25=//yang = .7;
per_frame_26=
per_frame_27=//BEWEGUNG
per_frame_28=movz= if(above(avg_/3,1.2),1,movz);
per_frame_29=movz = if(below(avg_/3,.9),-1,movz);
per_frame_30=proxy = proxy + movz/fps/4;
per_frame_31=proxy = min(max(proxy,1.1),4);
per_frame_32=proxy = 4-3*abs(sin(time/24));
per_frame_33=pos_z = dec_s * pos_z + (1-dec_s)*proxy*100;
per_frame_34=
per_frame_35=trelx = trelx + .1*sin(time/11)/fps*yang;
per_frame_36=q5 = trelx;
per_frame_37=trely = trely + xang*.2/fps; q6 = trely;
per_frame_38=//q6 = time*.03;
per_frame_39=vleaf = vleaf + (avg/64)/fps;
per_frame_40=q29 = vleaf;
per_frame_41=lrot = lrot + bass_att/fps*.2;
per_frame_42=q32 = lrot;
per_frame_43=
per_frame_44=ox = 0; oy = 0; oz = pos_z;
per_frame_45=mx = ox*cos(zang) - oy*sin(zang);
per_frame_46=my = ox*sin(zang) + oy*cos(zang);
per_frame_47=ox = mx;oy = my;
per_frame_48=mx = ox*cos(yang) + oz*sin(yang);
per_frame_49=mz = - ox*sin(yang) + oz*cos(yang);
per_frame_50=ox = mx;oz = mz;
per_frame_51=my = oy*cos(xang) - oz*sin(xang);
per_frame_52=mz = oy*sin(xang) + oz*cos(xang);
per_frame_53=oy = my;oz = mz;
per_frame_54=q11=ox; q12 = oy; q13 = oz; //Position
per_frame_55=
per_frame_56=//Vektor x nach rechts
per_frame_57=ox = 1; oy = 0; oz = 0;
per_frame_58=mx = ox*cos(zang) - oy*sin(zang);
per_frame_59=my = ox*sin(zang) + oy*cos(zang);
per_frame_60=ox = mx;oy = my;
per_frame_61=mx = ox*cos(yang) + oz*sin(yang);
per_frame_62=mz = - ox*sin(yang) + oz*cos(yang);
per_frame_63=ox = mx;oz = mz;
per_frame_64=my = oy*cos(xang) - oz*sin(xang);
per_frame_65=mz = oy*sin(xang) + oz*cos(xang);
per_frame_66=oy = my;oz = mz;
per_frame_67=q14=ox; q15 = oy; q16 = oz;
per_frame_68=
per_frame_69=
per_frame_70=//Vektor z nach hinten
per_frame_71=ox = 0; oy = 0; oz = 1;;
per_frame_72=
per_frame_73=mx = ox*cos(zang) - oy*sin(zang);
per_frame_74=my = ox*sin(zang) + oy*cos(zang);
per_frame_75=ox = mx;oy = my;
per_frame_76=mx = ox*cos(yang) + oz*sin(yang);
per_frame_77=mz = - ox*sin(yang) + oz*cos(yang);
per_frame_78=ox = mx;oz = mz;
per_frame_79=my = oy*cos(xang) - oz*sin(xang);
per_frame_80=mz = oy*sin(xang) + oz*cos(xang);
