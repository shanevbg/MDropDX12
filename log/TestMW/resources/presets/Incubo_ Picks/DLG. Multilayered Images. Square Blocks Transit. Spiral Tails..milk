per_frame_2=
per_frame_3=wave_r = 0.7 + 0.4*sin((time+treb_mem)*0.133);
per_frame_4=wave_g = 0.7 + 0.4*sin((time+treb_mem)*0.2333);
per_frame_5=wave_b = 0.7 + 0.4*cos((time+treb_mem)*0.3533);
