per_frame_init_1=wave_a=0;
per_frame_1=monitor=mid_att*3;
per_frame_2=q1=monitor;
per_frame_3=q2=1;
per_frame_4=
per_frame_5=
per_frame_6=zoom=zoom+bass_att/15;
per_frame_7=
per_frame_8=//This code is built by me.
per_frame_9=
per_frame_10=q3=max(0,bass_att-1)*0.008;
per_frame_11=dx=dx+q3*sin(time*71.2);
per_frame_12=dy=dy+q3*cos(time*97.2);
per_frame_13=
per_frame_14=//Credit to Geiss for the Shake code.
warp_1=`sampler sampler_Disco_Seq1;
warp_2=`sampler sampler_Disco_Seq2;
warp_3=`sampler sampler_Disco_Seq3;
warp_4=`sampler sampler_Disco_Seq4;
warp_5=`sampler sampler_Disco_Seq5;
warp_6=`sampler sampler_Disco_Seq6;
warp_7=`sampler sampler_Disco_Seq7;
warp_8=`
warp_9=`static const float4 texsize_001 = float4 (542,721,1.0/542,1.0/721);
warp_10=`
warp_11=`float2 uv1, uv2, uv3;
warp_12=`
warp_13=`shader_body {
warp_14=`if (q1>=1) {ret = tex2D (sampler_Disco_Seq1, uv);}
warp_15=`if (q1>=2) {ret = tex2D (sampler_Disco_Seq2, uv);}
warp_16=`if (q1>=3) {ret = tex2D (sampler_Disco_Seq3, uv);}
warp_17=`if (q1>=4) {ret = tex2D (sampler_Disco_Seq4, uv);}
warp_18=`if (q1>=5) {ret = tex2D (sampler_Disco_Seq5, uv);}
warp_19=`if (q1>=6) {ret = tex2D (sampler_Disco_Seq6, uv);}
warp_20=`if (q1>=7) {ret = tex2D (sampler_Disco_Seq7, uv);}
warp_21=`
warp_22=`ret *= q2;
warp_23=`ret = lerp (ret, GetPixel(uv), 0.05);
warp_24=`
warp_25=`//Credit to xmuzack and my edited code.
warp_26=`
warp_27=`}
comp_1=`float2 d, uv_y;
comp_2=`float3 dx, dy;
comp_3=`shader_body
comp_4=`{
comp_5=`
comp_6=` float zoom =1.81;
comp_7=` float2 c = float2(0.448+q9,0.701+q10);
comp_8=` float2 my_uv2 = (uv-0.5)*zoom;
comp_9=` my_uv2 = float2(my_uv2.x*my_uv2.x - my_uv2.y*my_uv2.y, 2*my_uv2.x*my_uv2.y) + c;
comp_10=`my_uv2=abs(frac(my_uv2+.5)-.5) ;
comp_11=` float julia = GetPixel(my_uv2).z;
comp_12=`
comp_13=`    d = texsize.zw*3;
comp_14=`    dx = ( GetBlur1(uv+float2(1,0)*d)-GetBlur1(uv-float2(1,0)*d) );
comp_15=`    dy = ( GetBlur1(uv+float2(0,1)*d)-GetBlur1(uv-float2(0,1)*d) );
comp_16=`
comp_17=`float3 base = GetPixel(uv);
comp_18=`float3 emboss = (-dx + dy + 1)*1.4;
comp_19=`float grad_x = length(float2(dx.x,dy.x));
comp_20=`float grad_y = length(float2(dx.y,dy.y));
comp_21=`
comp_22=`
comp_23=`ret = lerp( float3(0.6,0.5,0.4)*base.x*emboss.x,
comp_24=`            float3(4,2,1)*grad_x,
comp_25=`            grad_x*2
comp_26=`          ); 
comp_27=`
comp_28=`
comp_29=`ret = lerp(ret, float3(0.3,0,0), julia*4);
comp_30=`ret = lerp(ret, float3(0,0,1.4), grad_y*1.4);
comp_31=`ret = lerp(ret, 0.5, base.y*2);
comp_32=`    ret *= .2+bass_att/3; //bass-reacted gamma
comp_33=`}
